# === 0.7.0 security audit regression tests (t71-t78) ===
# Audit doc: docs/audit/2026-05-23-audit.md
# Fixes: H1 (CLI subject CRLF), H2 (--board path-traversal), H3
# (post_from re-validation), M3 (parse_post_id overflow cap).

# H1 — header_text_ok rejects CR/LF/NUL/ESC/C0 + accepts TAB/printable.
fn t71_header_text_ok_filters_control(): i64 {
    # Rejected
    if (header_text_ok(0)    != 0) { test_fail("t71_header_text_ok_filters_control", "NUL accepted"); return 1; }
    if (header_text_ok(10)   != 0) { test_fail("t71_header_text_ok_filters_control", "LF accepted"); return 1; }
    if (header_text_ok(13)   != 0) { test_fail("t71_header_text_ok_filters_control", "CR accepted"); return 1; }
    if (header_text_ok(0x1B) != 0) { test_fail("t71_header_text_ok_filters_control", "ESC accepted"); return 1; }
    if (header_text_ok(7)    != 0) { test_fail("t71_header_text_ok_filters_control", "BEL accepted"); return 1; }
    if (header_text_ok(31)   != 0) { test_fail("t71_header_text_ok_filters_control", "0x1F accepted"); return 1; }
    # Accepted
    if (header_text_ok(9)    != 1) { test_fail("t71_header_text_ok_filters_control", "TAB rejected"); return 1; }
    if (header_text_ok(32)   != 1) { test_fail("t71_header_text_ok_filters_control", "SP rejected"); return 1; }
    if (header_text_ok(65)   != 1) { test_fail("t71_header_text_ok_filters_control", "'A' rejected"); return 1; }
    if (header_text_ok(126)  != 1) { test_fail("t71_header_text_ok_filters_control", "'~' rejected"); return 1; }
    if (header_text_ok(200)  != 1) { test_fail("t71_header_text_ok_filters_control", "UTF-8 high byte rejected"); return 1; }
    test_pass("t71_header_text_ok_filters_control");
    return 0;
}

# H1 — header_text_buf_ok scans a buffer and rejects on first bad byte.
fn t72_header_text_buf_ok_rejects_injection(): i64 {
    # Innocuous subject
    if (header_text_buf_ok("Hello world", 11) != 1) {
        test_fail("t72_header_text_buf_ok_rejects_injection", "clean subject rejected");
        return 1;
    }
    # CRLF injection attempt: "foo\r\nReply-To: 1"
    var inject[32];
    memcpy(&inject, "foo", 3);
    store8((&inject) + 3, 13);
    store8((&inject) + 4, 10);
    memcpy((&inject) + 5, "Reply-To: 1", 11);
    if (header_text_buf_ok(&inject, 16) != 0) {
        test_fail("t72_header_text_buf_ok_rejects_injection", "CRLF-injected subject accepted");
        return 1;
    }
    # Lone LF (Unix newline) — also must be rejected.
    if (header_text_buf_ok("foo\nbar", 7) != 0) {
        test_fail("t72_header_text_buf_ok_rejects_injection", "lone-LF subject accepted");
        return 1;
    }
    # cstring variant
    if (header_text_cstr_ok("clean subject") != 1) {
        test_fail("t72_header_text_buf_ok_rejects_injection", "cstr clean rejected");
        return 1;
    }
    if (header_text_cstr_ok(0) != 1) {
        test_fail("t72_header_text_buf_ok_rejects_injection", "cstr NULL not treated as empty");
        return 1;
    }
    test_pass("t72_header_text_buf_ok_rejects_injection");
    return 0;
}

# H3 — fp16_valid: exactly 16 lowercase hex.
fn t73_fp16_valid_accepts(): i64 {
    if (fp16_valid("0123456789abcdef") != 1) {
        test_fail("t73_fp16_valid_accepts", "16 lowercase hex rejected");
        return 1;
    }
    if (fp16_valid("a0b1c2d3e4f50607") != 1) {
        test_fail("t73_fp16_valid_accepts", "mixed-position hex rejected");
        return 1;
    }
    test_pass("t73_fp16_valid_accepts");
    return 0;
}

fn t74_fp16_valid_rejects(): i64 {
    if (fp16_valid(0) != 0) {
        test_fail("t74_fp16_valid_rejects", "NULL accepted");
        return 1;
    }
    if (fp16_valid("") != 0) {
        test_fail("t74_fp16_valid_rejects", "empty accepted");
        return 1;
    }
    if (fp16_valid("ABCDEF0123456789") != 0) {
        test_fail("t74_fp16_valid_rejects", "uppercase accepted");
        return 1;
    }
    if (fp16_valid("0123456789abcde") != 0) {       # 15 chars
        test_fail("t74_fp16_valid_rejects", "15-char accepted");
        return 1;
    }
    if (fp16_valid("0123456789abcdef0") != 0) {     # 17 chars
        test_fail("t74_fp16_valid_rejects", "17-char accepted");
        return 1;
    }
    if (fp16_valid("0123456789abcdez") != 0) {      # bad char at end
        test_fail("t74_fp16_valid_rejects", "non-hex accepted");
        return 1;
    }
    test_pass("t74_fp16_valid_rejects");
    return 0;
}

# H3 — post_from treats a malformed handle (would-be CRLF injection
# from a tampered .users/<fp>/handle file) as anonymous.
fn t75_post_from_rejects_invalid_handle(): i64 {
    # Build a header block whose From: handle contains a CR.
    # Note: handle_valid alphabet is [a-z0-9_-]; a literal CR doesn't
    # survive header_get's line-terminator scan. But uppercase letters
    # ALSO fail handle_valid — use those to exercise the re-validate.
    var raw = "Subject: x\r\nFrom: BadHandle 0123456789abcdef\r\n\r\nbody";
    var hbuf[64];
    var fpbuf[20];
    var rc = post_from(raw, strlen(raw), &hbuf, 64, &fpbuf, 20);
    if (rc != 0) {
        test_fail("t75_post_from_rejects_invalid_handle", "uppercase handle accepted");
        return 1;
    }
    # Both output buffers must be cleared (empty cstring).
    if ((load8(&hbuf) & 0xFF) != 0) {
        test_fail("t75_post_from_rejects_invalid_handle", "handle_out not cleared");
        return 1;
    }
    if ((load8(&fpbuf) & 0xFF) != 0) {
        test_fail("t75_post_from_rejects_invalid_handle", "fp_out not cleared");
        return 1;
    }
    test_pass("t75_post_from_rejects_invalid_handle");
    return 0;
}

# H3 — post_from rejects malformed fingerprint (wrong length / case).
fn t76_post_from_rejects_invalid_fp(): i64 {
    # 17-char fp — fp16_valid rejects, post_from returns 0.
    var raw = "Subject: x\r\nFrom: alice 0123456789abcdef0\r\n\r\nbody";
    var hbuf[64];
    var fpbuf[20];
    if (post_from(raw, strlen(raw), &hbuf, 64, &fpbuf, 20) != 0) {
        test_fail("t76_post_from_rejects_invalid_fp", "17-char fp accepted");
        return 1;
    }
    # Uppercase fp — also rejected.
    var raw2 = "Subject: x\r\nFrom: alice ABCDEF0123456789\r\n\r\nbody";
    var hbuf2[64];
    var fpbuf2[20];
    if (post_from(raw2, strlen(raw2), &hbuf2, 64, &fpbuf2, 20) != 0) {
        test_fail("t76_post_from_rejects_invalid_fp", "uppercase fp accepted");
        return 1;
    }
    # Sanity: a valid handle + valid fp does pass.
    var ok_raw = "Subject: x\r\nFrom: alice 0123456789abcdef\r\n\r\nbody";
    var hbuf3[64];
    var fpbuf3[20];
    if (post_from(ok_raw, strlen(ok_raw), &hbuf3, 64, &fpbuf3, 20) != 1) {
        test_fail("t76_post_from_rejects_invalid_fp", "valid From rejected");
        return 1;
    }
    if (streq(&hbuf3, "alice") == 0) {
        test_fail("t76_post_from_rejects_invalid_fp", "valid handle not extracted");
        return 1;
    }
    if (streq(&fpbuf3, "0123456789abcdef") == 0) {
        test_fail("t76_post_from_rejects_invalid_fp", "valid fp not extracted");
        return 1;
    }
    test_pass("t76_post_from_rejects_invalid_fp");
    return 0;
}

# M3 — parse_post_id caps the digit prefix at 18 (i64 overflow guard).
fn t77_parse_post_id_rejects_overlong_digits(): i64 {
    # 19-digit prefix would wrap i64; reject.
    if (parse_post_id("1234567890123456789.txt") != 0) {
        test_fail("t77_parse_post_id_rejects_overlong_digits", "19-digit accepted");
        return 1;
    }
    # 20-digit prefix — also reject.
    if (parse_post_id("12345678901234567890.txt") != 0) {
        test_fail("t77_parse_post_id_rejects_overlong_digits", "20-digit accepted");
        return 1;
    }
    test_pass("t77_parse_post_id_rejects_overlong_digits");
    return 0;
}

fn t78_parse_post_id_accepts_18_digits(): i64 {
    # 18-digit prefix is exactly at the i64 ceiling — accept.
    var id = parse_post_id("100000000000000000.txt");
    if (id != 100000000000000000) {
        test_fail("t78_parse_post_id_accepts_18_digits", "18-digit value mis-parsed");
        return 1;
    }
    test_pass("t78_parse_post_id_accepts_18_digits");
    return 0;
}

# === 0.8.1 audit-L1 regression (t79) ===
# Audit doc: docs/audit/2026-05-23-audit.md § L1.

# A-1 — mode_is_loose: pure bit-math gate for keyfile-mode warn.
# Tight modes (owner-only): 0o600 / 0o700 / 0o400 → 0.
# Loose modes (any g/o bit): 0o644 / 0o660 / 0o604 / 0o666 → 1.
fn t79_mode_is_loose(): i64 {
    # Tight (owner-only) modes — must return 0.
    if (mode_is_loose(0x180) != 0) {                  # 0o600 rw- --- ---
        test_fail("t79_mode_is_loose", "0o600 misclassified as loose");
        return 1;
    }
    if (mode_is_loose(0x1C0) != 0) {                  # 0o700 rwx --- ---
        test_fail("t79_mode_is_loose", "0o700 misclassified as loose");
        return 1;
    }
    if (mode_is_loose(0x100) != 0) {                  # 0o400 r-- --- ---
        test_fail("t79_mode_is_loose", "0o400 misclassified as loose");
        return 1;
    }
    if (mode_is_loose(0) != 0) {                      # 0o000
        test_fail("t79_mode_is_loose", "0o000 misclassified as loose");
        return 1;
    }
    # Loose modes — must return 1.
    if (mode_is_loose(0x1A4) != 1) {                  # 0o644 rw- r-- r--
        test_fail("t79_mode_is_loose", "0o644 not detected as loose");
        return 1;
    }
    if (mode_is_loose(0x1B0) != 1) {                  # 0o660 rw- rw- ---
        test_fail("t79_mode_is_loose", "0o660 not detected as loose");
        return 1;
    }
    if (mode_is_loose(0x184) != 1) {                  # 0o604 rw- --- r--
        test_fail("t79_mode_is_loose", "0o604 not detected as loose");
        return 1;
    }
    if (mode_is_loose(0x1B6) != 1) {                  # 0o666 rw- rw- rw-
        test_fail("t79_mode_is_loose", "0o666 not detected as loose");
        return 1;
    }
    # Edge: only an other-execute bit (0o001) → loose.
    if (mode_is_loose(0x181) != 1) {                  # 0o601 rw- --- --x
        test_fail("t79_mode_is_loose", "0o601 not detected as loose");
        return 1;
    }
    # Edge: only a group-execute bit (0o010) → loose.
    if (mode_is_loose(0x188) != 1) {                  # 0o610 rw- --x ---
        test_fail("t79_mode_is_loose", "0o610 not detected as loose");
        return 1;
    }
    # High bits (setuid / type bits above 0o7777) must NOT trigger.
    # 0o100600 (regular file + 0o600) is a common st_mode value;
    # only the low 0o777 should matter for our check.
    if (mode_is_loose(0x8180) != 0) {                 # 0o100600 (S_IFREG | 0o600)
        test_fail("t79_mode_is_loose", "S_IFREG|0o600 (regular file, tight) misclassified");
        return 1;
    }
    test_pass("t79_mode_is_loose");
    return 0;
}

# === 0.8.3 audit-M4 regression (t80) ===
# Audit doc: docs/audit/2026-05-23-audit.md § M4.

# B-1 — board_exists treats "main" as always-existing and rejects
# missing-named-board lookups on a nonexistent store.
fn t80_board_exists_main_and_missing(): i64 {
    # "main" is the implicit flat root — always counts as existing
    # regardless of the store dir's state.
    if (board_exists("/nonexistent/store/that/should/not/exist", "main") != 1) {
        test_fail("t80_board_exists_main_and_missing", "main not treated as always-existing");
        return 1;
    }
    if (board_exists("/", "main") != 1) {
        test_fail("t80_board_exists_main_and_missing", "main rejected for / store");
        return 1;
    }
    # A named board under a guaranteed-missing path → 0.
    if (board_exists("/nonexistent/store/that/should/not/exist", "qix") != 0) {
        test_fail("t80_board_exists_main_and_missing", "missing named board reported as existing");
        return 1;
    }
    # /tmp definitely exists; a path with a long-random suffix definitely doesn't.
    if (board_exists("/tmp", "pac-zax-dig-jst-9q8w7e6r5t4y3u2i1o-not-here") != 0) {
        test_fail("t80_board_exists_main_and_missing", "missing named board under /tmp reported as existing");
        return 1;
    }
    test_pass("t80_board_exists_main_and_missing");
    return 0;
}

# === 1.1.0 door framework (t81-t86, ADR 0009) ===
# Pure-logic coverage for src/door.cyr: PRNG determinism + bounds,
# the logical-shift helper, integer helpers, the save-slot name
# validator (path-traversal guard), and the save-path builders.

# Same seed → identical stream; distinct seeds → distinct streams.
fn t81_rng_deterministic(): i64 {
    var a = alloc(8);
    var b = alloc(8);
    rng_seed(a, 12345);
    rng_seed(b, 12345);
    var i = 0;
    while (i < 32) {
        if (rng_next(a) != rng_next(b)) {
            test_fail("t81_rng_deterministic", "same seed diverged");
            return 1;
        }
        i = i + 1;
    }
    var c = alloc(8);
    var d = alloc(8);
    rng_seed(c, 999983);
    rng_seed(d, 12345);
    if (rng_next(c) == rng_next(d)) {
        test_fail("t81_rng_deterministic", "distinct seeds collided");
        return 1;
    }
    test_pass("t81_rng_deterministic");
    return 0;
}

# rng_range stays in [lo,hi]; degenerate ranges + rng_below(<=1) are 0;
# a [0,1] roll eventually shows both ends (no stuck low bit).
fn t82_rng_range_bounds(): i64 {
    var s = alloc(8);
    rng_seed(s, 4242);
    var i = 0;
    while (i < 500) {
        var r = rng_range(s, 5, 10);
        if (r < 5)  { test_fail("t82_rng_range_bounds", "below lo");  return 1; }
        if (r > 10) { test_fail("t82_rng_range_bounds", "above hi");  return 1; }
        i = i + 1;
    }
    if (rng_range(s, 7, 7) != 7) { test_fail("t82_rng_range_bounds", "degenerate range"); return 1; }
    if (rng_below(s, 1) != 0)    { test_fail("t82_rng_range_bounds", "below(1) not 0");   return 1; }
    if (rng_below(s, 0) != 0)    { test_fail("t82_rng_range_bounds", "below(0) not 0");   return 1; }
    var saw0 = 0;
    var saw1 = 0;
    var j = 0;
    while (j < 200) {
        var v = rng_range(s, 0, 1);
        if (v == 0) { saw0 = 1; }
        if (v == 1) { saw1 = 1; }
        j = j + 1;
    }
    if (saw0 == 0) { test_fail("t82_rng_range_bounds", "never saw 0"); return 1; }
    if (saw1 == 0) { test_fail("t82_rng_range_bounds", "never saw 1"); return 1; }
    test_pass("t82_rng_range_bounds");
    return 0;
}

# lshr is a true logical shift even on a negative (all-ones) cell.
fn t83_lshr_logical(): i64 {
    if (lshr(0 - 1, 63) != 1) { test_fail("t83_lshr_logical", "all-ones>>63 != 1"); return 1; }
    if (lshr(1024, 5)  != 32) { test_fail("t83_lshr_logical", "1024>>5 != 32");     return 1; }
    if (lshr(255, 4)   != 15) { test_fail("t83_lshr_logical", "255>>4 != 15");      return 1; }
    if (lshr(8, 0)     != 8)  { test_fail("t83_lshr_logical", "k=0 passthrough");   return 1; }
    if (lshr(0 - 1, 1) < 0)   { test_fail("t83_lshr_logical", "top bit not cleared"); return 1; }
    test_pass("t83_lshr_logical");
    return 0;
}

fn t84_int_helpers(): i64 {
    if (imin(3, 7) != 3)            { test_fail("t84_int_helpers", "imin");      return 1; }
    if (imin(7, 3) != 3)            { test_fail("t84_int_helpers", "imin rev");  return 1; }
    if (imax(3, 7) != 7)            { test_fail("t84_int_helpers", "imax");      return 1; }
    if (iclamp(5, 0, 10) != 5)      { test_fail("t84_int_helpers", "clamp mid"); return 1; }
    if (iclamp(0 - 3, 0, 10) != 0)  { test_fail("t84_int_helpers", "clamp lo");  return 1; }
    if (iclamp(99, 0, 10) != 10)    { test_fail("t84_int_helpers", "clamp hi");  return 1; }
    if (iabs(0 - 5) != 5)           { test_fail("t84_int_helpers", "iabs neg");  return 1; }
    if (iabs(5) != 5)               { test_fail("t84_int_helpers", "iabs pos");  return 1; }
    if (ipow(2, 10) != 1024)        { test_fail("t84_int_helpers", "pow 2^10");  return 1; }
    if (ipow(5, 0) != 1)            { test_fail("t84_int_helpers", "pow x^0");   return 1; }
    if (ipow(3, 3) != 27)           { test_fail("t84_int_helpers", "pow 3^3");   return 1; }
    test_pass("t84_int_helpers");
    return 0;
}

# game_name_valid is the only traversal guard on <game>.sav.
fn t85_game_name_valid(): i64 {
    if (game_name_valid("smuggler") != 1)       { test_fail("t85_game_name_valid", "smuggler");        return 1; }
    if (game_name_valid("port-authority") != 1) { test_fail("t85_game_name_valid", "port-authority");  return 1; }
    if (game_name_valid("handler") != 1)        { test_fail("t85_game_name_valid", "handler");         return 1; }
    if (game_name_valid("game_2") != 1)         { test_fail("t85_game_name_valid", "game_2");          return 1; }
    if (game_name_valid("a") != 1)              { test_fail("t85_game_name_valid", "a");               return 1; }
    if (game_name_valid("") != 0)               { test_fail("t85_game_name_valid", "empty");           return 1; }
    if (game_name_valid("Bad") != 0)            { test_fail("t85_game_name_valid", "uppercase");       return 1; }
    if (game_name_valid(".hidden") != 0)        { test_fail("t85_game_name_valid", "dot");             return 1; }
    if (game_name_valid("../etc") != 0)         { test_fail("t85_game_name_valid", "traversal");       return 1; }
    if (game_name_valid("a/b") != 0)            { test_fail("t85_game_name_valid", "slash");           return 1; }
    if (game_name_valid("-x") != 0)             { test_fail("t85_game_name_valid", "lead dash");       return 1; }
    if (game_name_valid("_y") != 0)             { test_fail("t85_game_name_valid", "lead underscore"); return 1; }
    if (game_name_valid("aaaaaaaaaabbbbbbbbbbccccccccccddd") != 0) { test_fail("t85_game_name_valid", "33 chars"); return 1; }
    test_pass("t85_game_name_valid");
    return 0;
}

# Save-path builders assemble the expected <store>/.users/<fp>/games tree.
fn t86_door_save_path(): i64 {
    var buf = alloc(PATH_MAX_BYTES);
    var n = door_save_path("store", "aabbccddeeff0011", "smuggler", buf);
    if (streq(buf, "store/.users/aabbccddeeff0011/games/smuggler.sav") == 0) {
        test_fail("t86_door_save_path", "save path mismatch");
        return 1;
    }
    if (n != 48) { test_fail("t86_door_save_path", "save path length"); return 1; }
    var dbuf = alloc(PATH_MAX_BYTES);
    var dn = door_games_dir("store", "aabbccddeeff0011", dbuf);
    if (streq(dbuf, "store/.users/aabbccddeeff0011/games") == 0) {
        test_fail("t86_door_save_path", "games dir mismatch");
        return 1;
    }
    if (dn != 35) { test_fail("t86_door_save_path", "games dir length"); return 1; }
    test_pass("t86_door_save_path");
    return 0;
}

# === 1.1.0 Smuggler's Ledger economy core (t87-t93, ADR 0009) ===
# Pure economy/finance coverage for src/smuggler.cyr.

fn t87_sl_new_defaults(): i64 {
    var st = sl_new(42, DOOR_SOLO, SL_DEF_DAYS);
    if (load64(st + SL_CASH) != SL_START_CASH)   { test_fail("t87_sl_new_defaults", "cash");    return 1; }
    if (load64(st + SL_DEBT) != SL_START_DEBT)   { test_fail("t87_sl_new_defaults", "debt");    return 1; }
    if (load64(st + SL_DAY) != 1)                { test_fail("t87_sl_new_defaults", "day");     return 1; }
    if (load64(st + SL_CAP) != SL_START_CAP)     { test_fail("t87_sl_new_defaults", "cap");     return 1; }
    if (load64(st + SL_HEALTH) != SL_START_HP)   { test_fail("t87_sl_new_defaults", "hp");      return 1; }
    if (sl_capacity_used(st) != 0)               { test_fail("t87_sl_new_defaults", "inv");     return 1; }
    if (sl_net_worth(st) != SL_START_CASH - SL_START_DEBT) { test_fail("t87_sl_new_defaults", "networth"); return 1; }
    test_pass("t87_sl_new_defaults");
    return 0;
}

fn t88_sl_buy_sell(): i64 {
    var st = sl_new(1, DOOR_PRACTICE, SL_DEF_DAYS);
    if (sl_buy(st, 0, 20, 10) != 0)     { test_fail("t88_sl_buy_sell", "buy failed");     return 1; }
    if (load64(st + SL_CASH) != 1800)   { test_fail("t88_sl_buy_sell", "cash after buy"); return 1; }
    if (sl_inv(st, 0) != 10)            { test_fail("t88_sl_buy_sell", "inv after buy");  return 1; }
    if (sl_capacity_used(st) != 10)     { test_fail("t88_sl_buy_sell", "cap used");       return 1; }
    if (sl_sell(st, 0, 30, 5) != 0)     { test_fail("t88_sl_buy_sell", "sell failed");    return 1; }
    if (load64(st + SL_CASH) != 1950)   { test_fail("t88_sl_buy_sell", "cash after sell");return 1; }
    if (sl_inv(st, 0) != 5)             { test_fail("t88_sl_buy_sell", "inv after sell"); return 1; }
    test_pass("t88_sl_buy_sell");
    return 0;
}

fn t89_sl_buy_sell_guards(): i64 {
    var st = sl_new(1, DOOR_PRACTICE, SL_DEF_DAYS);
    if (sl_buy(st, 0, 100000, 1) != (0 - 2)) { test_fail("t89_sl_buy_sell_guards", "cash guard"); return 1; }
    if (sl_buy(st, 99, 10, 1) != (0 - 1))    { test_fail("t89_sl_buy_sell_guards", "good guard"); return 1; }
    if (sl_buy(st, 0, 0, 1) != (0 - 4))      { test_fail("t89_sl_buy_sell_guards", "price guard");return 1; }
    if (sl_buy(st, 0, 10, 0) != (0 - 4))     { test_fail("t89_sl_buy_sell_guards", "qty guard");  return 1; }
    if (sl_buy(st, 0, 1, 200) != (0 - 3))    { test_fail("t89_sl_buy_sell_guards", "cap guard");  return 1; }
    if (sl_sell(st, 0, 10, 1) != (0 - 5))    { test_fail("t89_sl_buy_sell_guards", "sell guard"); return 1; }
    test_pass("t89_sl_buy_sell_guards");
    return 0;
}

fn t90_sl_capacity(): i64 {
    var st = sl_new(1, DOOR_PRACTICE, SL_DEF_DAYS);
    if (sl_buy(st, 1, 1, 100) != 0)       { test_fail("t90_sl_capacity", "fill failed");    return 1; }
    if (sl_capacity_free(st) != 0)        { test_fail("t90_sl_capacity", "free not 0");     return 1; }
    if (sl_buy(st, 2, 1, 1) != (0 - 3))   { test_fail("t90_sl_capacity", "overfill allowed");return 1; }
    test_pass("t90_sl_capacity");
    return 0;
}

fn t91_sl_finances(): i64 {
    var st = sl_new(1, DOOR_PRACTICE, SL_DEF_DAYS);
    if (sl_deposit(st, 500) != 0)      { test_fail("t91_sl_finances", "deposit");        return 1; }
    if (load64(st + SL_CASH) != 1500)  { test_fail("t91_sl_finances", "cash post-dep");   return 1; }
    if (load64(st + SL_BANK) != 500)   { test_fail("t91_sl_finances", "bank post-dep");   return 1; }
    if (sl_withdraw(st, 200) != 0)     { test_fail("t91_sl_finances", "withdraw");        return 1; }
    if (load64(st + SL_CASH) != 1700)  { test_fail("t91_sl_finances", "cash post-wd");    return 1; }
    if (sl_repay(st, 1000) != 0)       { test_fail("t91_sl_finances", "repay");           return 1; }
    if (load64(st + SL_DEBT) != 4500)  { test_fail("t91_sl_finances", "debt post-repay"); return 1; }
    if (load64(st + SL_CASH) != 700)   { test_fail("t91_sl_finances", "cash post-repay"); return 1; }
    sl_accrue_debt(st);
    if (load64(st + SL_DEBT) != 4950)  { test_fail("t91_sl_finances", "debt accrual");    return 1; }
    if (sl_borrow(st, 1000) != 0)      { test_fail("t91_sl_finances", "borrow");          return 1; }
    if (load64(st + SL_DEBT) != 5950)  { test_fail("t91_sl_finances", "debt post-borrow");return 1; }
    if (load64(st + SL_CASH) != 1700)  { test_fail("t91_sl_finances", "cash post-borrow");return 1; }
    test_pass("t91_sl_finances");
    return 0;
}

fn t92_sl_price_determinism(): i64 {
    var p1 = alloc(SL_GOODS * 8);
    var p2 = alloc(SL_GOODS * 8);
    var e1 = alloc(16);
    var e2 = alloc(16);
    sl_gen_prices(777, 3, p1, e1);
    sl_gen_prices(777, 3, p2, e2);
    var i = 0;
    while (i < SL_GOODS) {
        if (load64(p1 + i * 8) != load64(p2 + i * 8)) {
            test_fail("t92_sl_price_determinism", "price differs same seed/day");
            return 1;
        }
        i = i + 1;
    }
    if (load64(e1) != load64(e2))         { test_fail("t92_sl_price_determinism", "event kind differs"); return 1; }
    if (load64(e1 + 8) != load64(e2 + 8)) { test_fail("t92_sl_price_determinism", "event good differs"); return 1; }
    test_pass("t92_sl_price_determinism");
    return 0;
}

fn t93_sl_price_ranges(): i64 {
    var prices = alloc(SL_GOODS * 8);
    var ev = alloc(16);
    var saw_unavail = 0;
    var saw_spike = 0;
    var saw_crash = 0;
    var day = 1;
    while (day <= 400) {
        sl_gen_prices(20260607, day, prices, ev);
        var kind = load64(ev);
        var egood = load64(ev + 8);
        if (kind == 1) { saw_spike = 1; }
        if (kind == 2) { saw_crash = 1; }
        var i = 0;
        while (i < SL_GOODS) {
            var pr = load64(prices + i * 8);
            if (pr == 0) { saw_unavail = 1; }
            else {
                var is_event = 0;
                if (kind != 0) { if (i == egood) { is_event = 1; } }
                if (is_event == 0) {
                    if (pr < sl_good_min(i)) { test_fail("t93_sl_price_ranges", "below min"); return 1; }
                    if (pr > sl_good_max(i)) { test_fail("t93_sl_price_ranges", "above max"); return 1; }
                }
            }
            i = i + 1;
        }
        day = day + 1;
    }
    if (saw_unavail == 0) { test_fail("t93_sl_price_ranges", "no unavailable good seen"); return 1; }
    if (saw_spike == 0)   { test_fail("t93_sl_price_ranges", "no spike seen");            return 1; }
    if (saw_crash == 0)   { test_fail("t93_sl_price_ranges", "no crash seen");            return 1; }
    test_pass("t93_sl_price_ranges");
    return 0;
}

# === 1.1.0 Smuggler's Ledger interactive layer (t94-t100, ADR 0009) ===

fn t94_sl_save_load(): i64 {
    var st = sl_new(0 - 123456789, DOOR_SOLO, 20);   # negative seed
    rng_seed(st + SL_RNG, 0 - 987654321);            # negative rng cell
    store64(st + SL_DAY, 7);
    store64(st + SL_LOC, 5);
    store64(st + SL_CASH, 4242);
    store64(st + SL_BANK, 999);
    store64(st + SL_DEBT, 1500);
    store64(st + SL_HEALTH, 73);
    store64(st + SL_GUNS, 2);
    store64(st + SL_CAP, 180);
    sl_set_inv(st, 0, 11);
    sl_set_inv(st, 3, 4);
    sl_set_inv(st, 7, 1);
    var buf = alloc(SL_SAVE_CAP);
    var n = sl_save_format(st, buf, SL_SAVE_CAP);
    if (n <= 0) { test_fail("t94_sl_save_load", "format len"); return 1; }
    var st2 = sl_load_parse(buf, n);
    if (st2 == 0) { test_fail("t94_sl_save_load", "parse null"); return 1; }
    if (load64(st2 + SL_SEED) != (0 - 123456789)) { test_fail("t94_sl_save_load", "seed"); return 1; }
    if (load64(st2 + SL_RNG) != (0 - 987654321))  { test_fail("t94_sl_save_load", "rng");  return 1; }
    if (load64(st2 + SL_DAY) != 7)       { test_fail("t94_sl_save_load", "day");     return 1; }
    if (load64(st2 + SL_MAXDAYS) != 20)  { test_fail("t94_sl_save_load", "maxdays"); return 1; }
    if (load64(st2 + SL_LOC) != 5)       { test_fail("t94_sl_save_load", "loc");     return 1; }
    if (load64(st2 + SL_CASH) != 4242)   { test_fail("t94_sl_save_load", "cash");    return 1; }
    if (load64(st2 + SL_BANK) != 999)    { test_fail("t94_sl_save_load", "bank");    return 1; }
    if (load64(st2 + SL_DEBT) != 1500)   { test_fail("t94_sl_save_load", "debt");    return 1; }
    if (load64(st2 + SL_HEALTH) != 73)   { test_fail("t94_sl_save_load", "health");  return 1; }
    if (load64(st2 + SL_GUNS) != 2)      { test_fail("t94_sl_save_load", "guns");    return 1; }
    if (load64(st2 + SL_CAP) != 180)     { test_fail("t94_sl_save_load", "cap");     return 1; }
    if (load64(st2 + SL_MODE) != DOOR_SOLO) { test_fail("t94_sl_save_load", "mode"); return 1; }
    if (sl_inv(st2, 0) != 11) { test_fail("t94_sl_save_load", "inv0"); return 1; }
    if (sl_inv(st2, 3) != 4)  { test_fail("t94_sl_save_load", "inv3"); return 1; }
    if (sl_inv(st2, 7) != 1)  { test_fail("t94_sl_save_load", "inv7"); return 1; }
    if (sl_inv(st2, 1) != 0)  { test_fail("t94_sl_save_load", "inv1 zero"); return 1; }
    test_pass("t94_sl_save_load");
    return 0;
}

fn t95_sl_travel(): i64 {
    var st = sl_new(3, DOOR_PRACTICE, 5);
    sl_start(st);
    var debt0 = load64(st + SL_DEBT);
    if (sl_travel(st, 2) != 0)    { test_fail("t95_sl_travel", "travel rc"); return 1; }
    if (load64(st + SL_LOC) != 2) { test_fail("t95_sl_travel", "loc");       return 1; }
    if (load64(st + SL_DAY) != 2) { test_fail("t95_sl_travel", "day");       return 1; }
    if (load64(st + SL_DEBT) != debt0 + debt0 * SL_DEBT_RATE / 100) { test_fail("t95_sl_travel", "debt accrued"); return 1; }
    if (sl_travel(st, 99) != (0 - 1)) { test_fail("t95_sl_travel", "bad dest"); return 1; }
    sl_travel(st, 1);   # day 3
    sl_travel(st, 2);   # day 4
    sl_travel(st, 1);   # day 5
    if (load64(st + SL_OVER) != 0) { test_fail("t95_sl_travel", "over too early"); return 1; }
    sl_travel(st, 2);   # day 6 > 5 -> finished
    if (load64(st + SL_OVER) != 1) { test_fail("t95_sl_travel", "not finished"); return 1; }
    test_pass("t95_sl_travel");
    return 0;
}

fn t96_sl_shops(): i64 {
    var st = sl_new(1, DOOR_PRACTICE, SL_DEF_DAYS);
    store64(st + SL_CASH, 100000);
    var cap0 = load64(st + SL_CAP);
    if (sl_buy_capacity(st) != 0)                    { test_fail("t96_sl_shops", "cap buy");        return 1; }
    if (load64(st + SL_CAP) != cap0 + SL_CAP_STEP)   { test_fail("t96_sl_shops", "cap step");       return 1; }
    if (sl_buy_gun(st) != 0)                         { test_fail("t96_sl_shops", "gun buy");        return 1; }
    if (load64(st + SL_GUNS) != 1)                   { test_fail("t96_sl_shops", "gun count");      return 1; }
    if (sl_heal(st) != (0 - 7))                      { test_fail("t96_sl_shops", "heal full guard");return 1; }
    store64(st + SL_HEALTH, 50);
    if (sl_heal(st) != 0)                            { test_fail("t96_sl_shops", "heal");           return 1; }
    if (load64(st + SL_HEALTH) != 100)               { test_fail("t96_sl_shops", "healed full");    return 1; }
    var g = 1;
    while (g < SL_GUN_MAX) { sl_buy_gun(st); g = g + 1; }
    if (sl_buy_gun(st) != (0 - 6))                   { test_fail("t96_sl_shops", "gun max");        return 1; }
    store64(st + SL_CASH, 0);
    if (sl_buy_capacity(st) != (0 - 2))              { test_fail("t96_sl_shops", "cap cash guard"); return 1; }
    test_pass("t96_sl_shops");
    return 0;
}

fn t97_sl_combat_bounds(): i64 {
    var st = sl_new(7, DOOR_PRACTICE, SL_DEF_DAYS);
    sl_start(st);
    store64(st + SL_HEALTH, 8);
    store64(st + SL_GUNS, 0);
    var died = 0;
    var n = 0;
    while (n < 60) {
        if (load64(st + SL_OVER) == 0) {
            store64(st + SL_PEND, 3);
            sl_fight(st);
            var hp = load64(st + SL_HEALTH);
            if (hp < 0)   { test_fail("t97_sl_combat_bounds", "hp negative"); return 1; }
            if (hp > 100) { test_fail("t97_sl_combat_bounds", "hp over 100"); return 1; }
            if (load64(st + SL_OVER) == 2) { died = 1; }
        }
        n = n + 1;
    }
    if (died == 0)                   { test_fail("t97_sl_combat_bounds", "never died at hp8"); return 1; }
    if (load64(st + SL_HEALTH) != 0) { test_fail("t97_sl_combat_bounds", "dead but hp!=0");   return 1; }
    test_pass("t97_sl_combat_bounds");
    return 0;
}

fn t98_sl_feed_nav(): i64 {
    var st = sl_new(11, DOOR_PRACTICE, SL_DEF_DAYS);
    sl_start(st);
    sl_feed(st, "b", 1);
    if (load64(st + SL_SCREEN) != SCR_BUY)  { test_fail("t98_sl_feed_nav", "b->buy");  return 1; }
    sl_feed(st, "x", 1);
    if (load64(st + SL_SCREEN) != SCR_MAIN) { test_fail("t98_sl_feed_nav", "x->main"); return 1; }
    store64(load64(st + SL_PRICES) + 0, 20);   # pin good 0's price for determinism
    sl_feed(st, "b", 1);
    sl_feed(st, "1", 1);
    if (load64(st + SL_SCREEN) != SCR_BUYQTY) { test_fail("t98_sl_feed_nav", "1->buyqty"); return 1; }
    sl_feed(st, "10", 2);
    if (sl_inv(st, 0) != 10)                  { test_fail("t98_sl_feed_nav", "bought 10");   return 1; }
    if (load64(st + SL_CASH) != 1800)         { test_fail("t98_sl_feed_nav", "cash after");  return 1; }
    if (load64(st + SL_SCREEN) != SCR_MAIN)   { test_fail("t98_sl_feed_nav", "back to main");return 1; }
    if (sl_feed(st, "q", 1) != 1)             { test_fail("t98_sl_feed_nav", "q exits");     return 1; }
    test_pass("t98_sl_feed_nav");
    return 0;
}

fn t99_sl_rank_tiers(): i64 {
    if (streq(sl_rank(0 - 100), "Busted Flat") == 0)  { test_fail("t99_sl_rank_tiers", "neg"); return 1; }
    if (streq(sl_rank(100), "Corner Hustler") == 0)   { test_fail("t99_sl_rank_tiers", "100"); return 1; }
    if (streq(sl_rank(30000), "District Boss") == 0)  { test_fail("t99_sl_rank_tiers", "30k"); return 1; }
    if (streq(sl_rank(1000000), "Untouchable") == 0)  { test_fail("t99_sl_rank_tiers", "1M");  return 1; }
    test_pass("t99_sl_rank_tiers");
    return 0;
}

fn t100_sl_render_nonempty(): i64 {
    var st = sl_new(5, DOOR_PRACTICE, SL_DEF_DAYS);
    sl_start(st);
    var buf = alloc(4096);
    if (sl_render(st, buf, 4096) <= 0) { test_fail("t100_sl_render_nonempty", "main empty"); return 1; }
    store64(st + SL_OVER, 1);
    store64(st + SL_SCREEN, SCR_OVER);
    if (sl_render(st, buf, 4096) <= 0) { test_fail("t100_sl_render_nonempty", "over empty"); return 1; }
    test_pass("t100_sl_render_nonempty");
    return 0;
}

# === 1.1.0 Port Authority galaxy + economy core (t101-t105, ADR 0009) ===

fn t101_pa_new_defaults(): i64 {
    var st = pa_new(99, DOOR_SOLO, PA_DEF_DAYS);
    if (load64(st + PA_CREDITS) != PA_START_CREDITS)   { test_fail("t101_pa_new_defaults", "credits"); return 1; }
    if (load64(st + PA_HOLDS) != PA_START_HOLDS)       { test_fail("t101_pa_new_defaults", "holds");   return 1; }
    if (load64(st + PA_FIGHTERS) != PA_START_FIGHTERS) { test_fail("t101_pa_new_defaults", "fighters");return 1; }
    if (load64(st + PA_SECTOR) != 0)                   { test_fail("t101_pa_new_defaults", "sector");  return 1; }
    if (load64(st + PA_TURNS) != PA_TURNS_PER_DAY)     { test_fail("t101_pa_new_defaults", "turns");   return 1; }
    if (pa_cargo_used(st) != 0)                        { test_fail("t101_pa_new_defaults", "cargo");   return 1; }
    test_pass("t101_pa_new_defaults");
    return 0;
}

fn t102_pa_galaxy_determinism(): i64 {
    var g1 = pa_galaxy_new(555);
    var g2 = pa_galaxy_new(555);
    var s = 0;
    while (s < PA_SECTORS) {
        if (pa_has_port(g1, s) != pa_has_port(g2, s)) { test_fail("t102_pa_galaxy_determinism", "port differs"); return 1; }
        var w = 0;
        while (w < PA_MAX_WARPS) {
            if (pa_warp(g1, s, w) != pa_warp(g2, s, w)) { test_fail("t102_pa_galaxy_determinism", "warp differs"); return 1; }
            w = w + 1;
        }
        var c = 0;
        while (c < PA_COMM) {
            if (pa_port_flag(g1, s, c) != pa_port_flag(g2, s, c))   { test_fail("t102_pa_galaxy_determinism", "flag differs");  return 1; }
            if (pa_port_price(g1, s, c) != pa_port_price(g2, s, c)) { test_fail("t102_pa_galaxy_determinism", "price differs"); return 1; }
            c = c + 1;
        }
        s = s + 1;
    }
    test_pass("t102_pa_galaxy_determinism");
    return 0;
}

fn t103_pa_galaxy_structure(): i64 {
    var gx = pa_galaxy_new(2024);
    if (pa_has_port(gx, 0) != 0) { test_fail("t103_pa_galaxy_structure", "HQ sector has a port"); return 1; }
    var ports_seen = 0;
    var s = 0;
    while (s < PA_SECTORS) {
        if (pa_warp_count(gx, s) < 1)            { test_fail("t103_pa_galaxy_structure", "sector with no warps"); return 1; }
        if (pa_warp_count(gx, s) > PA_MAX_WARPS) { test_fail("t103_pa_galaxy_structure", "too many warps");       return 1; }
        if (pa_has_port(gx, s) == 1) {
            ports_seen = ports_seen + 1;
            var c = 0;
            while (c < PA_COMM) {
                var flag = pa_port_flag(gx, s, c);
                if (flag != 0) {
                    var pr = pa_port_price(gx, s, c);
                    if (pr < pa_comm_min(c)) { test_fail("t103_pa_galaxy_structure", "price below band"); return 1; }
                    if (pr > pa_comm_max(c)) { test_fail("t103_pa_galaxy_structure", "price above band"); return 1; }
                }
                c = c + 1;
            }
        }
        s = s + 1;
    }
    if (ports_seen < 1) { test_fail("t103_pa_galaxy_structure", "no ports at all"); return 1; }
    test_pass("t103_pa_galaxy_structure");
    return 0;
}

fn t104_pa_trade(): i64 {
    var st = pa_new(12345, DOOR_PRACTICE, PA_DEF_DAYS);
    var gx = pa_galaxy_new(12345);
    store64(st + PA_GX, gx);
    # find any (sector, commodity) the port SELLS
    var sell_sector = 0 - 1;
    var sell_c = 0;
    var s = 0;
    while (s < PA_SECTORS) {
        if (pa_has_port(gx, s) == 1) {
            var c = 0;
            while (c < PA_COMM) {
                if (pa_port_flag(gx, s, c) == PF_SELLS) {
                    if (sell_sector < 0) { sell_sector = s; sell_c = c; }
                }
                c = c + 1;
            }
        }
        s = s + 1;
    }
    if (sell_sector < 0) { test_fail("t104_pa_trade", "no sell port"); return 1; }
    store64(st + PA_SECTOR, sell_sector);
    var price = pa_port_price(gx, sell_sector, sell_c);
    var cr0 = load64(st + PA_CREDITS);
    if (pa_buy(st, sell_c, 3) != 0)                 { test_fail("t104_pa_trade", "buy failed");     return 1; }
    if (pa_cargo(st, sell_c) != 3)                  { test_fail("t104_pa_trade", "cargo after buy");return 1; }
    if (load64(st + PA_CREDITS) != cr0 - price * 3) { test_fail("t104_pa_trade", "credits buy");    return 1; }
    if (pa_sell(st, sell_c, 1) != (0 - 3))          { test_fail("t104_pa_trade", "sell wrong flag");return 1; }
    store64(st + PA_SECTOR, 0);                      # HQ = no port
    if (pa_buy(st, sell_c, 1) != (0 - 2))           { test_fail("t104_pa_trade", "buy no port");    return 1; }

    # find a BUY port, stock the ship, sell into it
    var buy_sector = 0 - 1;
    var buy_c = 0;
    var s2 = 0;
    while (s2 < PA_SECTORS) {
        if (pa_has_port(gx, s2) == 1) {
            var c2 = 0;
            while (c2 < PA_COMM) {
                if (pa_port_flag(gx, s2, c2) == PF_BUYS) {
                    if (buy_sector < 0) { buy_sector = s2; buy_c = c2; }
                }
                c2 = c2 + 1;
            }
        }
        s2 = s2 + 1;
    }
    if (buy_sector < 0) { test_fail("t104_pa_trade", "no buy port"); return 1; }
    store64(st + PA_SECTOR, buy_sector);
    pa_set_cargo(st, buy_c, 10);
    var bprice = pa_port_price(gx, buy_sector, buy_c);
    var cr1 = load64(st + PA_CREDITS);
    if (pa_sell(st, buy_c, 4) != 0)                    { test_fail("t104_pa_trade", "sell failed");     return 1; }
    if (pa_cargo(st, buy_c) != 6)                      { test_fail("t104_pa_trade", "cargo after sell");return 1; }
    if (load64(st + PA_CREDITS) != cr1 + bprice * 4)   { test_fail("t104_pa_trade", "credits sell");    return 1; }
    test_pass("t104_pa_trade");
    return 0;
}

fn t105_pa_holds_and_guards(): i64 {
    var st = pa_new(7, DOOR_PRACTICE, PA_DEF_DAYS);
    var gx = pa_galaxy_new(7);
    store64(st + PA_GX, gx);
    # find a sell port
    var sec = 0 - 1;
    var cc = 0;
    var s = 0;
    while (s < PA_SECTORS) {
        if (pa_has_port(gx, s) == 1) {
            var c = 0;
            while (c < PA_COMM) {
                if (pa_port_flag(gx, s, c) == PF_SELLS) { if (sec < 0) { sec = s; cc = c; } }
                c = c + 1;
            }
        }
        s = s + 1;
    }
    if (sec < 0) { test_fail("t105_pa_holds_and_guards", "no sell port"); return 1; }
    store64(st + PA_SECTOR, sec);
    # holds guard: buy more than capacity (cheap price 1 to dodge credit cap)
    store64(load64(gx + GX_PORTS) + (sec * pa_port_stride() + 2 + cc * 2) * 8, 1);   # price = 1
    store64(st + PA_CREDITS, 1000000);
    if (pa_buy(st, cc, PA_START_HOLDS + 5) != (0 - 6)) { test_fail("t105_pa_holds_and_guards", "holds guard"); return 1; }
    if (pa_buy(st, cc, PA_START_HOLDS) != 0)           { test_fail("t105_pa_holds_and_guards", "fill holds");  return 1; }
    if (pa_holds_free(st) != 0)                        { test_fail("t105_pa_holds_and_guards", "free not 0");  return 1; }
    if (pa_buy(st, 99, 1) != (0 - 1))                  { test_fail("t105_pa_holds_and_guards", "bad comm");    return 1; }
    test_pass("t105_pa_holds_and_guards");
    return 0;
}

# === 1.1.0 Port Authority interactive layer (t106-t111, ADR 0009) ===

fn t106_pa_move_turns(): i64 {
    var st = pa_new(31, DOOR_PRACTICE, 3);
    pa_start(st);
    var gx = load64(st + PA_GX);
    var dest = pa_nth_warp(gx, 0, 0);
    if (dest < 0) { test_fail("t106_pa_move_turns", "no warp from 0"); return 1; }
    var t0 = load64(st + PA_TURNS);
    if (pa_move(st, dest) != 0)            { test_fail("t106_pa_move_turns", "move failed"); return 1; }
    if (load64(st + PA_SECTOR) != dest)    { test_fail("t106_pa_move_turns", "sector");      return 1; }
    if (load64(st + PA_TURNS) != t0 - 1)   { test_fail("t106_pa_move_turns", "turn spent");  return 1; }
    if (pa_move(st, load64(st + PA_SECTOR)) != (0 - 1)) { test_fail("t106_pa_move_turns", "self move"); return 1; }
    store64(st + PA_TURNS, 0);
    var d2 = pa_nth_warp(gx, load64(st + PA_SECTOR), 0);
    if (d2 >= 0) {
        if (pa_move(st, d2) != (0 - 2)) { test_fail("t106_pa_move_turns", "out of turns"); return 1; }
    }
    store64(st + PA_DAY, 1);
    pa_end_day(st);
    if (load64(st + PA_DAY) != 2)                  { test_fail("t106_pa_move_turns", "day advance");  return 1; }
    if (load64(st + PA_TURNS) != PA_TURNS_PER_DAY) { test_fail("t106_pa_move_turns", "turns refill"); return 1; }
    store64(st + PA_DAY, 3);
    pa_end_day(st);
    if (load64(st + PA_OVER) != 1) { test_fail("t106_pa_move_turns", "not finished"); return 1; }
    test_pass("t106_pa_move_turns");
    return 0;
}

fn t107_pa_combat(): i64 {
    var st = pa_new(8, DOOR_PRACTICE, PA_DEF_DAYS);
    store64(st + PA_FIGHTERS, 1000);
    store64(st + PA_PEND, 10);
    var cr0 = load64(st + PA_CREDITS);
    if (pa_fight(st) != 1)              { test_fail("t107_pa_combat", "should win big"); return 1; }
    if (load64(st + PA_CREDITS) <= cr0) { test_fail("t107_pa_combat", "no loot");       return 1; }
    if (load64(st + PA_FIGHTERS) < 0)   { test_fail("t107_pa_combat", "fighters neg");  return 1; }
    store64(st + PA_FIGHTERS, 3);
    store64(st + PA_SHIELDS, 0);
    var destroyed = 0;
    var n = 0;
    while (n < 80) {
        if (load64(st + PA_OVER) == 0) {
            store64(st + PA_PEND, 200);
            pa_fight(st);
            if (load64(st + PA_FIGHTERS) < 0) { test_fail("t107_pa_combat", "fighters neg loop"); return 1; }
            if (load64(st + PA_OVER) == 2) { destroyed = 1; }
        }
        n = n + 1;
    }
    if (destroyed == 0) { test_fail("t107_pa_combat", "never destroyed"); return 1; }
    test_pass("t107_pa_combat");
    return 0;
}

fn t108_pa_dock(): i64 {
    var st = pa_new(8, DOOR_PRACTICE, PA_DEF_DAYS);
    store64(st + PA_CREDITS, 100000);
    var h0 = load64(st + PA_HOLDS);
    if (pa_buy_holds(st) != 0)                          { test_fail("t108_pa_dock", "holds");        return 1; }
    if (load64(st + PA_HOLDS) != h0 + PA_HOLD_BLOCK)    { test_fail("t108_pa_dock", "hold block");   return 1; }
    var f0 = load64(st + PA_FIGHTERS);
    if (pa_buy_fighters(st) != 0)                       { test_fail("t108_pa_dock", "fighters");     return 1; }
    if (load64(st + PA_FIGHTERS) != f0 + PA_FIGHTER_BLOCK) { test_fail("t108_pa_dock", "fight block");return 1; }
    var s0 = load64(st + PA_SHIELDS);
    if (pa_buy_shields(st) != 0)                        { test_fail("t108_pa_dock", "shields");      return 1; }
    if (load64(st + PA_SHIELDS) != s0 + PA_SHIELD_BLOCK){ test_fail("t108_pa_dock", "shield block"); return 1; }
    store64(st + PA_CREDITS, 0);
    if (pa_buy_holds(st) != (0 - 5))                    { test_fail("t108_pa_dock", "credit guard"); return 1; }
    test_pass("t108_pa_dock");
    return 0;
}

fn t109_pa_planet(): i64 {
    var st = pa_new(8, DOOR_PRACTICE, PA_DEF_DAYS);
    if (load64(st + PA_PLANET) != (0 - 1)) { test_fail("t109_pa_planet", "planet not -1 init"); return 1; }
    store64(st + PA_SECTOR, 5);
    if (pa_establish_planet(st) != 0)        { test_fail("t109_pa_planet", "establish");        return 1; }
    if (load64(st + PA_PLANET) != 5)         { test_fail("t109_pa_planet", "planet sector");    return 1; }
    if (pa_establish_planet(st) != (0 - 1))  { test_fail("t109_pa_planet", "double establish"); return 1; }
    store64(st + PA_CREDITS, 5000);
    if (pa_planet_deposit(st, 2000) != 0)    { test_fail("t109_pa_planet", "deposit");          return 1; }
    if (load64(st + PA_CREDITS) != 3000)     { test_fail("t109_pa_planet", "credits post-dep"); return 1; }
    if (load64(st + PA_PLANET_CR) != 2000)   { test_fail("t109_pa_planet", "planet cr");        return 1; }
    if (pa_planet_withdraw(st, 500) != 0)    { test_fail("t109_pa_planet", "withdraw");         return 1; }
    if (load64(st + PA_PLANET_CR) != 1500)   { test_fail("t109_pa_planet", "planet cr post-wd");return 1; }
    if (load64(st + PA_CREDITS) != 3500)     { test_fail("t109_pa_planet", "credits post-wd");  return 1; }
    test_pass("t109_pa_planet");
    return 0;
}

fn t110_pa_save_load(): i64 {
    var st = pa_new(0 - 222, DOOR_SOLO, 25);
    rng_seed(st + PA_RNG, 0 - 333);
    store64(st + PA_DAY, 9);
    store64(st + PA_SECTOR, 17);
    store64(st + PA_CREDITS, 8888);
    store64(st + PA_HOLDS, 60);
    store64(st + PA_FIGHTERS, 120);
    store64(st + PA_SHIELDS, 40);
    store64(st + PA_TURNS, 33);
    store64(st + PA_PLANET, 17);
    store64(st + PA_PLANET_CR, 5000);
    pa_set_cargo(st, 0, 7);
    pa_set_cargo(st, 2, 3);
    var buf = alloc(PA_SAVE_CAP);
    var n = pa_save_format(st, buf, PA_SAVE_CAP);
    var st2 = pa_load_parse(buf, n);
    if (st2 == 0)                              { test_fail("t110_pa_save_load", "parse null"); return 1; }
    if (load64(st2 + PA_SEED) != (0 - 222))    { test_fail("t110_pa_save_load", "seed");      return 1; }
    if (load64(st2 + PA_RNG) != (0 - 333))     { test_fail("t110_pa_save_load", "rng");       return 1; }
    if (load64(st2 + PA_DAY) != 9)             { test_fail("t110_pa_save_load", "day");       return 1; }
    if (load64(st2 + PA_MAXDAYS) != 25)        { test_fail("t110_pa_save_load", "maxdays");   return 1; }
    if (load64(st2 + PA_SECTOR) != 17)         { test_fail("t110_pa_save_load", "sector");    return 1; }
    if (load64(st2 + PA_CREDITS) != 8888)      { test_fail("t110_pa_save_load", "credits");   return 1; }
    if (load64(st2 + PA_FIGHTERS) != 120)      { test_fail("t110_pa_save_load", "fighters");  return 1; }
    if (load64(st2 + PA_SHIELDS) != 40)        { test_fail("t110_pa_save_load", "shields");   return 1; }
    if (load64(st2 + PA_PLANET) != 17)         { test_fail("t110_pa_save_load", "planet");    return 1; }
    if (load64(st2 + PA_PLANET_CR) != 5000)    { test_fail("t110_pa_save_load", "planet cr"); return 1; }
    if (load64(st2 + PA_MODE) != DOOR_SOLO)    { test_fail("t110_pa_save_load", "mode");      return 1; }
    if (pa_cargo(st2, 0) != 7)                 { test_fail("t110_pa_save_load", "cargo0");    return 1; }
    if (pa_cargo(st2, 2) != 3)                 { test_fail("t110_pa_save_load", "cargo2");    return 1; }
    test_pass("t110_pa_save_load");
    return 0;
}

fn t111_pa_feed_render(): i64 {
    var st = pa_new(13, DOOR_PRACTICE, PA_DEF_DAYS);
    pa_start(st);
    var buf = alloc(4096);
    if (pa_render(st, buf, 4096) <= 0)       { test_fail("t111_pa_feed_render", "main render"); return 1; }
    pa_feed(st, "m", 1);
    if (load64(st + PA_SCREEN) != PSCR_MOVE) { test_fail("t111_pa_feed_render", "m->move");     return 1; }
    if (pa_render(st, buf, 4096) <= 0)       { test_fail("t111_pa_feed_render", "move render"); return 1; }
    pa_feed(st, "x", 1);
    if (load64(st + PA_SCREEN) != PSCR_MAIN) { test_fail("t111_pa_feed_render", "x->main");     return 1; }
    if (pa_feed(st, "q", 1) != 1)            { test_fail("t111_pa_feed_render", "q exits");     return 1; }
    test_pass("t111_pa_feed_render");
    return 0;
}

# === 1.1.0 The Handler core: model + generation + deduction (t112-t116, ADR 0009) ===

fn t112_th_determinism(): i64 {
    var a = th_new(424242, DOOR_SOLO, TH_DEF_DAYS);
    var b = th_new(424242, DOOR_SOLO, TH_DEF_DAYS);
    if (load64(a + TH_MOLEIDX) != load64(b + TH_MOLEIDX)) { test_fail("t112_th_determinism", "mole differs"); return 1; }
    var i = 0;
    while (i < TH_AGENTS) {
        var ag = th_agent(a, i);
        var bg = th_agent(b, i);
        if (load64(ag + AG_CITY) != load64(bg + AG_CITY))     { test_fail("t112_th_determinism", "city differs");   return 1; }
        if (load64(ag + AG_RELIAB) != load64(bg + AG_RELIAB)) { test_fail("t112_th_determinism", "reliab differs"); return 1; }
        if (load64(ag + AG_DISC) != load64(bg + AG_DISC))     { test_fail("t112_th_determinism", "disc differs");   return 1; }
        i = i + 1;
    }
    test_pass("t112_th_determinism");
    return 0;
}

fn t113_th_mole_invariant(): i64 {
    var st = th_new(31337, DOOR_SOLO, TH_DEF_DAYS);
    var mole = load64(st + TH_MOLEIDX);
    var i = 0;
    while (i < TH_AGENTS) {
        var is_mole = load64(th_agent(st, i) + AG_MOLE);
        if (i == mole) {
            if (is_mole != 1) { test_fail("t113_th_mole_invariant", "mole flag missing"); return 1; }
        } else {
            if (is_mole != 0) { test_fail("t113_th_mole_invariant", "non-mole flagged"); return 1; }
        }
        i = i + 1;
    }
    test_pass("t113_th_mole_invariant");
    return 0;
}

fn t114_th_suspicion_separation(): i64 {
    var st = th_new(900, DOOR_SOLO, TH_DEF_DAYS);
    # force a known mole (agent 0, city-relay class) and clean honest agents
    store64(th_agent(st, 0) + AG_MOLE, 1);
    store64(th_agent(st, 0) + AG_DISC, 0);
    store64(st + TH_MOLEIDX, 0);
    var i = 1;
    while (i < TH_AGENTS) {
        store64(th_agent(st, i) + AG_MOLE, 0);
        store64(th_agent(st, i) + AG_RELIAB, 100);   # no clerical noise
        i = i + 1;
    }
    var day = 1;
    while (day <= 20) {
        store64(st + TH_DAY, day);
        th_gen_day(st);
        day = day + 1;
    }
    var mole_susp = th_agent_suspicion(st, 0);
    if (mole_susp < 8) { test_fail("t114_th_suspicion_separation", "mole suspicion too low"); return 1; }
    var j = 1;
    while (j < TH_AGENTS) {
        if (th_agent_suspicion(st, j) >= mole_susp) { test_fail("t114_th_suspicion_separation", "honest >= mole"); return 1; }
        j = j + 1;
    }
    if (th_registry_count(st) < 80) { test_fail("t114_th_suspicion_separation", "registry too small"); return 1; }
    test_pass("t114_th_suspicion_separation");
    return 0;
}

fn t115_th_discrepant(): i64 {
    var cb = alloc(CB_SIZE);
    memset(cb, 0, CB_SIZE);
    store64(cb + CB_VIA, 2);
    store64(cb + CB_TRUECITY, 2);
    store64(cb + CB_CIPHER, 1);
    store64(cb + CB_DATEOK, 1);
    if (th_cable_discrepant(cb) != 0) { test_fail("t115_th_discrepant", "clean flagged"); return 1; }
    store64(cb + CB_VIA, 3);                                  # city conflict
    if (th_cable_discrepant(cb) != 1) { test_fail("t115_th_discrepant", "city not flagged"); return 1; }
    store64(cb + CB_VIA, 2);
    store64(cb + CB_DATEOK, 0);                               # stale
    if (th_cable_discrepant(cb) != 1) { test_fail("t115_th_discrepant", "stale not flagged"); return 1; }
    store64(cb + CB_DATEOK, 1);
    store64(cb + CB_CIPHER, 0);                               # cipher
    if (th_cable_discrepant(cb) != 1) { test_fail("t115_th_discrepant", "cipher not flagged"); return 1; }
    test_pass("t115_th_discrepant");
    return 0;
}

fn t116_th_no_mole_clean(): i64 {
    var st = th_new(12321, DOOR_SOLO, TH_DEF_DAYS);
    store64(st + TH_MOLEIDX, 0 - 1);
    var i = 0;
    while (i < TH_AGENTS) {
        store64(th_agent(st, i) + AG_MOLE, 0);
        store64(th_agent(st, i) + AG_RELIAB, 100);
        i = i + 1;
    }
    var day = 1;
    while (day <= 20) {
        store64(st + TH_DAY, day);
        th_gen_day(st);
        day = day + 1;
    }
    var j = 0;
    while (j < TH_AGENTS) {
        if (th_agent_suspicion(st, j) != 0) { test_fail("t116_th_no_mole_clean", "clean agent flagged"); return 1; }
        j = j + 1;
    }
    test_pass("t116_th_no_mole_clean");
    return 0;
}

# === 1.1.0 The Handler interactive layer (t117-t121, ADR 0009) ===

fn t117_th_actions(): i64 {
    var st = th_new(50, DOOR_SOLO, TH_DEF_DAYS);
    th_start(st);
    store64(th_agent(st, 1) + AG_STATUS, AGS_ACTIVE);
    store64(th_agent(st, 1) + AG_CITY, 0);
    var pts0 = load64(st + TH_POINTS);
    var bud0 = load64(st + TH_BUDGET);
    if (th_order_move(st, 1, 2) != 0)                       { test_fail("t117_th_actions", "move");      return 1; }
    if (load64(th_agent(st, 1) + AG_CITY) != 2)            { test_fail("t117_th_actions", "city");      return 1; }
    if (load64(st + TH_POINTS) != pts0 - 1)               { test_fail("t117_th_actions", "points");    return 1; }
    if (load64(st + TH_BUDGET) != bud0 - TH_MOVE_COST)    { test_fail("t117_th_actions", "budget");    return 1; }
    store64(th_agent(st, 2) + AG_TRUST, 50);
    store64(th_agent(st, 2) + AG_PAY, 100);
    if (th_authorize_funds(st, 2, 1000) != 0)             { test_fail("t117_th_actions", "fund");      return 1; }
    if (load64(th_agent(st, 2) + AG_TRUST) <= 50)         { test_fail("t117_th_actions", "trust up");  return 1; }
    if (load64(st + TH_AUDIT) < 15)                       { test_fail("t117_th_actions", "audit");     return 1; }
    if (th_order_extract(st, 3) != 0)                     { test_fail("t117_th_actions", "extract");   return 1; }
    if (load64(th_agent(st, 3) + AG_STATUS) != AGS_EXTRACTED) { test_fail("t117_th_actions", "extracted"); return 1; }
    store64(st + TH_POINTS, 0);
    if (th_order_move(st, 1, 0) != (0 - 2))               { test_fail("t117_th_actions", "no points"); return 1; }
    test_pass("t117_th_actions");
    return 0;
}

fn t118_th_accuse(): i64 {
    var st = th_new(50, DOOR_SOLO, TH_DEF_DAYS);
    var i = 0;
    while (i < TH_AGENTS) { store64(th_agent(st, i) + AG_MOLE, 0); i = i + 1; }
    store64(th_agent(st, 2) + AG_MOLE, 1);
    store64(st + TH_MOLEIDX, 2);
    store64(st + TH_CONF, 60);
    if (th_accuse(st, 0) != 0)                              { test_fail("t118_th_accuse", "wrong not 0");   return 1; }
    if (load64(st + TH_CONF) != 30)                        { test_fail("t118_th_accuse", "wrong conf");    return 1; }
    if (load64(th_agent(st, 0) + AG_STATUS) != AGS_FLAGGED){ test_fail("t118_th_accuse", "not flagged");   return 1; }
    if (th_accuse(st, 2) != 1)                             { test_fail("t118_th_accuse", "correct not 1"); return 1; }
    if (load64(st + TH_MOLEIDX) != (0 - 1))               { test_fail("t118_th_accuse", "moleidx clear"); return 1; }
    if (load64(st + TH_CONF) != 55)                       { test_fail("t118_th_accuse", "correct conf");  return 1; }
    store64(st + TH_CONF, 20);
    th_accuse(st, 1);
    if (load64(st + TH_OVER) != 2)                        { test_fail("t118_th_accuse", "not recalled");  return 1; }
    test_pass("t118_th_accuse");
    return 0;
}

fn t119_th_nextday_score(): i64 {
    var st = th_new(77, DOOR_SOLO, 3);
    th_start(st);
    store64(st + TH_MOLEIDX, 0 - 1);
    var i = 0;
    while (i < TH_AGENTS) { store64(th_agent(st, i) + AG_MOLE, 0); i = i + 1; }
    store64(st + TH_POINTS, 1);
    th_next_day(st);
    if (load64(st + TH_DAY) != 2)                       { test_fail("t119_th_nextday_score", "day");          return 1; }
    if (load64(st + TH_POINTS) != TH_DISPATCH_PTS)     { test_fail("t119_th_nextday_score", "points refill"); return 1; }
    th_next_day(st);
    if (load64(st + TH_OVER) != 0)                     { test_fail("t119_th_nextday_score", "over early");    return 1; }
    th_next_day(st);
    if (load64(st + TH_OVER) != 1)                     { test_fail("t119_th_nextday_score", "not finished");  return 1; }
    if (th_score(st) <= 0)                             { test_fail("t119_th_nextday_score", "score");         return 1; }
    var st2 = th_new(77, DOOR_SOLO, 30);
    th_start(st2);
    store64(st2 + TH_CONF, 0);
    th_next_day(st2);
    if (load64(st2 + TH_OVER) != 2)                    { test_fail("t119_th_nextday_score", "not recalled");  return 1; }
    test_pass("t119_th_nextday_score");
    return 0;
}

fn t120_th_save_load(): i64 {
    var st = th_new(0 - 7, DOOR_SOLO, 18);
    th_start(st);
    th_next_day(st);
    th_next_day(st);
    store64(st + TH_CONF, 44);
    store64(st + TH_BUDGET, 3210);
    store64(th_agent(st, 1) + AG_TRUST, 88);
    var regn = th_registry_count(st);
    var buf = alloc(TH_SAVE_CAP);
    var n = th_save_format(st, buf, TH_SAVE_CAP);
    var st2 = th_load_parse(buf, n);
    if (st2 == 0)                                         { test_fail("t120_th_save_load", "parse null"); return 1; }
    if (load64(st2 + TH_SEED) != (0 - 7))                { test_fail("t120_th_save_load", "seed");       return 1; }
    if (load64(st2 + TH_CONF) != 44)                     { test_fail("t120_th_save_load", "conf");       return 1; }
    if (load64(st2 + TH_BUDGET) != 3210)                 { test_fail("t120_th_save_load", "budget");     return 1; }
    if (load64(st2 + TH_MAXDAYS) != 18)                  { test_fail("t120_th_save_load", "maxdays");    return 1; }
    if (load64(st2 + TH_MOLEIDX) != load64(st + TH_MOLEIDX)) { test_fail("t120_th_save_load", "moleidx");return 1; }
    if (th_registry_count(st2) != regn)                  { test_fail("t120_th_save_load", "regcount");   return 1; }
    if (load64(th_agent(st2, 1) + AG_TRUST) != 88)       { test_fail("t120_th_save_load", "agent trust");return 1; }
    if (load64(th_cable_at(st2, 0) + CB_VIA) != load64(th_cable_at(st, 0) + CB_VIA))     { test_fail("t120_th_save_load", "cable via");   return 1; }
    if (load64(th_cable_at(st2, 0) + CB_AGENT) != load64(th_cable_at(st, 0) + CB_AGENT)) { test_fail("t120_th_save_load", "cable agent"); return 1; }
    test_pass("t120_th_save_load");
    return 0;
}

fn t121_th_feed_render(): i64 {
    var st = th_new(123, DOOR_SOLO, TH_DEF_DAYS);
    th_start(st);
    var buf = alloc(8192);
    if (th_render(st, buf, 8192) <= 0)        { test_fail("t121_th_feed_render", "main render"); return 1; }
    th_feed(st, "c", 1);
    if (load64(st + TH_SCREEN) != HSCR_CABLES){ test_fail("t121_th_feed_render", "c->cables");   return 1; }
    if (th_render(st, buf, 8192) <= 0)        { test_fail("t121_th_feed_render", "cables render");return 1; }
    th_feed(st, "1", 1);
    if (load64(st + TH_SCREEN) != HSCR_READ)  { test_fail("t121_th_feed_render", "read");        return 1; }
    if (th_render(st, buf, 8192) <= 0)        { test_fail("t121_th_feed_render", "read render"); return 1; }
    th_feed(st, "x", 1);
    th_feed(st, "x", 1);
    if (load64(st + TH_SCREEN) != HSCR_MAIN)  { test_fail("t121_th_feed_render", "back main");   return 1; }
    th_feed(st, "x", 1);
    if (load64(st + TH_SCREEN) != HSCR_XREF)  { test_fail("t121_th_feed_render", "x->xref");     return 1; }
    th_feed(st, "z", 1);
    if (load64(st + TH_SCREEN) != HSCR_MAIN)  { test_fail("t121_th_feed_render", "xref back");   return 1; }
    if (th_feed(st, "q", 1) != 1)             { test_fail("t121_th_feed_render", "q exits");     return 1; }
    test_pass("t121_th_feed_render");
    return 0;
}

# === 1.2.0 world-transaction framework (t122-t123, ADR 0010) ===

fn t122_world_paths(): i64 {
    var buf = alloc(PATH_MAX_BYTES);
    world_dir("store", "port", buf);
    if (streq(buf, "store/.games/port/world") == 0)            { test_fail("t122_world_paths", "dir");  return 1; }
    var fb = alloc(PATH_MAX_BYTES);
    world_file("store", "port", "snapshot", fb);
    if (streq(fb, "store/.games/port/world/snapshot") == 0)    { test_fail("t122_world_paths", "file"); return 1; }
    # traversal guard: invalid game name → lock refused before any fs touch
    if (world_lock_acquire("store", "../etc") >= 0)            { test_fail("t122_world_paths", "traversal"); return 1; }
    test_pass("t122_world_paths");
    return 0;
}

# Single-process transaction round-trip (resets first, so it's
# deterministic regardless of prior /tmp state). Cross-process
# no-lost-updates is proven by docs/examples/08-world-concurrency.sh.
fn t123_world_txn_roundtrip(): i64 {
    var z = alloc(8);
    store64(z, 0);
    if (world_write("/tmp/agora-worldtest-t123", "bench", z, 8) != 0) { test_fail("t123_world_txn_roundtrip", "reset");  return 1; }
    if (world_txn_add("/tmp/agora-worldtest-t123", "bench", 5) != 5)  { test_fail("t123_world_txn_roundtrip", "add5");   return 1; }
    if (world_txn_add("/tmp/agora-worldtest-t123", "bench", 3) != 8)  { test_fail("t123_world_txn_roundtrip", "add3");   return 1; }
    var rb = alloc(8);
    if (world_read("/tmp/agora-worldtest-t123", "bench", rb, 8) != 8) { test_fail("t123_world_txn_roundtrip", "readlen"); return 1; }
    if (load64(rb) != 8)                                              { test_fail("t123_world_txn_roundtrip", "readval"); return 1; }
    test_pass("t123_world_txn_roundtrip");
    return 0;
}

# === 1.1.1 The Handler field pressure (t124-t127) ===

# Pure cover-wear math: baseline, stressed, mole-co-located, and the
# stressed+local worst case. Pins the burn curve independent of rng.
fn t124_th_cover_loss(): i64 {
    if (th_cover_loss(0, 0, 2) != 2)                                          { test_fail("t124_th_cover_loss", "base"); return 1; }
    if (th_cover_loss(TH_STRESS_HOT, 0, 2) != 2 + TH_HOT_WEAR)               { test_fail("t124_th_cover_loss", "hot");  return 1; }
    if (th_cover_loss(0, 1, 2) != 2 + TH_MOLE_LOCAL)                         { test_fail("t124_th_cover_loss", "local"); return 1; }
    if (th_cover_loss(TH_STRESS_HOT, 1, 2) != 2 + TH_HOT_WEAR + TH_MOLE_LOCAL){ test_fail("t124_th_cover_loss", "both"); return 1; }
    test_pass("t124_th_cover_loss");
    return 0;
}

# An honest agent sharing the mole's city burns; a distant honest agent
# survives. Confidence drops on the burn. mole_local fires only while
# the mole is unflagged.
fn t125_th_mole_local_burn(): i64 {
    var st = th_new(555, DOOR_SOLO, TH_DEF_DAYS);
    var i = 0;
    while (i < TH_AGENTS) { store64(th_agent(st, i) + AG_MOLE, 0); store64(th_agent(st, i) + AG_STATUS, AGS_ACTIVE); i = i + 1; }
    # agent 0 = mole in city 1; agent 1 honest co-located; agent 2 honest distant
    store64(th_agent(st, 0) + AG_MOLE, 1);
    store64(st + TH_MOLEIDX, 0);
    store64(th_agent(st, 0) + AG_CITY, 1);
    store64(th_agent(st, 1) + AG_CITY, 1);
    store64(th_agent(st, 2) + AG_CITY, 3);
    if (th_mole_local(st, 1) != 1) { test_fail("t125_th_mole_local_burn", "local not 1"); return 1; }
    if (th_mole_local(st, 2) != 0) { test_fail("t125_th_mole_local_burn", "distant not 0"); return 1; }
    if (th_mole_local(st, 0) != 0) { test_fail("t125_th_mole_local_burn", "mole self local"); return 1; }
    # low cover on the co-located agent, high on the distant one
    store64(th_agent(st, 1) + AG_COVER, 6);
    store64(th_agent(st, 2) + AG_COVER, 95);
    var conf0 = load64(st + TH_CONF);
    th_field_tick(st);
    if (load64(th_agent(st, 1) + AG_STATUS) != AGS_DEAD)   { test_fail("t125_th_mole_local_burn", "colocated survived"); return 1; }
    if (load64(th_agent(st, 2) + AG_STATUS) != AGS_ACTIVE) { test_fail("t125_th_mole_local_burn", "distant burned");     return 1; }
    if (load64(st + TH_LASTBURN) < 1)                      { test_fail("t125_th_mole_local_burn", "lastburn");           return 1; }
    if (load64(st + TH_CONF) >= conf0)                     { test_fail("t125_th_mole_local_burn", "conf not hit");       return 1; }
    test_pass("t125_th_mole_local_burn");
    return 0;
}

# Funding an agent relieves stress (morale), not just trust.
fn t126_th_fund_relieves_stress(): i64 {
    var st = th_new(606, DOOR_SOLO, TH_DEF_DAYS);
    store64(th_agent(st, 2) + AG_STATUS, AGS_ACTIVE);
    store64(th_agent(st, 2) + AG_STRESS, 90);
    store64(st + TH_BUDGET, 9000);
    store64(st + TH_POINTS, 4);
    if (th_authorize_funds(st, 2, 1000) != 0)            { test_fail("t126_th_fund_relieves_stress", "fund rc"); return 1; }
    if (load64(th_agent(st, 2) + AG_STRESS) >= 90)       { test_fail("t126_th_fund_relieves_stress", "stress");  return 1; }
    test_pass("t126_th_fund_relieves_stress");
    return 0;
}

# Extraction pulls an agent out of the field, so field pressure can no
# longer burn them — and an extracted agent still scores (half trust).
fn t127_th_extract_saves_from_burn(): i64 {
    var st = th_new(707, DOOR_SOLO, TH_DEF_DAYS);
    store64(st + TH_MOLEIDX, 0 - 1);
    var i = 0;
    while (i < TH_AGENTS) { store64(th_agent(st, i) + AG_MOLE, 0); store64(th_agent(st, i) + AG_STATUS, AGS_ACTIVE); store64(th_agent(st, i) + AG_COVER, 2); i = i + 1; }
    store64(th_agent(st, 0) + AG_TRUST, 80);
    store64(st + TH_BUDGET, 9000);
    store64(st + TH_POINTS, 4);
    if (th_order_extract(st, 0) != 0)                    { test_fail("t127_th_extract_saves_from_burn", "extract rc"); return 1; }
    th_field_tick(st);
    th_field_tick(st);
    if (load64(th_agent(st, 0) + AG_STATUS) != AGS_EXTRACTED) { test_fail("t127_th_extract_saves_from_burn", "not safe"); return 1; }
    if (th_score(st) <= 0)                               { test_fail("t127_th_extract_saves_from_burn", "no score"); return 1; }
    test_pass("t127_th_extract_saves_from_burn");
    return 0;
}

# === 1.2.0 Universe: Port Authority shared galaxy (t128-t134, ADR 0010 bite 2) ===

# Fresh world: version + seed set, every traded slot at baseline stock,
# every sector unclaimed.
fn t128_paw_new(): i64 {
    var w = paw_new(98765);
    if (paw_seed(w) != 98765)                       { test_fail("t128_paw_new", "seed"); return 1; }
    if (paw_valid(w, paw_byte_size()) != 1)         { test_fail("t128_paw_new", "valid"); return 1; }
    if (paw_valid(w, paw_byte_size() - 8) != 0)     { test_fail("t128_paw_new", "bad len accepted"); return 1; }
    if (paw_stock(w, 7, 2) != PAW_STOCK_BASE)       { test_fail("t128_paw_new", "stock"); return 1; }
    if (paw_planet_owner(w, 7) != 0)                { test_fail("t128_paw_new", "owner"); return 1; }
    test_pass("t128_paw_new");
    return 0;
}

# Distinct write/read-back across the whole stock array in a loop — this
# directly probes the array-in-loop codegen bug (store64(base+i*8,…)
# collapsing onto the base index) that reverted the first bite-2 attempt.
# Each (s,c) gets a unique value; every one must read back exactly.
fn t129_paw_stock_distinct(): i64 {
    var w = paw_new(1);
    var s = 0;
    while (s < PA_SECTORS) {
        var c = 0;
        while (c < PA_COMM) {
            paw_set_stock(w, s, c, s * 100 + c + 1);
            c = c + 1;
        }
        s = s + 1;
    }
    s = 0;
    while (s < PA_SECTORS) {
        var c = 0;
        while (c < PA_COMM) {
            if (paw_stock(w, s, c) != s * 100 + c + 1) { test_fail("t129_paw_stock_distinct", "collapsed write"); return 1; }
            c = c + 1;
        }
        s = s + 1;
    }
    # planet owners must be untouched by the stock writes (no overlap)
    if (paw_planet_owner(w, 0) != 0)                { test_fail("t129_paw_stock_distinct", "owner clobbered"); return 1; }
    if (paw_planet_owner(w, PA_SECTORS - 1) != 0)   { test_fail("t129_paw_stock_distinct", "owner clobbered tail"); return 1; }
    test_pass("t129_paw_stock_distinct");
    return 0;
}

# Price curve: base at baseline stock, higher when depleted, lower when
# glutted, clamped to the band.
fn t130_paw_price_curve(): i64 {
    if (paw_price(100, PAW_STOCK_BASE) != 100)            { test_fail("t130_paw_price_curve", "baseline"); return 1; }
    if (paw_price(100, PAW_STOCK_BASE / 2) <= 100)        { test_fail("t130_paw_price_curve", "depleted not up"); return 1; }
    if (paw_price(100, PAW_STOCK_BASE + PAW_STOCK_BASE / 2) >= 100) { test_fail("t130_paw_price_curve", "glut not down"); return 1; }
    if (paw_price(100, 0) != 200)                         { test_fail("t130_paw_price_curve", "empty cap"); return 1; }
    if (paw_price(100, 2 * PAW_STOCK_BASE) != 33)         { test_fail("t130_paw_price_curve", "full floor"); return 1; }
    test_pass("t130_paw_price_curve");
    return 0;
}

# Find a sector whose port SELLS commodity c (for buy tests) or BUYS it
# (for sell tests). Returns sector or -1. flag: PF_SELLS / PF_BUYS.
fn t_paw_find_port(gx, c, want_flag): i64 {
    var s = 1;
    var found = 0 - 1;
    while (s < PA_SECTORS) {
        if (found < 0) {
            if (pa_has_port(gx, s) == 1) {
                if (pa_port_flag(gx, s, c) == want_flag) { found = s; }
            }
        }
        s = s + 1;
    }
    return found;
}

# Buying drains stock and raises the next quoted price; guards reject
# over-credits / over-holds / over-stock without mutating.
fn t131_paw_buy_depletes(): i64 {
    var gx = pa_galaxy_new(4242);
    var w = paw_new(4242);
    # locate the first SELLS port across the commodities
    var c = 0;
    var s = 0 - 1;
    var found_c = 0 - 1;
    while (c < PA_COMM) {
        if (s < 0) {
            var cand = t_paw_find_port(gx, c, PF_SELLS);
            if (cand >= 0) { s = cand; found_c = c; }
        }
        c = c + 1;
    }
    if (s < 0) { test_pass("t131_paw_buy_depletes"); return 0; }   # no SELLS port at this seed: vacuously ok
    var price0 = paw_quote(w, gx, s, found_c);
    var cost = paw_buy(w, gx, s, found_c, 100, 1000000, 1000);
    if (cost < 0)                                   { test_fail("t131_paw_buy_depletes", "buy failed"); return 1; }
    if (paw_stock(w, s, found_c) != PAW_STOCK_BASE - 100) { test_fail("t131_paw_buy_depletes", "stock not drained"); return 1; }
    if (paw_quote(w, gx, s, found_c) < price0)      { test_fail("t131_paw_buy_depletes", "price not up"); return 1; }
    # guards: no credits, no holds, over stock — none should mutate further
    var stock_now = paw_stock(w, s, found_c);
    if (paw_buy(w, gx, s, found_c, 10, 0, 1000) != (0 - 5))   { test_fail("t131_paw_buy_depletes", "credit guard"); return 1; }
    if (paw_buy(w, gx, s, found_c, 10, 1000000, 0) != (0 - 6)){ test_fail("t131_paw_buy_depletes", "holds guard"); return 1; }
    if (paw_buy(w, gx, s, found_c, 999999, 1000000, 1000000) != (0 - 7)) { test_fail("t131_paw_buy_depletes", "stock guard"); return 1; }
    if (paw_stock(w, s, found_c) != stock_now)      { test_fail("t131_paw_buy_depletes", "guard mutated"); return 1; }
    test_pass("t131_paw_buy_depletes");
    return 0;
}

# Selling refills stock and lowers the next quoted price.
fn t132_paw_sell_gluts(): i64 {
    var gx = pa_galaxy_new(909);
    var w = paw_new(909);
    var c = 0;
    var s = 0 - 1;
    var found_c = 0 - 1;
    while (c < PA_COMM) {
        if (s < 0) {
            var cand = t_paw_find_port(gx, c, PF_BUYS);
            if (cand >= 0) { s = cand; found_c = c; }
        }
        c = c + 1;
    }
    if (s < 0) { test_pass("t132_paw_sell_gluts"); return 0; }    # no BUYS port at this seed
    var price0 = paw_quote(w, gx, s, found_c);
    var proceeds = paw_sell(w, gx, s, found_c, 80, 1000);
    if (proceeds < 0)                               { test_fail("t132_paw_sell_gluts", "sell failed"); return 1; }
    if (paw_stock(w, s, found_c) != PAW_STOCK_BASE + 80) { test_fail("t132_paw_sell_gluts", "stock not filled"); return 1; }
    if (paw_quote(w, gx, s, found_c) > price0)      { test_fail("t132_paw_sell_gluts", "price not down"); return 1; }
    if (paw_sell(w, gx, s, found_c, 81, 80) != (0 - 7)) { test_fail("t132_paw_sell_gluts", "cargo guard"); return 1; }
    test_pass("t132_paw_sell_gluts");
    return 0;
}

# Planet claim is exclusive: first owner sticks, a second claim by
# anyone fails, anonymous (fp 0) is refused.
fn t133_paw_claim_planet(): i64 {
    var w = paw_new(5);
    if (paw_claim_planet(w, 12, 0) != (0 - 2))      { test_fail("t133_paw_claim_planet", "anon allowed"); return 1; }
    if (paw_claim_planet(w, 12, 44444) != 0)        { test_fail("t133_paw_claim_planet", "first claim"); return 1; }
    if (paw_planet_owner(w, 12) != 44444)           { test_fail("t133_paw_claim_planet", "owner recorded"); return 1; }
    if (paw_claim_planet(w, 12, 44444) != (0 - 1))  { test_fail("t133_paw_claim_planet", "reclaim self"); return 1; }
    if (paw_claim_planet(w, 12, 77777) != (0 - 1))  { test_fail("t133_paw_claim_planet", "steal"); return 1; }
    if (paw_planet_owner(w, 12) != 44444)           { test_fail("t133_paw_claim_planet", "owner changed"); return 1; }
    test_pass("t133_paw_claim_planet");
    return 0;
}

# The world buffer is directly persistable: its raw bytes round-trip
# through a byte copy (what world_read/world_write do on disk) and the
# accessors still read true.
fn t134_paw_bytes_roundtrip(): i64 {
    var w = paw_new(321);
    paw_set_stock(w, 3, 1, 137);
    paw_set_planet_owner(w, 9, 88888);
    var cap = paw_byte_size();
    var disk = alloc(cap);
    memcpy(disk, w, cap);
    if (paw_valid(disk, cap) != 1)            { test_fail("t134_paw_bytes_roundtrip", "valid"); return 1; }
    if (paw_seed(disk) != 321)               { test_fail("t134_paw_bytes_roundtrip", "seed"); return 1; }
    if (paw_stock(disk, 3, 1) != 137)        { test_fail("t134_paw_bytes_roundtrip", "stock"); return 1; }
    if (paw_planet_owner(disk, 9) != 88888)  { test_fail("t134_paw_bytes_roundtrip", "owner"); return 1; }
    test_pass("t134_paw_bytes_roundtrip");
    return 0;
}

# Ship-side Universe glue: a PA ship in DOOR_UNIVERSE routes pa_buy /
# pa_sell / pa_establish_planet through the in-memory world — applying
# the credit/cargo effect to the ship AND mutating shared stock /
# ownership — while the solo path is untouched.
fn t135_pa_universe_actions(): i64 {
    var seed = 4242;
    var gx = pa_galaxy_new(seed);
    var w = paw_new(seed);
    var st = pa_new(seed, DOOR_UNIVERSE, PA_DEF_DAYS);
    pa_start(st);                       # regenerates PA_GX from seed (== gx structurally)
    store64(st + PA_WORLD, w);
    store64(st + PA_FP, 31415);
    if (pa_is_universe(st) != 1)        { test_fail("t135_pa_universe_actions", "not universe"); return 1; }

    # find a SELLS port and move the ship there
    var c = 0;
    var s = 0 - 1;
    var bc = 0 - 1;
    while (c < PA_COMM) {
        if (s < 0) { var cand = t_paw_find_port(load64(st + PA_GX), c, PF_SELLS);
                     if (cand >= 0) { s = cand; bc = c; } }
        c = c + 1;
    }
    if (s >= 0) {
        store64(st + PA_SECTOR, s);
        store64(st + PA_CREDITS, 1000000);
        var cr0 = load64(st + PA_CREDITS);
        var stk0 = paw_stock(w, s, bc);
        if (pa_buy(st, bc, 10) != 0)                  { test_fail("t135_pa_universe_actions", "buy"); return 1; }
        if (pa_cargo(st, bc) != 10)                   { test_fail("t135_pa_universe_actions", "cargo"); return 1; }
        if (load64(st + PA_CREDITS) >= cr0)           { test_fail("t135_pa_universe_actions", "credits not spent"); return 1; }
        if (paw_stock(w, s, bc) != stk0 - 10)         { test_fail("t135_pa_universe_actions", "world stock not drained"); return 1; }
    }

    # planet claim writes ownership into the shared world
    store64(st + PA_PLANET, 0 - 1);
    var psec = load64(st + PA_SECTOR);
    if (pa_establish_planet(st) != 0)                 { test_fail("t135_pa_universe_actions", "claim"); return 1; }
    if (paw_planet_owner(w, psec) != 31415)           { test_fail("t135_pa_universe_actions", "world owner"); return 1; }
    # a rival ship can't re-claim the same sector
    var rival = pa_new(seed, DOOR_UNIVERSE, PA_DEF_DAYS);
    pa_start(rival);
    store64(rival + PA_WORLD, w);
    store64(rival + PA_FP, 27182);
    store64(rival + PA_SECTOR, psec);
    store64(rival + PA_PLANET, 0 - 1);
    if (pa_establish_planet(rival) != (0 - 3))        { test_fail("t135_pa_universe_actions", "rival claimed"); return 1; }
    test_pass("t135_pa_universe_actions");
    return 0;
}

# === 1.2.0 bite 3: PA deployed garrisons / async PvP (t136-t138) ===

# Deploy establishes + reinforces an owned garrison; rivals are locked
# out; hostile detection is owner-relative.
fn t136_paw_deploy(): i64 {
    var w = paw_new(1);
    if (paw_deploy(w, 5, 111, 30) != 0)            { test_fail("t136_paw_deploy", "establish"); return 1; }
    if (paw_garrison_owner(w, 5) != 111)           { test_fail("t136_paw_deploy", "owner"); return 1; }
    if (paw_garrison_fighters(w, 5) != 30)         { test_fail("t136_paw_deploy", "fighters"); return 1; }
    if (paw_deploy(w, 5, 111, 20) != 0)            { test_fail("t136_paw_deploy", "reinforce"); return 1; }
    if (paw_garrison_fighters(w, 5) != 50)         { test_fail("t136_paw_deploy", "reinforced count"); return 1; }
    if (paw_deploy(w, 5, 222, 10) != (0 - 1))      { test_fail("t136_paw_deploy", "rival deployed"); return 1; }
    if (paw_deploy(w, 6, 0, 10) != (0 - 2))        { test_fail("t136_paw_deploy", "anon"); return 1; }
    if (paw_deploy(w, 6, 222, 0) != (0 - 4))       { test_fail("t136_paw_deploy", "bad count"); return 1; }
    if (paw_hostile_garrison(w, 5, 222) != 50)     { test_fail("t136_paw_deploy", "rival not hostile"); return 1; }
    if (paw_hostile_garrison(w, 5, 111) != 0)      { test_fail("t136_paw_deploy", "own seen hostile"); return 1; }
    if (paw_hostile_garrison(w, 7, 222) != 0)      { test_fail("t136_paw_deploy", "empty hostile"); return 1; }
    test_pass("t136_paw_deploy");
    return 0;
}

# Pure clash loss: other/2 + roll, capped at active strength.
fn t137_pa_clash_loss(): i64 {
    if (pa_clash_loss(100, 40, 0) != 20)   { test_fail("t137_pa_clash_loss", "base"); return 1; }
    if (pa_clash_loss(100, 40, 5) != 25)   { test_fail("t137_pa_clash_loss", "roll"); return 1; }
    if (pa_clash_loss(10, 40, 0) != 10)    { test_fail("t137_pa_clash_loss", "cap"); return 1; }
    if (pa_clash_loss(100, 0, 0) != 0)     { test_fail("t137_pa_clash_loss", "no foe"); return 1; }
    test_pass("t137_pa_clash_loss");
    return 0;
}

# Arrival resolution: a wiped garrison clears the sector and the ship
# survives; arriving at your OWN garrison is no fight; a hopeless
# arrival destroys the ship.
fn t138_pa_arrival_universe(): i64 {
    var w = paw_new(PA_UNIVERSE_SEED);
    var st = pa_new(PA_UNIVERSE_SEED, DOOR_UNIVERSE, PA_DEF_DAYS);
    pa_start(st);
    store64(st + PA_WORLD, w);
    store64(st + PA_FP, 111);

    # big ship transits a tiny hostile garrison -> garrison wiped, ship lives
    store64(st + PA_SECTOR, 8);
    store64(st + PA_FIGHTERS, 1000);
    paw_set_garrison(w, 8, 222, 1);
    if (pa_arrival_universe(st) != 1)          { test_fail("t138_pa_arrival_universe", "no encounter"); return 1; }
    if (paw_garrison_owner(w, 8) != 0)         { test_fail("t138_pa_arrival_universe", "garrison not cleared"); return 1; }
    if (load64(st + PA_OVER) == 2)             { test_fail("t138_pa_arrival_universe", "ship died vs 1"); return 1; }

    # arriving at your OWN garrison: no fight, untouched
    store64(st + PA_FP, 222);
    paw_set_garrison(w, 9, 222, 5);
    store64(st + PA_SECTOR, 9);
    if (pa_arrival_universe(st) != 0)          { test_fail("t138_pa_arrival_universe", "own fought"); return 1; }
    if (paw_garrison_fighters(w, 9) != 5)      { test_fail("t138_pa_arrival_universe", "own touched"); return 1; }

    # hopeless arrival: 1 fighter into a 1000 garrison -> ship destroyed
    store64(st + PA_FP, 111);
    store64(st + PA_FIGHTERS, 1);
    store64(st + PA_SECTOR, 10);
    paw_set_garrison(w, 10, 222, 1000);
    pa_arrival_universe(st);
    if (load64(st + PA_OVER) != 2)             { test_fail("t138_pa_arrival_universe", "ship not destroyed"); return 1; }
    test_pass("t138_pa_arrival_universe");
    return 0;
}

# === 1.2.0 bite 4: Smuggler shared heat + Handler shared alerts (t139-t140) ===

# Smuggler shared district heat: new/valid, clamped add, and the
# pure heat→cop-chance curve.
fn t139_slw_heat(): i64 {
    var w = slw_new();
    if (slw_valid(w, slw_byte_size()) != 1)      { test_fail("t139_slw_heat", "valid"); return 1; }
    if (slw_valid(w, slw_byte_size() - 8) != 0)  { test_fail("t139_slw_heat", "bad len"); return 1; }
    if (slw_heat(w, 3) != 0)                     { test_fail("t139_slw_heat", "init"); return 1; }
    slw_add_heat(w, 3, 30);
    if (slw_heat(w, 3) != 30)                    { test_fail("t139_slw_heat", "add"); return 1; }
    slw_add_heat(w, 3, 999);
    if (slw_heat(w, 3) != SLW_HEAT_MAX)          { test_fail("t139_slw_heat", "clamp hi"); return 1; }
    slw_add_heat(w, 3, 0 - 999);
    if (slw_heat(w, 3) != 0)                     { test_fail("t139_slw_heat", "clamp lo"); return 1; }
    if (slw_heat(w, 4) != 0)                     { test_fail("t139_slw_heat", "isolation"); return 1; }
    if (sl_heat_chance(18, 0) != 18)             { test_fail("t139_slw_heat", "chance base"); return 1; }
    if (sl_heat_chance(18, 60) <= 18)            { test_fail("t139_slw_heat", "chance up"); return 1; }
    if (sl_heat_chance(18, 100) > 80)            { test_fail("t139_slw_heat", "chance cap"); return 1; }
    test_pass("t139_slw_heat");
    return 0;
}

# Handler shared city alerts: new/valid, clamped add, total, and the
# pure alert→confidence-drain curve.
fn t140_thw_alert(): i64 {
    var w = thw_new();
    if (thw_valid(w, thw_byte_size()) != 1)      { test_fail("t140_thw_alert", "valid"); return 1; }
    if (thw_valid(w, thw_byte_size() + 8) != 0)  { test_fail("t140_thw_alert", "bad len"); return 1; }
    if (thw_total_alert(w) != 0)                 { test_fail("t140_thw_alert", "init total"); return 1; }
    thw_add_alert(w, 0, 40);
    thw_add_alert(w, 2, 60);
    if (thw_alert(w, 0) != 40)                   { test_fail("t140_thw_alert", "alert0"); return 1; }
    if (thw_total_alert(w) != 100)               { test_fail("t140_thw_alert", "total"); return 1; }
    thw_add_alert(w, 0, 999);
    if (thw_alert(w, 0) != THW_ALERT_MAX)        { test_fail("t140_thw_alert", "clamp"); return 1; }
    if (th_alert_drain(0) != 0)                  { test_fail("t140_thw_alert", "drain0"); return 1; }
    if (th_alert_drain(100) != 100 / THW_DRAIN_DIV) { test_fail("t140_thw_alert", "drain"); return 1; }
    test_pass("t140_thw_alert");
    return 0;
}

# === 1.2.0 bite 5: leaderboard score parsing (t141) ===

# lb_line_score extracts the integer score field (after the first tab)
# from a "<handle>\t<score>\t<rank>" line span.
fn t141_lb_line_score(): i64 {
    var s = "qix\t1234\tFree Trader";
    if (lb_line_score(s, 0, strlen(s)) != 1234)   { test_fail("t141_lb_line_score", "basic"); return 1; }
    var s2 = "pac\t0\tBilge Runner";
    if (lb_line_score(s2, 0, strlen(s2)) != 0)    { test_fail("t141_lb_line_score", "zero"); return 1; }
    var s3 = "zax\t98765\tStar Sovereign";
    if (lb_line_score(s3, 0, strlen(s3)) != 98765){ test_fail("t141_lb_line_score", "big"); return 1; }
    var s4 = "nohandle-no-tabs";
    if (lb_line_score(s4, 0, strlen(s4)) != 0)    { test_fail("t141_lb_line_score", "malformed"); return 1; }
    test_pass("t141_lb_line_score");
    return 0;
}


# === 1.3.0 chat area pure helpers (t142-t148, ADR 0011) ===

# Channel names reuse the door-game alphabet: 1..32, [a-z0-9] lead,
# [a-z0-9-_] tail, no '/', no leading dot. Unlike boards, "main" is OK.
fn t142_chat_channel_valid(): i64 {
    if (chat_channel_valid("lobby") != 1)   { test_fail("t142_chat_channel_valid", "lobby"); return 1; }
    if (chat_channel_valid("main") != 1)     { test_fail("t142_chat_channel_valid", "main allowed"); return 1; }
    if (chat_channel_valid("dev-2_a") != 1)  { test_fail("t142_chat_channel_valid", "alnum-dash-us"); return 1; }
    if (chat_channel_valid("") != 0)         { test_fail("t142_chat_channel_valid", "empty"); return 1; }
    if (chat_channel_valid("-bad") != 0)     { test_fail("t142_chat_channel_valid", "lead dash"); return 1; }
    if (chat_channel_valid(".hidden") != 0)  { test_fail("t142_chat_channel_valid", "lead dot"); return 1; }
    if (chat_channel_valid("a/b") != 0)      { test_fail("t142_chat_channel_valid", "slash"); return 1; }
    if (chat_channel_valid("UP") != 0)       { test_fail("t142_chat_channel_valid", "uppercase"); return 1; }
    test_pass("t142_chat_channel_valid");
    return 0;
}

# format_line writes "<seq>\t<handle>\t<text>\n"; line_seq parses the
# leading seq back; last_seq returns the seq of the final line.
fn t143_chat_format_seq(): i64 {
    var out = alloc(64);
    var n = chat_format_line(7, "qix", "hi", 2, out);
    # "7\tqix\thi\n" = 1+1+3+1+2+1 = 9
    if (n != 9)                          { test_fail("t143_chat_format_seq", "len"); return 1; }
    if (chat_line_seq(out, 0, n) != 7)   { test_fail("t143_chat_format_seq", "seq"); return 1; }
    if ((load8(out + 1) & 0xFF) != 9)    { test_fail("t143_chat_format_seq", "tab1"); return 1; }
    if ((load8(out + n - 1) & 0xFF) != 10) { test_fail("t143_chat_format_seq", "nl"); return 1; }
    # two-line buffer → last_seq is the second line's seq
    var buf = alloc(128);
    var p = chat_format_line(3, "a", "x", 1, buf);
    p = p + chat_format_line(42, "b", "y", 1, buf + p);
    if (chat_last_seq(buf, p) != 42)     { test_fail("t143_chat_format_seq", "last_seq"); return 1; }
    if (chat_last_seq(buf, 0) != 0)      { test_fail("t143_chat_format_seq", "empty"); return 1; }
    test_pass("t143_chat_format_seq");
    return 0;
}

# render_one turns a stored "seq\thandle\ttext" span into the display
# line "<handle> text\r\n"; a span with no handle field renders nothing.
fn t144_chat_render_one(): i64 {
    var line = "5\tqix\thello";
    var out = alloc(64);
    var n = chat_render_one(line, 0, strlen(line), out);
    # "<qix> hello\r\n" = 1+3+1+1+5+2 = 13
    if (n != 13)                       { test_fail("t144_chat_render_one", "len"); return 1; }
    if ((load8(out) & 0xFF) != 60)     { test_fail("t144_chat_render_one", "lt"); return 1; }
    if (memeq(out, "<qix> hello", 11) == 0) { test_fail("t144_chat_render_one", "body"); return 1; }
    if ((load8(out + 11) & 0xFF) != 13) { test_fail("t144_chat_render_one", "cr"); return 1; }
    if ((load8(out + 12) & 0xFF) != 10) { test_fail("t144_chat_render_one", "lf"); return 1; }
    # malformed (only a seq, no tab) → 0
    var bad = "99";
    if (chat_render_one(bad, 0, strlen(bad), out) != 0) { test_fail("t144_chat_render_one", "malformed"); return 1; }
    test_pass("t144_chat_render_one");
    return 0;
}

# emit_since renders only lines with seq > since and reports the new
# watermark (max seq seen) — the live-tail core.
fn t145_chat_emit_since(): i64 {
    var buf = alloc(128);
    var p = chat_format_line(1, "a", "one", 3, buf);
    p = p + chat_format_line(2, "b", "two", 3, buf + p);
    p = p + chat_format_line(3, "c", "three", 5, buf + p);
    var out = alloc(1024);
    var seenp = alloc(8);
    # since=1 → only seq 2 and 3 render. (outcap must exceed
    # CHAT_LINE_DISP_MAX per render line — production uses CHAT_TAIL_CAP.)
    store64(seenp, 0);
    var ol = chat_emit_since(buf, p, 1, out, 1024, seenp);
    if (load64(seenp) != 3)            { test_fail("t145_chat_emit_since", "watermark"); return 1; }
    # "<b> two\r\n<c> three\r\n" = 9 + 11 = 20
    if (ol != 20)                      { test_fail("t145_chat_emit_since", "since1 len"); return 1; }
    if (memeq(out, "<b> two\r\n<c> three\r\n", 20) == 0) { test_fail("t145_chat_emit_since", "since1 body"); return 1; }
    # since=3 → nothing new, watermark stays 3
    store64(seenp, 3);
    if (chat_emit_since(buf, p, 3, out, 1024, seenp) != 0) { test_fail("t145_chat_emit_since", "since3"); return 1; }
    if (load64(seenp) != 3)            { test_fail("t145_chat_emit_since", "since3 wm"); return 1; }
    test_pass("t145_chat_emit_since");
    return 0;
}

# trim_to_cap drops whole front lines until len <= cap, landing on a
# line boundary and keeping the maximum tail that fits.
fn t146_chat_trim(): i64 {
    var buf = alloc(64);
    # three 5-byte lines: "aaaa\nbbbb\ncccc\n" = 15
    memcpy(buf, "aaaa\nbbbb\ncccc\n", 15);
    # cap 15 → unchanged
    if (chat_trim_to_cap(buf, 15, 15) != 15) { test_fail("t146_chat_trim", "nocap"); return 1; }
    # cap 10: drop=5 lands exactly on line-2 start → keep "bbbb\ncccc\n"
    memcpy(buf, "aaaa\nbbbb\ncccc\n", 15);
    var nl = chat_trim_to_cap(buf, 15, 10);
    if (nl != 10)                            { test_fail("t146_chat_trim", "len10"); return 1; }
    if (memeq(buf, "bbbb\ncccc\n", 10) == 0) { test_fail("t146_chat_trim", "tail10"); return 1; }
    # cap 9: must shed >5 → drop two lines → keep "cccc\n" (5)
    memcpy(buf, "aaaa\nbbbb\ncccc\n", 15);
    var n9 = chat_trim_to_cap(buf, 15, 9);
    if (n9 != 5)                             { test_fail("t146_chat_trim", "len9"); return 1; }
    if (memeq(buf, "cccc\n", 5) == 0)        { test_fail("t146_chat_trim", "tail9"); return 1; }
    test_pass("t146_chat_trim");
    return 0;
}

# text_sanitize keeps only printable ASCII (32..126); drops control,
# tab, CR/LF, ESC, high bytes; caps at `cap`.
fn t147_chat_sanitize(): i64 {
    var out = alloc(64);
    # embed TAB(9), ESC(27), NUL(0), DEL(127), high(200) among printables
    var src = alloc(16);
    store8(src + 0, 104);   # h
    store8(src + 1, 9);     # TAB (drop)
    store8(src + 2, 105);   # i
    store8(src + 3, 27);    # ESC (drop)
    store8(src + 4, 33);    # !
    store8(src + 5, 0);     # NUL (drop)
    store8(src + 6, 127);   # DEL (drop)
    store8(src + 7, 200);   # high (drop)
    var n = chat_text_sanitize(src, 8, out, 64);
    if (n != 3)                        { test_fail("t147_chat_sanitize", "len"); return 1; }
    if (memeq(out, "hi!", 3) == 0)     { test_fail("t147_chat_sanitize", "body"); return 1; }
    # cap clamps output
    var n2 = chat_text_sanitize("abcdef", 6, out, 4);
    if (n2 != 4)                       { test_fail("t147_chat_sanitize", "cap"); return 1; }
    test_pass("t147_chat_sanitize");
    return 0;
}

# tail_k_start / emit_tail_k pick the last k lines for join scrollback
# and report the latest seq as the watermark.
fn t148_chat_scrollback(): i64 {
    var buf = alloc(128);
    var p = chat_format_line(1, "a", "x", 1, buf);
    p = p + chat_format_line(2, "b", "y", 1, buf + p);
    p = p + chat_format_line(3, "c", "z", 1, buf + p);
    # last 2 of 3 lines
    var start = chat_tail_k_start(buf, p, 2);
    if (chat_line_seq(buf, start, p) != 2) { test_fail("t148_chat_scrollback", "k2 start"); return 1; }
    # k >= line count → from 0
    if (chat_tail_k_start(buf, p, 9) != 0) { test_fail("t148_chat_scrollback", "k all"); return 1; }
    var out = alloc(1024);
    var seenp = alloc(8);
    store64(seenp, 0);
    var ol = chat_emit_tail_k(buf, p, 2, out, 1024, seenp);
    if (load64(seenp) != 3)                { test_fail("t148_chat_scrollback", "watermark"); return 1; }
    # "<b> y\r\n<c> z\r\n" = 7 + 7 = 14
    if (ol != 14)                          { test_fail("t148_chat_scrollback", "len"); return 1; }
    if (memeq(out, "<b> y\r\n<c> z\r\n", 14) == 0) { test_fail("t148_chat_scrollback", "body"); return 1; }
    test_pass("t148_chat_scrollback");
    return 0;
}

# === 1.3.0 Eliza / DOCTOR engine (t149-t154, ADR 0011) ===

# normalize: lowercase, punctuation -> single space, apostrophes kept, trim.
fn t149_ez_normalize(): i64 {
    var out = alloc(64);
    var n = ez_normalize("Hello, World!", 13, out, EZ_IN_MAX);
    if (n != 11)                       { test_fail("t149_ez_normalize", "len"); return 1; }
    if (memeq(out, "hello world", 11) == 0) { test_fail("t149_ez_normalize", "body"); return 1; }
    # apostrophe survives, case folds
    var n2 = ez_normalize("I'M Fine", 8, out, EZ_IN_MAX);
    if (memeq(out, "i'm fine", n2) == 0)    { test_fail("t149_ez_normalize", "apostrophe"); return 1; }
    test_pass("t149_ez_normalize");
    return 0;
}

# reflect: whole-word pronoun swap, single pass.
fn t150_ez_reflect(): i64 {
    var out = alloc(128);
    var n = ez_reflect("i am happy", 10, out, 128);
    if (memeq(out, "you are happy", n) == 0) { test_fail("t150_ez_reflect", "i am"); return 1; }
    var n2 = ez_reflect("my name", 7, out, 128);
    if (memeq(out, "your name", n2) == 0)    { test_fail("t150_ez_reflect", "my"); return 1; }
    var n3 = ez_reflect("i'm fine", 8, out, 128);
    if (memeq(out, "you are fine", n3) == 0) { test_fail("t150_ez_reflect", "contraction"); return 1; }
    test_pass("t150_ez_reflect");
    return 0;
}

# scan: highest rank wins, leftmost on ties.
fn t151_ez_scan(): i64 {
    var pp = alloc(8);
    var lp = alloc(8);
    # COMPUTER(50) beats MY(2)
    var nb = alloc(64);
    var l1 = ez_normalize("my computer is broken", 21, nb, EZ_IN_MAX);
    if (ez_scan(nb, l1, pp, lp) != KW_COMPUTER) { test_fail("t151_ez_scan", "computer"); return 1; }
    # REMEMBER(5) beats I(0) and YOU(0)
    var l2 = ez_normalize("i remember you", 14, nb, EZ_IN_MAX);
    if (ez_scan(nb, l2, pp, lp) != KW_REMEMBER) { test_fail("t151_ez_scan", "remember"); return 1; }
    # plain "i am sad" -> leftmost rank-0 keyword is I
    var l3 = ez_normalize("i am sad", 8, nb, EZ_IN_MAX);
    if (ez_scan(nb, l3, pp, lp) != KW_I)        { test_fail("t151_ez_scan", "i leftmost"); return 1; }
    # no keyword
    var l4 = ez_normalize("blah blah", 9, nb, EZ_IN_MAX);
    if (ez_scan(nb, l4, pp, lp) != KW_NONE)     { test_fail("t151_ez_scan", "none"); return 1; }
    test_pass("t151_ez_scan");
    return 0;
}

# respond: decomposition + reassembly through a fresh state.
fn t152_ez_respond(): i64 {
    var st = ez_new(0, 0, 0);
    var out = alloc(EZ_RESP_CAP);
    # "I am sad" -> i/am decomposition, predicate reflected
    var n = ez_respond(st, "I am sad", 8, out);
    if (memeq(out, "How long have you been sad?", n) == 0) { test_fail("t152_ez_respond", "i am sad"); return 1; }
    # "Sorry" -> canned (counter 0)
    var n2 = ez_respond(st, "Sorry", 5, out);
    if (memeq(out, "Please don't apologize.", n2) == 0)    { test_fail("t152_ez_respond", "sorry"); return 1; }
    # no keyword -> first NONE deflection
    var n3 = ez_respond(st, "xyzzy plugh", 11, out);
    if (memeq(out, "I am not sure I understand you fully.", n3) == 0) { test_fail("t152_ez_respond", "none"); return 1; }
    test_pass("t152_ez_respond");
    return 0;
}

# memory: a "my X" stash resurfaces on a later NONE turn.
fn t153_ez_memory(): i64 {
    var st = ez_new(0, 0, 0);
    var out = alloc(EZ_RESP_CAP);
    # stash: "my dog is sick" -> "Your dog is sick?" + memory "dog is sick"
    var n = ez_respond(st, "my dog is sick", 14, out);
    if (memeq(out, "Your dog is sick?", n) == 0) { test_fail("t153_ez_memory", "my reply"); return 1; }
    # NONE turn surfaces the oldest memory
    var n2 = ez_respond(st, "hmmmm", 5, out);
    if (memeq(out, "Earlier you said your dog is sick.", n2) == 0) { test_fail("t153_ez_memory", "resurface"); return 1; }
    test_pass("t153_ez_memory");
    return 0;
}

# object-position "you" reflects to "me"; subject "you are/were" -> "I am/was".
# (Regression guard for the 1.3.0 review's reflection-grammar findings.)
fn t155_ez_reflect_you(): i64 {
    var out = alloc(128);
    var n = ez_reflect("i hate you", 10, out, 128);
    if (memeq(out, "you hate me", n) == 0)  { test_fail("t155_ez_reflect_you", "object you"); return 1; }
    var n2 = ez_reflect("you are sad", 11, out, 128);
    if (memeq(out, "I am sad", n2) == 0)    { test_fail("t155_ez_reflect_you", "you are"); return 1; }
    var n3 = ez_reflect("you were here", 13, out, 128);
    if (memeq(out, "I was here", n3) == 0)  { test_fail("t155_ez_reflect_you", "you were"); return 1; }
    # end-to-end through ez_respond (fresh state each so idx == 0)
    var s1 = ez_new(0, 0, 0);
    var r = ez_respond(s1, "i hate you", 10, out);
    if (memeq(out, "You say hate me?", r) == 0) { test_fail("t155_ez_reflect_you", "respond object"); return 1; }
    var s2 = ez_new(0, 0, 0);
    var r2 = ez_respond(s2, "if you are happy", 16, out);
    if (memeq(out, "Do you think it's likely that I am happy?", r2) == 0) { test_fail("t155_ez_reflect_you", "respond you-are"); return 1; }
    test_pass("t155_ez_reflect_you");
    return 0;
}

# quit pre-scan recognizes goodbye tokens.
fn t154_ez_quit(): i64 {
    if (ez_is_quit("bye", 3) != 1)         { test_fail("t154_ez_quit", "bye"); return 1; }
    if (ez_is_quit("Goodbye now", 11) != 1){ test_fail("t154_ez_quit", "goodbye"); return 1; }
    if (ez_is_quit("hello", 5) != 0)       { test_fail("t154_ez_quit", "hello"); return 1; }
    if (ez_is_quit("i am fine", 9) != 0)   { test_fail("t154_ez_quit", "not quit"); return 1; }
    test_pass("t154_ez_quit");
    return 0;
}

# === 1.3.1 PARRY affect engine (t156-t160) ===

# input classifier flags
fn t156_py_classify(): i64 {
    var nb = alloc(64);
    var l1 = ez_normalize("you are crazy", 13, nb, PY_IN_MAX);
    if ((py_scan_flags(nb, l1) & PF_INSULT) == 0)     { test_fail("t156_py_classify", "insult"); return 1; }
    var l2 = ez_normalize("the mafia is after me", 21, nb, PY_IN_MAX);
    if ((py_scan_flags(nb, l2) & PF_FLARE_HOT) == 0)  { test_fail("t156_py_classify", "flare hot"); return 1; }
    var l3 = ez_normalize("why do you ask", 14, nb, PY_IN_MAX);
    if ((py_scan_flags(nb, l3) & PF_PROBE) == 0)      { test_fail("t156_py_classify", "probe"); return 1; }
    var l4 = ez_normalize("i understand", 12, nb, PY_IN_MAX);
    if ((py_scan_flags(nb, l4) & PF_BENE) == 0)       { test_fail("t156_py_classify", "bene"); return 1; }
    var l5 = ez_normalize("nice weather today", 18, nb, PY_IN_MAX);
    if (py_scan_flags(nb, l5) != 0)                   { test_fail("t156_py_classify", "neutral=0"); return 1; }
    test_pass("t156_py_classify");
    return 0;
}

# affect dynamics: a hot flare spikes; benevolence calms fear/anger fast,
# mistrust slow (the sticky-paranoia asymmetry).
fn t157_py_affect(): i64 {
    var st = py_new(0, 0, 0);
    # fresh baselines
    if (load64(st + PY_FEAR) != PY_FEAR_BASE)         { test_fail("t157_py_affect", "fear base"); return 1; }
    if (load64(st + PY_MISTRUST) != PY_MISTRUST_BASE) { test_fail("t157_py_affect", "mistrust base"); return 1; }
    # one HOT flare: F 1->5, A 1->2, M 4->9
    py_apply_affect(st, PF_FLARE_HOT);
    if (load64(st + PY_FEAR) != 5)     { test_fail("t157_py_affect", "flare fear"); return 1; }
    if (load64(st + PY_ANGER) != 2)    { test_fail("t157_py_affect", "flare anger"); return 1; }
    if (load64(st + PY_MISTRUST) != 9) { test_fail("t157_py_affect", "flare mistrust"); return 1; }
    # from a riled state, benevolence: decay (F10->8,A10->8,M10->9) then
    # bene (-2,-2,-1) => F6 A6 M8 — fear/anger drop more than mistrust.
    var s2 = py_new(0, 0, 0);
    store64(s2 + PY_FEAR, 10); store64(s2 + PY_ANGER, 10); store64(s2 + PY_MISTRUST, 10);
    py_apply_affect(s2, PF_BENE);
    if (load64(s2 + PY_FEAR) != 6)     { test_fail("t157_py_affect", "calm fear"); return 1; }
    if (load64(s2 + PY_ANGER) != 6)    { test_fail("t157_py_affect", "calm anger"); return 1; }
    if (load64(s2 + PY_MISTRUST) != 8) { test_fail("t157_py_affect", "calm mistrust sticky"); return 1; }
    test_pass("t157_py_affect");
    return 0;
}

# mood derivation thresholds + hostile/fearful tie-break.
fn t158_py_mood(): i64 {
    if (py_mood(1, 1, 4) != MOOD_CALM)      { test_fail("t158_py_mood", "calm"); return 1; }
    if (py_mood(1, 1, 7) != MOOD_WARY)      { test_fail("t158_py_mood", "wary"); return 1; }
    if (py_mood(12, 1, 9) != MOOD_FEARFUL)  { test_fail("t158_py_mood", "fearful"); return 1; }
    if (py_mood(12, 15, 9) != MOOD_HOSTILE) { test_fail("t158_py_mood", "hostile"); return 1; }
    # both high, fear dominates -> fearful (shut down, not lash out)
    if (py_mood(15, 12, 9) != MOOD_FEARFUL) { test_fail("t158_py_mood", "fear-dominant"); return 1; }
    test_pass("t158_py_mood");
    return 0;
}

# end-to-end: calm greeting, then a hot flare launches the delusion story.
fn t159_py_respond(): i64 {
    var st = py_new(0, 0, 0);
    var out = alloc(PY_RESP_CAP);
    var n = py_respond(st, "hello there", 11, out);
    if (memeq(out, "I'm getting by.", n) == 0) { test_fail("t159_py_respond", "calm"); return 1; }
    # a hot flare -> story latches, beat 0
    var n2 = py_respond(st, "the mafia is after me", 21, out);
    if (memeq(out, "I got in over my head betting the horses. I owe money I haven't got.", n2) == 0) { test_fail("t159_py_respond", "story beat 0"); return 1; }
    if (load64(st + PY_STORYIDX) != 1) { test_fail("t159_py_respond", "beat advanced"); return 1; }
    test_pass("t159_py_respond");
    return 0;
}

# story steers back (no beat advance) when the user changes the subject.
fn t160_py_steerback(): i64 {
    var st = py_new(0, 0, 0);
    var out = alloc(PY_RESP_CAP);
    store64(st + PY_STORYON, 1);
    store64(st + PY_STORYIDX, 3);
    store64(st + PY_MISTRUST, 10);
    var n = py_respond(st, "nice weather today", 18, out);
    if (memeq(out, "I don't care about that. What I'm telling you is they're after me.", n) == 0) { test_fail("t160_py_steerback", "steerback text"); return 1; }
    if (load64(st + PY_STORYIDX) != 3) { test_fail("t160_py_steerback", "beat held"); return 1; }
    test_pass("t160_py_steerback");
    return 0;
}

# === 1.3.2 QUEST (LORD homage) — t161-t166 ===

# daily-turn rationing: refill on a new wall-clock day + bank interest;
# same-day calls are no-ops.
fn t161_qu_day_tick(): i64 {
    var st = qu_new(7, 0, 0);
    if (qu_day_tick(st, 100) != 1)            { test_fail("t161_qu_day_tick", "first rollover"); return 1; }
    if (load64(st + QU_FOREST) != QU_FOREST_DAILY) { test_fail("t161_qu_day_tick", "refill"); return 1; }
    if (load64(st + QU_LASTDAY) != 100)       { test_fail("t161_qu_day_tick", "lastday"); return 1; }
    store64(st + QU_FOREST, 3);
    store64(st + QU_BANK, 100);
    if (qu_day_tick(st, 100) != 0)            { test_fail("t161_qu_day_tick", "same day no-op"); return 1; }
    if (load64(st + QU_FOREST) != 3)          { test_fail("t161_qu_day_tick", "no refill same day"); return 1; }
    if (qu_day_tick(st, 101) != 1)            { test_fail("t161_qu_day_tick", "next day"); return 1; }
    if (load64(st + QU_FOREST) != QU_FOREST_DAILY) { test_fail("t161_qu_day_tick", "refill 2"); return 1; }
    if (load64(st + QU_BANK) != 110)          { test_fail("t161_qu_day_tick", "interest 10%"); return 1; }
    test_pass("t161_qu_day_tick");
    return 0;
}

# master victory: advance + stat boost + full heal + a turning-point
# fragment; the level-12 Sovereign = ascension (won + over).
fn t162_qu_master_victory(): i64 {
    var st = qu_new(7, 0, 0);
    store64(st + QU_LEVEL, 3);
    store64(st + QU_MAXHP, 50); store64(st + QU_HP, 10); store64(st + QU_STR, 10);
    if (qu_master_victory(st) != 0)           { test_fail("t162_qu_master_victory", "not ended"); return 1; }
    if (load64(st + QU_FRAGS) != 1)           { test_fail("t162_qu_master_victory", "fragment at L3"); return 1; }
    if (load64(st + QU_LEVEL) != 4)           { test_fail("t162_qu_master_victory", "advanced"); return 1; }
    if (load64(st + QU_MAXHP) != 58)          { test_fail("t162_qu_master_victory", "maxhp+8"); return 1; }
    if (load64(st + QU_STR) != 13)            { test_fail("t162_qu_master_victory", "str+3"); return 1; }
    if (load64(st + QU_HP) != load64(st + QU_MAXHP)) { test_fail("t162_qu_master_victory", "full heal"); return 1; }
    # ascension
    var s2 = qu_new(7, 0, 0);
    store64(s2 + QU_LEVEL, 12); store64(s2 + QU_FRAGS, 3);
    if (qu_master_victory(s2) != 1)           { test_fail("t162_qu_master_victory", "ascension ends"); return 1; }
    if (load64(s2 + QU_WON) != 1)             { test_fail("t162_qu_master_victory", "won"); return 1; }
    if (load64(s2 + QU_OVER) != 1)            { test_fail("t162_qu_master_victory", "over"); return 1; }
    if (load64(s2 + QU_FRAGS) != 4)           { test_fail("t162_qu_master_victory", "4th fragment"); return 1; }
    test_pass("t162_qu_master_victory");
    return 0;
}

# spawn scaling + the Sovereign at L12; master-ready gate.
fn t163_qu_spawn(): i64 {
    var st = qu_new(7, 0, 0);
    store64(st + QU_LEVEL, 5);
    qu_spawn_beast(st);
    if (load64(st + QU_FOE_KIND) != FOE_BEAST) { test_fail("t163_qu_spawn", "beast kind"); return 1; }
    if (load64(st + QU_FOE_HP) <= 0)          { test_fail("t163_qu_spawn", "beast hp"); return 1; }
    qu_spawn_master(st);
    if (load64(st + QU_FOE_KIND) != FOE_MASTER) { test_fail("t163_qu_spawn", "master kind"); return 1; }
    store64(st + QU_LEVEL, 12);
    qu_spawn_master(st);
    if (load64(st + QU_FOE_KIND) != FOE_SOVEREIGN) { test_fail("t163_qu_spawn", "sovereign"); return 1; }
    store64(st + QU_LVLWINS, 2);
    if (qu_master_ready(st) != 0)             { test_fail("t163_qu_spawn", "not ready"); return 1; }
    store64(st + QU_LVLWINS, QU_MASTER_AT);
    if (qu_master_ready(st) != 1)             { test_fail("t163_qu_spawn", "ready"); return 1; }
    test_pass("t163_qu_spawn");
    return 0;
}

# save round-trip (positional QUST1).
fn t164_qu_save(): i64 {
    var st = qu_new(123, 1, 0);
    store64(st + QU_LEVEL, 7); store64(st + QU_HP, 33); store64(st + QU_MAXHP, 70);
    store64(st + QU_STR, 18); store64(st + QU_GOLD, 250); store64(st + QU_BANK, 99);
    store64(st + QU_FRAGS, 2); store64(st + QU_FOUGHT, 40); store64(st + QU_LASTDAY, 555);
    var buf = alloc(QU_SAVE_CAP);
    var n = qu_save_format(st, buf, QU_SAVE_CAP);
    var st2 = qu_load_parse(buf, n);
    if (st2 == 0)                       { test_fail("t164_qu_save", "parse"); return 1; }
    if (load64(st2 + QU_LEVEL) != 7)    { test_fail("t164_qu_save", "level"); return 1; }
    if (load64(st2 + QU_GOLD) != 250)   { test_fail("t164_qu_save", "gold"); return 1; }
    if (load64(st2 + QU_FRAGS) != 2)    { test_fail("t164_qu_save", "frags"); return 1; }
    if (load64(st2 + QU_LASTDAY) != 555){ test_fail("t164_qu_save", "lastday"); return 1; }
    if (load64(st2 + QU_STR) != 18)     { test_fail("t164_qu_save", "str"); return 1; }
    if (qu_load_parse("NOPE", 4) != 0)  { test_fail("t164_qu_save", "bad header"); return 1; }
    test_pass("t164_qu_save");
    return 0;
}

# score / rank / heal cost.
fn t165_qu_score(): i64 {
    var st = qu_new(7, 0, 0);
    store64(st + QU_LEVEL, 5); store64(st + QU_FOUGHT, 20); store64(st + QU_FRAGS, 2);
    if (qu_final_score(st) != 6200)    { test_fail("t165_qu_score", "score"); return 1; }
    store64(st + QU_WON, 1);
    if (qu_final_score(st) != 56200)   { test_fail("t165_qu_score", "won bonus"); return 1; }
    if (streq(qu_rank(56200), "Sovereign of the Emerald Throne") == 0) { test_fail("t165_qu_score", "rank top"); return 1; }
    if (streq(qu_rank(100), "Pilgrim of the Mud") == 0) { test_fail("t165_qu_score", "rank low"); return 1; }
    store64(st + QU_MAXHP, 50); store64(st + QU_HP, 30);
    if (qu_heal_cost(st) != 40)        { test_fail("t165_qu_score", "heal cost"); return 1; }
    test_pass("t165_qu_score");
    return 0;
}

# feed: hunting in the forest spends a ration and enters a fight.
fn t166_qu_feed(): i64 {
    var st = qu_new(7, 0, 0);
    qu_start(st);
    store64(st + QU_SCREEN, QSCR_FOREST);
    store64(st + QU_FOREST, 5);
    qu_feed(st, "y", 1);
    if (load64(st + QU_SCREEN) != QSCR_FIGHT) { test_fail("t166_qu_feed", "enter fight"); return 1; }
    if (load64(st + QU_FOREST) != 4)          { test_fail("t166_qu_feed", "ration spent"); return 1; }
    if (load64(st + QU_FOE_HP) <= 0)          { test_fail("t166_qu_feed", "foe spawned"); return 1; }
    test_pass("t166_qu_feed");
    return 0;
}

# === 1.3.3 Jabberwacky (corpus-learning chatbot) — t167-t178 ===

# Sanitiser: drop control bytes (TAB/ESC), keep printable, trim trailing
# space. The TAB/ESC drop is the record-delimiter + escape-injection
# guard for the learned corpus.
fn t167_jw_sanitize(): i64 {
    var out = alloc(64);
    var inb = alloc(16);
    store8(inb + 0, 104);   # h
    store8(inb + 1, 105);   # i
    store8(inb + 2, 9);     # TAB  -> dropped
    store8(inb + 3, 116);   # t
    store8(inb + 4, 111);   # o
    store8(inb + 5, 27);    # ESC  -> dropped
    store8(inb + 6, 32);    # space (trailing -> trimmed)
    store8(inb + 7, 32);    # space (trailing -> trimmed)
    var n = jw_sanitize(inb, 8, out, 64);
    if (n != 4)                       { test_fail("t167_jw_sanitize", "len"); return 1; }
    if (memeq(out, "hito", 4) == 0)   { test_fail("t167_jw_sanitize", "body"); return 1; }
    test_pass("t167_jw_sanitize");
    return 0;
}

# Whole-word membership: present, absent, and a substring is NOT a match.
fn t168_jw_word_in(): i64 {
    var b = alloc(64);
    var bl = ez_normalize("dog and fish", 12, b, JW_IN_MAX);
    if (jw_word_in("dog", 3, b, bl) != 1)  { test_fail("t168_jw_word_in", "present"); return 1; }
    if (jw_word_in("cat", 3, b, bl) != 0)  { test_fail("t168_jw_word_in", "absent"); return 1; }
    if (jw_word_in("fis", 3, b, bl) != 0)  { test_fail("t168_jw_word_in", "substring"); return 1; }
    test_pass("t168_jw_word_in");
    return 0;
}

# Word-overlap score: content matches, stop-words skipped, 1-char
# skipped, no-overlap = 0, and a REPEATED query word counts once.
fn t169_jw_overlap(): i64 {
    var b = alloc(64);
    var bl = ez_normalize("dog and fish", 12, b, JW_IN_MAX);   # "and" is a stop-word
    var a = alloc(64);
    var al = ez_normalize("cat dog fish", 12, a, JW_IN_MAX);
    if (jw_overlap(a, al, b, bl) != 2) { test_fail("t169_jw_overlap", "two"); return 1; }
    var c = alloc(64);
    var cl = ez_normalize("the dog", 7, c, JW_IN_MAX);          # "the" skipped
    if (jw_overlap(c, cl, b, bl) != 1) { test_fail("t169_jw_overlap", "stopskip"); return 1; }
    var d = alloc(64);
    var dl = ez_normalize("a dog", 5, d, JW_IN_MAX);            # "a" skipped (1-char)
    if (jw_overlap(d, dl, b, bl) != 1) { test_fail("t169_jw_overlap", "shortskip"); return 1; }
    var e = alloc(64);
    var el = ez_normalize("bird worm", 9, e, JW_IN_MAX);
    if (jw_overlap(e, el, b, bl) != 0) { test_fail("t169_jw_overlap", "none"); return 1; }
    var f = alloc(64);
    var fl = ez_normalize("dog dog cat", 11, f, JW_IN_MAX);     # distinct: "dog" once
    if (jw_overlap(f, fl, b, bl) != 1) { test_fail("t169_jw_overlap", "distinct"); return 1; }
    test_pass("t169_jw_overlap");
    return 0;
}

# Best-match over the seed corpus: a seed hit resolves to the right
# response, no-overlap returns (0-1), and ties go to the LATEST pair.
fn t170_jw_best_match(): i64 {
    var st = jw_new(0, DOOR_PRACTICE, JW_DEF_DAYS);
    var q = alloc(64);
    var ql = ez_normalize("what is your name", 17, q, JW_IN_MAX);
    var idx = jw_best_match(st, q, ql);
    if (idx < 0) { test_fail("t170_jw_best_match", "name hit"); return 1; }
    var rl = load64(load64(st + JW_RTXTL) + idx * 8);
    if (memeq(load64(st + JW_RTXT) + idx * JW_SLOT, "Jabberwacky. Easy for you to say.", rl) == 0) {
        test_fail("t170_jw_best_match", "name resp"); return 1; }
    var q2 = alloc(64);
    var ql2 = ez_normalize("zzz qqq", 7, q2, JW_IN_MAX);
    if (jw_best_match(st, q2, ql2) != (0 - 1)) { test_fail("t170_jw_best_match", "no match"); return 1; }
    # latest pair wins a score tie
    jw_add_pair(st, "tiebreak word", 13, "FIRST", 5);
    jw_add_pair(st, "tiebreak word", 13, "SECOND", 6);
    var q3 = alloc(64);
    var ql3 = ez_normalize("tiebreak word", 13, q3, JW_IN_MAX);
    var idx3 = jw_best_match(st, q3, ql3);
    var rl3 = load64(load64(st + JW_RTXTL) + idx3 * 8);
    if (memeq(load64(st + JW_RTXT) + idx3 * JW_SLOT, "SECOND", rl3) == 0) {
        test_fail("t170_jw_best_match", "latest wins"); return 1; }
    test_pass("t170_jw_best_match");
    return 0;
}

# Seed response (fresh state) + the generic fallback when nothing matches.
fn t171_jw_seed_response(): i64 {
    var st = jw_new(0, DOOR_PRACTICE, JW_DEF_DAYS);
    var out = alloc(JW_RESP_CAP);
    var exp = "Jabberwacky. Easy for you to say.";
    var n = jw_respond(st, "what is your name", 17, out);
    if (n != strlen(exp))            { test_fail("t171_jw_seed_response", "len"); return 1; }
    if (memeq(out, exp, n) == 0)     { test_fail("t171_jw_seed_response", "body"); return 1; }
    var st2 = jw_new(0, DOOR_PRACTICE, JW_DEF_DAYS);
    var n2 = jw_respond(st2, "xyzzy plugh", 11, out);   # turn 0 -> first fallback
    if (memeq(out, "Go on.", n2) == 0) { test_fail("t171_jw_seed_response", "fallback"); return 1; }
    test_pass("t171_jw_seed_response");
    return 0;
}

# THE core mechanic: teach (prev line -> this line), then replay it.
fn t172_jw_learn_replay(): i64 {
    var st = jw_new(0, DOOR_PRACTICE, JW_DEF_DAYS);
    var out = alloc(JW_RESP_CAP);
    var exp = "the password is rosebud";
    jw_respond(st, "what is the password", 20, out);     # turn 0
    jw_respond(st, "the password is rosebud", 23, out);  # turn 1: learns the pair
    var n = jw_respond(st, "what is the password", 20, out);  # turn 2: replays
    if (n != strlen(exp))         { test_fail("t172_jw_learn_replay", "len"); return 1; }
    if (memeq(out, exp, n) == 0)  { test_fail("t172_jw_learn_replay", "replay"); return 1; }
    test_pass("t172_jw_learn_replay");
    return 0;
}

# Persistence round-trip: a learned pair survives save_format -> load_parse.
fn t173_jw_save_load(): i64 {
    var st = jw_new(0, DOOR_SOLO, JW_DEF_DAYS);
    var out = alloc(JW_RESP_CAP);
    jw_respond(st, "secret code phrase", 18, out);
    jw_respond(st, "the code is hunter two", 22, out);   # learns (secret code phrase -> ...)
    var sbuf = alloc(4096);
    var sn = jw_save_format(st, sbuf, 4096);
    if (memeq(sbuf, "JBRW1\n", 6) == 0) { test_fail("t173_jw_save_load", "header"); return 1; }
    var st2 = jw_load_parse(sbuf, sn);
    if (st2 == 0) { test_fail("t173_jw_save_load", "load null"); return 1; }
    var exp = "the code is hunter two";
    var n2 = jw_respond(st2, "secret code phrase", 18, out);
    if (n2 != strlen(exp))         { test_fail("t173_jw_save_load", "rt len"); return 1; }
    if (memeq(out, exp, n2) == 0)  { test_fail("t173_jw_save_load", "rt replay"); return 1; }
    if (jw_load_parse("NOPE", 4) != 0) { test_fail("t173_jw_save_load", "bad header"); return 1; }
    test_pass("t173_jw_save_load");
    return 0;
}

# Ring cap: learned pairs evict oldest at JW_MAXPAIRS; seeds never evict.
fn t174_jw_evict_cap(): i64 {
    var st = jw_new(0, DOOR_PRACTICE, JW_DEF_DAYS);
    var i = 0;
    var go = 1;
    while (go == 1) {
        if (i >= 50) { go = 0; continue; }
        jw_add_pair(st, "znp word here", 13, "junk", 4);
        i = i + 1;
    }
    if (load64(st + JW_COUNT) != JW_MAXPAIRS) { test_fail("t174_jw_evict_cap", "cap"); return 1; }
    var out = alloc(JW_RESP_CAP);
    var n = jw_respond(st, "what is your name", 17, out);
    if (memeq(out, "Jabberwacky. Easy for you to say.", n) == 0) {
        test_fail("t174_jw_evict_cap", "seed survived"); return 1; }
    test_pass("t174_jw_evict_cap");
    return 0;
}

# Door contract: opening frame is prefixed, 'bye' exits, is_over stays 0
# (so the corpus saves on exit), a normal line continues.
fn t175_jw_door(): i64 {
    var st = jw_new(0, DOOR_PRACTICE, JW_DEF_DAYS);
    jw_start(st);
    var buf = alloc(8192);
    var fn2 = jw_render(st, buf, 8192);
    if (fn2 <= 0)                          { test_fail("t175_jw_door", "frame len"); return 1; }
    if (memeq(buf, "JABBERWACKY: ", 13) == 0) { test_fail("t175_jw_door", "frame prefix"); return 1; }
    if (jw_feed(st, "bye", 3) != 1)        { test_fail("t175_jw_door", "bye exits"); return 1; }
    if (jw_is_over(st) != 0)               { test_fail("t175_jw_door", "is_over stays 0"); return 1; }
    if (jw_feed(st, "hello there", 11) != 0) { test_fail("t175_jw_door", "feed continues"); return 1; }
    test_pass("t175_jw_door");
    return 0;
}

# Adversarial .sav deserialization: a stored response carrying ESC / a
# C1 byte / TAB is re-sanitised on load so nothing un-printable can
# replay into a terminal. (Builds the save by hand to bypass the writer.)
fn t176_jw_load_sanitize(): i64 {
    var sb = alloc(64);
    var p = 0;
    memcpy(sb + p, "JBRW1\n", 6); p = p + 6;
    memcpy(sb + p, "1\n", 2); p = p + 2;
    memcpy(sb + p, "hello", 5); p = p + 5;
    store8(sb + p, 9);   p = p + 1;   # TAB delimiter
    store8(sb + p, 27);  p = p + 1;   # ESC      -> dropped
    store8(sb + p, 91);  p = p + 1;   # [
    store8(sb + p, 51);  p = p + 1;   # 3
    store8(sb + p, 49);  p = p + 1;   # 1
    store8(sb + p, 109); p = p + 1;   # m
    store8(sb + p, 112); p = p + 1;   # p
    store8(sb + p, 119); p = p + 1;   # w
    store8(sb + p, 110); p = p + 1;   # n
    store8(sb + p, 100); p = p + 1;   # d
    store8(sb + p, 155); p = p + 1;   # 0x9B C1  -> dropped
    store8(sb + p, 10);  p = p + 1;   # LF end record
    var st = jw_load_parse(sb, p);
    if (st == 0) { test_fail("t176_jw_load_sanitize", "load null"); return 1; }
    var out = alloc(JW_RESP_CAP);
    var n = jw_respond(st, "hello", 5, out);
    var i = 0;
    var bad = 0;
    var go = 1;
    while (go == 1) {
        if (i >= n) { go = 0; continue; }
        var c = load8(out + i) & 0xFF;
        if (c < 32)  { bad = 1; }
        if (c > 126) { bad = 1; }
        i = i + 1;
    }
    if (bad != 0)                       { test_fail("t176_jw_load_sanitize", "control survived"); return 1; }
    if (memeq(out, "[31mpwnd", 8) == 0) { test_fail("t176_jw_load_sanitize", "body"); return 1; }
    test_pass("t176_jw_load_sanitize");
    return 0;
}

# Couch re-entry: jw_start resets the conversation cursor so a stale
# pending stimulus from a prior session cannot bridge into the next.
fn t177_jw_couch_reentry(): i64 {
    var st = jw_new(0, DOOR_PRACTICE, JW_DEF_DAYS);
    jw_start(st);
    var out = alloc(JW_RESP_CAP);
    jw_respond(st, "what is the password", 20, out);    # sets JW_PREV
    if (load64(st + JW_PREVL) == 0) { test_fail("t177_jw_couch_reentry", "prev unset"); return 1; }
    jw_start(st);                                        # re-entry resets the cursor
    if (load64(st + JW_PREVL) != 0) { test_fail("t177_jw_couch_reentry", "prev not reset"); return 1; }
    var before = load64(st + JW_COUNT);
    jw_respond(st, "apples are red", 14, out);           # prev empty -> no bridge learned
    if (load64(st + JW_COUNT) != before) { test_fail("t177_jw_couch_reentry", "spurious bridge"); return 1; }
    test_pass("t177_jw_couch_reentry");
    return 0;
}

# Malformed save: a mid-stream tab-less record is skipped, not bled into
# the next, so the following good pair still loads.
fn t178_jw_load_malformed(): i64 {
    var sb = alloc(64);
    var p = 0;
    memcpy(sb + p, "JBRW1\n", 6); p = p + 6;
    memcpy(sb + p, "2\n", 2); p = p + 2;
    memcpy(sb + p, "notabhere\n", 10); p = p + 10;       # tab-less record
    memcpy(sb + p, "goodstim", 8); p = p + 8;
    store8(sb + p, 9); p = p + 1;                         # TAB
    memcpy(sb + p, "goodresp", 8); p = p + 8;
    store8(sb + p, 10); p = p + 1;                        # LF
    var st = jw_load_parse(sb, p);
    if (st == 0) { test_fail("t178_jw_load_malformed", "load null"); return 1; }
    var out = alloc(JW_RESP_CAP);
    var n = jw_respond(st, "goodstim", 8, out);
    if (memeq(out, "goodresp", n) == 0) { test_fail("t178_jw_load_malformed", "good pair lost"); return 1; }
    test_pass("t178_jw_load_malformed");
    return 0;
}

# === 1.3.4 Wager (shared casino primitive, ADR 0013) ===
#
# The pure majority — validation, the weight→outcome mapping, the
# edge-haircut resolve, the clamp-and-apply settle — is unit-tested for
# exact values. The one impure point (wager_draw_csprng) is tested only
# for DISTRIBUTION (range + termination + coverage), never an exact
# value: that is the property the casino requires and the games reject.

# A small 3-outcome table backing two arrays the test owns; weights
# [1,2,3] (total 6), gross multipliers [5,2,1]. Reused across tests.
fn wt_fixture(edge_bps): i64 {
    var w = alloc(3 * 8);
    store64(w + 0, 1); store64(w + 8, 2); store64(w + 16, 3);
    var m = alloc(3 * 8);
    store64(m + 0, 5); store64(m + 8, 2); store64(m + 16, 1);
    var tbl = alloc(WT_SIZE);
    wager_table_init(tbl, 2, 100, edge_bps, 3, w, m);
    return tbl;
}

# t179 — validation accepts a good bet and returns the right reason for
# each reject (stake0 / funds / min / max / choice low + high).
fn t179_wager_validate(): i64 {
    var tbl = wt_fixture(0);
    if (wager_validate(tbl, 50, 10, 1) != WAGER_OK)       { test_fail("t179_wager_validate", "ok"); return 1; }
    if (wager_validate(tbl, 50, 0, 1) != WAGER_E_STAKE0)  { test_fail("t179_wager_validate", "stake0"); return 1; }
    if (wager_validate(tbl, 50, (0 - 5), 1) != WAGER_E_STAKE0) { test_fail("t179_wager_validate", "neg"); return 1; }
    if (wager_validate(tbl, 5, 10, 1) != WAGER_E_FUNDS)   { test_fail("t179_wager_validate", "funds"); return 1; }
    if (wager_validate(tbl, 50, 1, 1) != WAGER_E_MIN)     { test_fail("t179_wager_validate", "min"); return 1; }
    if (wager_validate(tbl, 500, 200, 1) != WAGER_E_MAX)  { test_fail("t179_wager_validate", "max"); return 1; }
    if (wager_validate(tbl, 50, 10, (0 - 1)) != WAGER_E_CHOICE) { test_fail("t179_wager_validate", "choice<0"); return 1; }
    if (wager_validate(tbl, 50, 10, 3) != WAGER_E_CHOICE) { test_fail("t179_wager_validate", "choice>=n"); return 1; }
    # MAX <= 0 means "no upper bound": a huge stake passes the max gate
    var w = alloc(8); store64(w, 1);
    var m = alloc(8); store64(m, 1);
    var nb = alloc(WT_SIZE);
    wager_table_init(nb, 1, 0, 0, 1, w, m);
    if (wager_validate(nb, 1000000, 999999, 0) != WAGER_OK) { test_fail("t179_wager_validate", "nomax"); return 1; }
    test_pass("t179_wager_validate");
    return 0;
}

# t180 — wager_pick maps a uniform r to the right outcome across every
# weight boundary; total reports the denominator; zero-total → outcome 0.
fn t180_wager_pick(): i64 {
    var tbl = wt_fixture(0);                       # weights [1,2,3], total 6
    if (wager_weight_total(tbl) != 6)  { test_fail("t180_wager_pick", "total"); return 1; }
    if (wager_pick(tbl, 0) != 0)       { test_fail("t180_wager_pick", "r0->0"); return 1; }   # [0,1) -> 0
    if (wager_pick(tbl, 1) != 1)       { test_fail("t180_wager_pick", "r1->1"); return 1; }   # [1,3) -> 1
    if (wager_pick(tbl, 2) != 1)       { test_fail("t180_wager_pick", "r2->1"); return 1; }
    if (wager_pick(tbl, 3) != 2)       { test_fail("t180_wager_pick", "r3->2"); return 1; }   # [3,6) -> 2
    if (wager_pick(tbl, 5) != 2)       { test_fail("t180_wager_pick", "r5->2"); return 1; }
    # zero-total table: every weight 0 -> falls through to last index (0)
    var zw = alloc(8); store64(zw, 0);
    var zm = alloc(8); store64(zm, 1);
    var zt = alloc(WT_SIZE);
    wager_table_init(zt, 1, 0, 0, 1, zw, zm);
    if (wager_weight_total(zt) != 0)   { test_fail("t180_wager_pick", "ztotal"); return 1; }
    if (wager_pick(zt, 0) != 0)        { test_fail("t180_wager_pick", "zpick"); return 1; }
    # multi-outcome zero-total: falls to outcome 0 (safe slot), NOT last/jackpot
    var mzw = alloc(3 * 8); store64(mzw, 0); store64(mzw + 8, 0); store64(mzw + 16, 0);
    var mzm = alloc(3 * 8); store64(mzm, 1); store64(mzm + 8, 1); store64(mzm + 16, 9);
    var mzt = alloc(WT_SIZE);
    wager_table_init(mzt, 1, 0, 0, 3, mzw, mzm);
    if (wager_pick(mzt, 0) != 0)       { test_fail("t180_wager_pick", "multizero"); return 1; }
    # r >= total: defensive residual returns the last legal index n-1
    if (wager_pick(tbl, 6) != 2)       { test_fail("t180_wager_pick", "residual6"); return 1; }
    if (wager_pick(tbl, 100) != 2)     { test_fail("t180_wager_pick", "residual100"); return 1; }
    test_pass("t180_wager_pick");
    return 0;
}

# t181 — resolve: a loss is -stake; a win pays +stake*mult; the edge is a
# floored haircut on the gross win; an absurd (>100%) edge cannot pay
# negative.
fn t181_wager_resolve(): i64 {
    var tbl = wt_fixture(0);                       # mults [5,2,1], edge 0
    # bet 10 on outcome 0, draw 0 -> win +10*5 = +50
    if (wager_resolve(tbl, 10, 0, 0) != 50)        { test_fail("t181_wager_resolve", "win"); return 1; }
    # bet 10 on outcome 0, draw 1 -> lose -10
    if (wager_resolve(tbl, 10, 0, 1) != (0 - 10))  { test_fail("t181_wager_resolve", "loss"); return 1; }
    # bet 7 on outcome 1, draw 1 -> +7*2 = +14
    if (wager_resolve(tbl, 7, 1, 1) != 14)         { test_fail("t181_wager_resolve", "win2"); return 1; }
    # edge 250 bps (2.5%): win 10 on outcome 0 -> floor(50 * 9750/10000) = floor(48.75) = 48
    var et = wt_fixture(250);
    if (wager_resolve(et, 10, 0, 0) != 48)         { test_fail("t181_wager_resolve", "edge"); return 1; }
    # edge floors in the house favor even when it loses a fraction
    var ht = wt_fixture(1);                         # 0.01%: floor(50*9999/10000)=floor(49.995)=49
    if (wager_resolve(ht, 10, 0, 0) != 49)         { test_fail("t181_wager_resolve", "edgefloor"); return 1; }
    # absurd edge > 100% clamps kept to 0 -> a "win" pays 0, never negative
    var at = wt_fixture(20000);
    if (wager_resolve(at, 10, 0, 0) != 0)          { test_fail("t181_wager_resolve", "absurd"); return 1; }
    # negative edge is clamped high-side: the house never pays ABOVE gross
    # even on a sign-typo'd table (edge -250 -> kept capped at 10000 -> +50)
    var nt = wt_fixture(0 - 250);
    if (wager_resolve(nt, 10, 0, 0) != 50)         { test_fail("t181_wager_resolve", "negedge"); return 1; }
    # seam guards: a refused-draw sentinel nets zero (never debits); an
    # out-of-range or negative choice loses before any mults[] deref
    if (wager_resolve(tbl, 10, 0, (0 - 1)) != 0)       { test_fail("t181_wager_resolve", "sentinel"); return 1; }
    if (wager_resolve(tbl, 10, 5, 0) != (0 - 10))      { test_fail("t181_wager_resolve", "choiceoob"); return 1; }
    if (wager_resolve(tbl, 10, (0 - 1), 0) != (0 - 10)){ test_fail("t181_wager_resolve", "choiceneg"); return 1; }
    test_pass("t181_wager_resolve");
    return 0;
}

# t182 — settle applies a signed delta and clamps at zero; there is no
# path to a negative balance through a wager.
fn t182_wager_settle(): i64 {
    if (wager_settle(100, 50) != 150)       { test_fail("t182_wager_settle", "win"); return 1; }
    if (wager_settle(100, (0 - 30)) != 70)  { test_fail("t182_wager_settle", "loss"); return 1; }
    if (wager_settle(100, (0 - 100)) != 0)  { test_fail("t182_wager_settle", "zero"); return 1; }
    # defense-in-depth: an over-large loss clamps rather than going negative
    if (wager_settle(100, (0 - 250)) != 0)  { test_fail("t182_wager_settle", "clamp"); return 1; }
    # positive-overflow defense: a winning delta that wraps i64 must not zero
    # a rich balance — leave it unchanged (2^62 + 2^62 wraps to i64-min)
    var big = 4611686018427387904;
    if (wager_settle(big, big) != big)      { test_fail("t182_wager_settle", "ovf"); return 1; }
    test_pass("t182_wager_settle");
    return 0;
}

# t183 — the ONE impure path. wager_draw_csprng pulls real kernel
# entropy, so we cannot assert an exact outcome; instead we assert
# DISTRIBUTION: every draw lands in [0, nout), the call terminates, and
# over many draws each outcome is hit at least once (coverage, not
# uniformity-to-a-tolerance — that would be flaky). A negative return
# would mean a CSPRNG read failure, which we treat as a hard test fail
# (the draw must be reliable on a healthy kernel).
fn t183_wager_draw_csprng(): i64 {
    var tbl = wt_fixture(0);                        # 3 outcomes, weights [1,2,3]
    var hit = alloc(3 * 8);
    store64(hit + 0, 0); store64(hit + 8, 0); store64(hit + 16, 0);
    var i = 0;
    while (i < 3000) {
        var o = wager_draw_csprng(tbl);
        if (o < 0)  { test_fail("t183_wager_draw_csprng", "csprng read failed"); return 1; }
        if (o >= 3) { test_fail("t183_wager_draw_csprng", "out of range"); return 1; }
        store64(hit + o * 8, load64(hit + o * 8) + 1);
        i = i + 1;
    }
    if (load64(hit + 0) < 1)  { test_fail("t183_wager_draw_csprng", "outcome 0 never hit"); return 1; }
    if (load64(hit + 8) < 1)  { test_fail("t183_wager_draw_csprng", "outcome 1 never hit"); return 1; }
    if (load64(hit + 16) < 1) { test_fail("t183_wager_draw_csprng", "outcome 2 never hit"); return 1; }
    test_pass("t183_wager_draw_csprng");
    return 0;
}

# t184 — the degenerate (entropy-free) draw branches: a single-mass table
# resolves to that outcome deterministically without touching the CSPRNG,
# and an all-zero table resolves to outcome 0 (the safe slot). These are
# the only deterministic, unit-testable branches of the impure draw fn.
fn t184_wager_draw_degenerate(): i64 {
    # weights [0,1,0], total 1 -> always outcome 1, no entropy read
    var w1 = alloc(3 * 8); store64(w1, 0); store64(w1 + 8, 1); store64(w1 + 16, 0);
    var m1 = alloc(3 * 8); store64(m1, 1); store64(m1 + 8, 1); store64(m1 + 16, 1);
    var t1 = alloc(WT_SIZE);
    wager_table_init(t1, 1, 0, 0, 3, w1, m1);
    var i = 0;
    while (i < 50) {
        if (wager_draw_csprng(t1) != 1) { test_fail("t184_wager_draw_degenerate", "single mass"); return 1; }
        i = i + 1;
    }
    # weights [0,0,0], total 0 -> outcome 0 (safe slot), no entropy read
    var w0 = alloc(3 * 8); store64(w0, 0); store64(w0 + 8, 0); store64(w0 + 16, 0);
    var m0 = alloc(3 * 8); store64(m0, 1); store64(m0 + 8, 1); store64(m0 + 16, 9);
    var t0 = alloc(WT_SIZE);
    wager_table_init(t0, 1, 0, 0, 3, w0, m0);
    if (wager_draw_csprng(t0) != 0) { test_fail("t184_wager_draw_degenerate", "zero total"); return 1; }
    test_pass("t184_wager_draw_degenerate");
    return 0;
}

# t185 — door_parse_2int: the "<stake> <choice>" bet-line parser shared by
# the 1.3.5 wager integrations. First int returned, second written out;
# (0-1) for an absent field; extra trailing tokens ignored.
fn t185_door_parse_2int(): i64 {
    var snd = alloc(8);
    if (door_parse_2int("50 3", 4, snd) != 50)      { test_fail("t185_door_parse_2int", "first"); return 1; }
    if (load64(snd) != 3)                            { test_fail("t185_door_parse_2int", "second"); return 1; }
    # leading + extra spaces tolerated
    if (door_parse_2int("  12   7 x", 10, snd) != 12){ test_fail("t185_door_parse_2int", "spaces1"); return 1; }
    if (load64(snd) != 7)                            { test_fail("t185_door_parse_2int", "spaces2"); return 1; }
    # missing second field → (0-1), first still parsed
    if (door_parse_2int("99", 2, snd) != 99)         { test_fail("t185_door_parse_2int", "lonefirst"); return 1; }
    if (load64(snd) != (0 - 1))                      { test_fail("t185_door_parse_2int", "nosecond"); return 1; }
    # blank line → both absent
    if (door_parse_2int("   ", 3, snd) != (0 - 1))   { test_fail("t185_door_parse_2int", "blank1"); return 1; }
    if (load64(snd) != (0 - 1))                      { test_fail("t185_door_parse_2int", "blank2"); return 1; }
    test_pass("t185_door_parse_2int");
    return 0;
}

# t186 — PA cantina dabo wheel tuning (1.3.5). Pins the table shape + the
# edge-floored payout so a stray weight/mult/edge can't silently change
# the house take. Green/Amber/Red weights 3/2/1 (total 6), pays 1/2/5,
# edge 300 bps, min 5.
fn t186_pa_dabo_table(): i64 {
    var tbl = alloc(WT_SIZE);
    pa_dabo_table(tbl);
    if (wager_weight_total(tbl) != 6)                 { test_fail("t186_pa_dabo_table", "total"); return 1; }
    # Red (choice 2, 5x) win on stake 100 → floor(500 * 9700/10000) = 485
    if (wager_resolve(tbl, 100, 2, 2) != 485)         { test_fail("t186_pa_dabo_table", "redwin"); return 1; }
    # Amber (choice 1, 2x) win on stake 50 → floor(100 * 9700/10000) = 97
    if (wager_resolve(tbl, 50, 1, 1) != 97)           { test_fail("t186_pa_dabo_table", "amberwin"); return 1; }
    # a miss loses the stake
    if (wager_resolve(tbl, 50, 0, 2) != (0 - 50))     { test_fail("t186_pa_dabo_table", "miss"); return 1; }
    # min stake enforced (4 < 5)
    if (wager_validate(tbl, 1000, 4, 0) != WAGER_E_MIN) { test_fail("t186_pa_dabo_table", "min"); return 1; }
    test_pass("t186_pa_dabo_table");
    return 0;
}

# t187 — Smuggler back-alley bones tuning (1.3.5). Two even-money
# outcomes (total 2), edge 600 bps, min 5.
fn t187_sl_dice_table(): i64 {
    var tbl = alloc(WT_SIZE);
    sl_dice_table(tbl);
    if (wager_weight_total(tbl) != 2)                 { test_fail("t187_sl_dice_table", "total"); return 1; }
    # even-money win on stake 100 → floor(100 * 9400/10000) = 94
    if (wager_resolve(tbl, 100, 0, 0) != 94)          { test_fail("t187_sl_dice_table", "win"); return 1; }
    if (wager_resolve(tbl, 100, 1, 0) != (0 - 100))   { test_fail("t187_sl_dice_table", "loss"); return 1; }
    if (wager_validate(tbl, 1000, 4, 1) != WAGER_E_MIN) { test_fail("t187_sl_dice_table", "min"); return 1; }
    test_pass("t187_sl_dice_table");
    return 0;
}

# t188 — QUEST tavern card table tuning (1.3.5). Four equal suits
# (total 4), 3:1 payout, edge 400 bps, min 5.
fn t188_qu_cards_table(): i64 {
    var tbl = alloc(WT_SIZE);
    qu_cards_table(tbl);
    if (wager_weight_total(tbl) != 4)                 { test_fail("t188_qu_cards_table", "total"); return 1; }
    # suit hit (3x) on stake 100 → floor(300 * 9600/10000) = 288
    if (wager_resolve(tbl, 100, 0, 0) != 288)         { test_fail("t188_qu_cards_table", "win"); return 1; }
    if (wager_resolve(tbl, 100, 0, 3) != (0 - 100))   { test_fail("t188_qu_cards_table", "miss"); return 1; }
    if (wager_validate(tbl, 1000, 4, 2) != WAGER_E_MIN) { test_fail("t188_qu_cards_table", "min"); return 1; }
    test_pass("t188_qu_cards_table");
    return 0;
}

# === 1.3.6 Olympiad (the competition primitive + owner economy) ===

# t189 — chariot form: sum of stats scaled by condition, floored at 1 for
# a live team, 0 for an empty slot.
fn t189_ol_chariot_form(): i64 {
    var c = alloc(CMP_SIZE);
    store64(c + CMP_SPEED, 8); store64(c + CMP_STAMINA, 8);
    store64(c + CMP_HANDLE, 8); store64(c + CMP_NERVE, 8);
    store64(c + CMP_COND, 100);
    if (ol_chariot_form(c) != 32)        { test_fail("t189_ol_chariot_form", "full"); return 1; }
    store64(c + CMP_COND, 50);
    if (ol_chariot_form(c) != 16)        { test_fail("t189_ol_chariot_form", "half"); return 1; }
    store64(c + CMP_COND, 0);            # spent but alive → floored to 1
    if (ol_chariot_form(c) != 1)         { test_fail("t189_ol_chariot_form", "spent"); return 1; }
    store64(c + CMP_SPEED, 0); store64(c + CMP_STAMINA, 0);
    store64(c + CMP_HANDLE, 0); store64(c + CMP_NERVE, 0);
    store64(c + CMP_COND, 100);
    if (ol_chariot_form(c) != 0)         { test_fail("t189_ol_chariot_form", "empty"); return 1; }
    test_pass("t189_ol_chariot_form");
    return 0;
}

# t190 — ol_pick_weighted: the pure weight→entrant seam, with the taken
# mask for sequential draws, across every boundary.
fn t190_ol_pick_weighted(): i64 {
    var f = alloc(3 * 8); store64(f, 1); store64(f + 8, 2); store64(f + 16, 3);  # total 6
    if (ol_field_total(f, 3, 0) != 6)        { test_fail("t190_ol_pick_weighted", "total"); return 1; }
    if (ol_pick_weighted(f, 3, 0, 0) != 0)   { test_fail("t190_ol_pick_weighted", "r0"); return 1; }
    if (ol_pick_weighted(f, 3, 0, 1) != 1)   { test_fail("t190_ol_pick_weighted", "r1"); return 1; }
    if (ol_pick_weighted(f, 3, 0, 3) != 2)   { test_fail("t190_ol_pick_weighted", "r3"); return 1; }
    if (ol_pick_weighted(f, 3, 0, 5) != 2)   { test_fail("t190_ol_pick_weighted", "r5"); return 1; }
    # residual r >= total → last entrant
    if (ol_pick_weighted(f, 3, 0, 99) != 2)  { test_fail("t190_ol_pick_weighted", "residual"); return 1; }
    # taken mask: entrant 0 removed → remaining forms 2,3 (total 5)
    var tk = alloc(3); store8(tk, 1); store8(tk + 1, 0); store8(tk + 2, 0);
    if (ol_field_total(f, 3, tk) != 5)       { test_fail("t190_ol_pick_weighted", "tktotal"); return 1; }
    if (ol_pick_weighted(f, 3, tk, 0) != 1)  { test_fail("t190_ol_pick_weighted", "tk r0"); return 1; }
    if (ol_pick_weighted(f, 3, tk, 2) != 2)  { test_fail("t190_ol_pick_weighted", "tk r2"); return 1; }
    test_pass("t190_ol_pick_weighted");
    return 0;
}

# t191 — train/rest economy: gains, diminishing returns past 2/3 cap, the
# hard cap, condition cost, and rest restoring + clamping.
fn t191_ol_train_rest(): i64 {
    var c = alloc(CMP_SIZE);
    store64(c + CMP_SPEED, 8); store64(c + CMP_COND, 100);
    if (ol_train(c, CMP_SPEED) != 2)         { test_fail("t191_ol_train_rest", "gain"); return 1; }
    if (load64(c + CMP_SPEED) != 10)         { test_fail("t191_ol_train_rest", "raised"); return 1; }
    if (load64(c + CMP_COND) != 88)          { test_fail("t191_ol_train_rest", "fatigue"); return 1; }
    store64(c + CMP_SPEED, 20);              # past 2/3 of cap (16) → diminished gain 1
    if (ol_train(c, CMP_SPEED) != 1)         { test_fail("t191_ol_train_rest", "diminish"); return 1; }
    store64(c + CMP_SPEED, OL_STAT_CAP);     # capped → no gain
    if (ol_train(c, CMP_SPEED) != 0)         { test_fail("t191_ol_train_rest", "capped"); return 1; }
    store64(c + CMP_COND, 40);               # rest restores +30
    ol_rest(c);
    if (load64(c + CMP_COND) != 70)          { test_fail("t191_ol_train_rest", "rest"); return 1; }
    store64(c + CMP_COND, 90);               # rest clamps at 100
    ol_rest(c);
    if (load64(c + CMP_COND) != 100)         { test_fail("t191_ol_train_rest", "restclamp"); return 1; }
    test_pass("t191_ol_train_rest");
    return 0;
}

# t192 — the compete() draw (the one impure point). Can't pin a CSPRNG
# outcome, so assert DISTRIBUTION + structure: winners stay in range, a
# heavy favourite wins most, and the finishing order is a valid permutation.
fn t192_ol_compete(): i64 {
    var f = alloc(3 * 8); store64(f, 10); store64(f + 8, 1); store64(f + 16, 1);  # 0 is the heavy favourite
    var winfav = 0;
    var i = 0;
    while (i < 600) {
        var w = ol_compete_winner(f, 3);
        if (w < 0)  { test_fail("t192_ol_compete", "csprng fault"); return 1; }
        if (w >= 3) { test_fail("t192_ol_compete", "range"); return 1; }
        if (w == 0) { winfav = winfav + 1; }
        i = i + 1;
    }
    # favourite (~10/12) should clear a simple majority over 600 draws
    if (winfav < 300) { test_fail("t192_ol_compete", "favourite underperformed"); return 1; }
    # finishing order is a permutation of {0,1,2}
    var order = alloc(3 * 8);
    if (ol_compete_order(f, 3, order) != 0) { test_fail("t192_ol_compete", "order fault"); return 1; }
    var seen = alloc(3); store8(seen, 0); store8(seen + 1, 0); store8(seen + 2, 0);
    var p = 0;
    while (p < 3) {
        var e = load64(order + p * 8);
        if (e < 0)  { test_fail("t192_ol_compete", "order range lo"); return 1; }
        if (e >= 3) { test_fail("t192_ol_compete", "order range hi"); return 1; }
        if ((load8(seen + e) & 0xFF) != 0) { test_fail("t192_ol_compete", "order dup"); return 1; }
        store8(seen + e, 1);
        p = p + 1;
    }
    test_pass("t192_ol_compete");
    return 0;
}

# t193 — fair odds ×100 straight from the forms (the same weights that
# resolve the race price the book), plus the founding-owner construction.
fn t193_ol_odds_and_new(): i64 {
    var f = alloc(3 * 8); store64(f, 1); store64(f + 8, 1); store64(f + 16, 2);  # total 4
    # entrant 0: (4-1)*100/1 = 300 (3:1); entrant 2: (4-2)*100/2 = 100 (evens)
    if (ol_fair_odds_x100(f, 3, 0) != 300)   { test_fail("t193_ol_odds_and_new", "longshot"); return 1; }
    if (ol_fair_odds_x100(f, 3, 2) != 100)   { test_fail("t193_ol_odds_and_new", "evens"); return 1; }
    var z = alloc(8); store64(z, 0);                                              # can't-win
    if (ol_fair_odds_x100(z, 1, 0) != 0)     { test_fail("t193_ol_odds_and_new", "cantwin"); return 1; }
    # founding owner: one Blue chariot, starting purse + ration
    var st = ol_new(123, DOOR_PRACTICE);
    if (load64(st + OL_NCOMP) != 1)          { test_fail("t193_ol_odds_and_new", "ncomp"); return 1; }
    if (load64(st + OL_MONEY) != OL_START_MONEY) { test_fail("t193_ol_odds_and_new", "money"); return 1; }
    if (load64(st + OL_ACTIONS) != OL_DAY_ACTIONS) { test_fail("t193_ol_odds_and_new", "actions"); return 1; }
    var c0 = ol_comp(st, 0);
    if (load64(c0 + CMP_TYPE) != EV_CHARIOT) { test_fail("t193_ol_odds_and_new", "type"); return 1; }
    if (load64(c0 + CMP_SPEED) != OL_STAT_START) { test_fail("t193_ol_odds_and_new", "stat"); return 1; }
    if (ol_is_over(st) != 0)                 { test_fail("t193_ol_odds_and_new", "over"); return 1; }
    test_pass("t193_ol_odds_and_new");
    return 0;
}

# t195 — wager_payout: the fractional (pari-mutuel) profit helper. Odds as
# num:den profit, edge shaved in the house's favour, floored; defensive 0s.
fn t195_wager_payout(): i64 {
    if (wager_payout(100, 3, 1, 0) != 300)    { test_fail("t195_wager_payout", "3:1"); return 1; }
    if (wager_payout(100, 1, 1, 0) != 100)    { test_fail("t195_wager_payout", "evens"); return 1; }
    if (wager_payout(100, 4, 5, 0) != 80)     { test_fail("t195_wager_payout", "favourite"); return 1; }   # pays < 1x
    if (wager_payout(100, 2, 1, 500) != 190)  { test_fail("t195_wager_payout", "edge"); return 1; }         # 200 fair, 5% vig
    if (wager_payout(0, 3, 1, 0) != 0)        { test_fail("t195_wager_payout", "stake0"); return 1; }
    if (wager_payout(100, 3, 0, 0) != 0)      { test_fail("t195_wager_payout", "den0"); return 1; }
    if (wager_payout(100, 0, 1, 0) != 0)      { test_fail("t195_wager_payout", "num0"); return 1; }
    test_pass("t195_wager_payout");
    return 0;
}

# t194 — chariot field construction: lane 0 is a copy of your team, the
# field is the right size, every entrant has positive form, and rivals are
# non-Blue factions with in-range stats (seeded generation).
fn t194_ol_field(): i64 {
    var st = ol_new(777, DOOR_PRACTICE);
    var mine = ol_comp(st, 0);
    store64(mine + CMP_SPEED, 15);                 # distinctive, to spot the lane-0 copy
    var n = ol_build_chariot_field(st);
    if (n != OL_RACE_FIELD)                  { test_fail("t194_ol_field", "size"); return 1; }
    if (load64(st + OL_FIELDN) != OL_RACE_FIELD) { test_fail("t194_ol_field", "fieldn"); return 1; }
    var fc = load64(st + OL_FCOMP);
    if (load64(fc + CMP_SPEED) != 15)        { test_fail("t194_ol_field", "lane0 copy"); return 1; }
    var forms = load64(st + OL_FIELD);
    var i = 0;
    while (i < n) {
        if (load64(forms + i * 8) <= 0)      { test_fail("t194_ol_field", "form>0"); return 1; }
        i = i + 1;
    }
    var j = 1;
    while (j < n) {
        var c = fc + j * CMP_SIZE;
        var fac = load64(c + CMP_FACTION);
        if (fac < 1) { test_fail("t194_ol_field", "faction lo"); return 1; }   # not Blue (yours)
        if (fac > 3) { test_fail("t194_ol_field", "faction hi"); return 1; }
        var sp = load64(c + CMP_SPEED);
        if (sp < 1)           { test_fail("t194_ol_field", "stat lo"); return 1; }
        if (sp > OL_STAT_CAP) { test_fail("t194_ol_field", "stat hi"); return 1; }
        j = j + 1;
    }
    test_pass("t194_ol_field");
    return 0;
}

# t196 — the season ladder: a win climbs a tier (purse scales), and winning
# the final meet takes the crown and ends the campaign. Made deterministic
# by handing only your team (lane 0) any form, so you always win.
fn t196_ol_ladder(): i64 {
    var st = ol_new(5, DOOR_PRACTICE);
    store64(st + OL_FIELDN, 4);
    var f = load64(st + OL_FIELD);
    store64(f + 0, 10); store64(f + 8, 0); store64(f + 16, 0); store64(f + 24, 0);
    var money0 = load64(st + OL_MONEY);
    ol_run_race(st);
    if (load64(st + OL_PLACE) != 1)              { test_fail("t196_ol_ladder", "won"); return 1; }
    if (load64(st + OL_TIER) != 1)               { test_fail("t196_ol_ladder", "advance"); return 1; }
    if (load64(st + OL_PURSE) != OL_PURSE_WIN)   { test_fail("t196_ol_ladder", "purse t0"); return 1; }
    if (load64(st + OL_MONEY) != money0 + OL_PURSE_WIN) { test_fail("t196_ol_ladder", "paid"); return 1; }
    if (ol_is_over(st) != 0)                     { test_fail("t196_ol_ladder", "not over yet"); return 1; }
    # at the final meet, a win takes the crown and ends it
    var st2 = ol_new(5, DOOR_PRACTICE);
    store64(st2 + OL_TIER, OL_MAX_TIER - 1);
    store64(st2 + OL_FIELDN, 4);
    var f2 = load64(st2 + OL_FIELD);
    store64(f2 + 0, 10); store64(f2 + 8, 0); store64(f2 + 16, 0); store64(f2 + 24, 0);
    ol_run_race(st2);
    if (ol_is_over(st2) != 1)                    { test_fail("t196_ol_ladder", "crown over"); return 1; }
    if (load64(st2 + OL_CROWNS) != 1)            { test_fail("t196_ol_ladder", "crown count"); return 1; }
    if (load64(st2 + OL_PURSE) != OL_PURSE_WIN * OL_MAX_TIER) { test_fail("t196_ol_ladder", "purse top"); return 1; }
    test_pass("t196_ol_ladder");
    return 0;
}

# t197 — the solo save round-trips the owner + stable, and a bad header is
# rejected. (Runtime-only fields aren't serialized; the stable is.)
fn t197_ol_saveload(): i64 {
    var st = ol_new(42, DOOR_SOLO);
    store64(st + OL_TIER, 5);
    store64(st + OL_MONEY, 777);
    store64(st + OL_CROWNS, 1);
    store64(st + OL_DAY, 9);
    var c = ol_comp(st, 0);
    store64(c + CMP_SPEED, 18);
    store64(c + CMP_COND, 63);
    var buf = alloc(4096);
    var n = ol_save_format(st, buf, 4096);
    var st2 = ol_load_parse(buf, n);
    if (st2 == 0)                          { test_fail("t197_ol_saveload", "null"); return 1; }
    if (load64(st2 + OL_SEED) != 42)       { test_fail("t197_ol_saveload", "seed"); return 1; }
    if (load64(st2 + OL_TIER) != 5)        { test_fail("t197_ol_saveload", "tier"); return 1; }
    if (load64(st2 + OL_MONEY) != 777)     { test_fail("t197_ol_saveload", "money"); return 1; }
    if (load64(st2 + OL_CROWNS) != 1)      { test_fail("t197_ol_saveload", "crowns"); return 1; }
    if (load64(st2 + OL_DAY) != 9)         { test_fail("t197_ol_saveload", "day"); return 1; }
    if (load64(st2 + OL_NCOMP) != 1)       { test_fail("t197_ol_saveload", "ncomp"); return 1; }
    var c2 = ol_comp(st2, 0);
    if (load64(c2 + CMP_SPEED) != 18)      { test_fail("t197_ol_saveload", "stat"); return 1; }
    if (load64(c2 + CMP_COND) != 63)       { test_fail("t197_ol_saveload", "cond"); return 1; }
    if (ol_load_parse("NOPE1\n", 6) != 0)  { test_fail("t197_ol_saveload", "bad header"); return 1; }
    test_pass("t197_ol_saveload");
    return 0;
}

