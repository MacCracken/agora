# === M6-C login-flow pure helpers ===

# T57: nonce_to_hex encodes 32 raw bytes into 64 lowercase hex chars + NUL.
# Input: bytes 0x00..0x1F → expected first chars "000102...1f".
fn t57_nonce_to_hex_known(): i64 {
    var raw[32];
    var i = 0;
    while (i < 32) { store8((&raw) + i, i); i = i + 1; }
    var hex[65];
    nonce_to_hex(&raw, &hex);
    var expected = "000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f";
    if (memeq(&hex, expected, 64) == 0) {
        test_fail("t57_nonce_to_hex_known", "hex bytes mismatch");
        return 1;
    }
    if ((load8((&hex) + 64) & 0xFF) != 0) {
        test_fail("t57_nonce_to_hex_known", "missing NUL terminator");
        return 1;
    }
    test_pass("t57_nonce_to_hex_known");
    return 0;
}

# T58: format_challenge_msg writes "agora-login:" + nonce_hex (76 bytes).
