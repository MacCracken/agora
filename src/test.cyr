# T40: board_name_valid accepts the canonical alphabet.
fn t40_board_name_valid_accepts(): i64 {
    if (board_name_valid("art")               != 1) { test_fail("t40", "art");                return 1; }
    if (board_name_valid("a")                 != 1) { test_fail("t40", "a");                  return 1; }
    if (board_name_valid("9")                 != 1) { test_fail("t40", "9");                  return 1; }
    if (board_name_valid("hello-world_2")     != 1) { test_fail("t40", "hello-world_2");      return 1; }
    if (board_name_valid("a1b2c3d4e5f6g7h8")  != 1) { test_fail("t40", "16-char");            return 1; }
    test_pass("t40_board_name_valid_accepts");
    return 0;
}

# T41: board_name_valid rejects what ADR 0004 says it should.
fn t41_board_name_valid_rejects(): i64 {
    if (board_name_valid(0)                   != 0) { test_fail("t41", "NUL pointer");        return 1; }
    if (board_name_valid("")                  != 0) { test_fail("t41", "empty string");       return 1; }
    if (board_name_valid("main")              != 0) { test_fail("t41", "reserved name main"); return 1; }
    if (board_name_valid("Art")               != 0) { test_fail("t41", "uppercase A");        return 1; }
    if (board_name_valid("a.b")               != 0) { test_fail("t41", "dot in middle");      return 1; }
    if (board_name_valid("a/b")               != 0) { test_fail("t41", "slash in middle");    return 1; }
    if (board_name_valid("-foo")              != 0) { test_fail("t41", "leading dash");       return 1; }
    if (board_name_valid("_foo")              != 0) { test_fail("t41", "leading underscore"); return 1; }
    if (board_name_valid(".lock")             != 0) { test_fail("t41", "leading dot");        return 1; }
    if (board_name_valid("..")                != 0) { test_fail("t41", "dotdot");             return 1; }
    if (board_name_valid("a b")               != 0) { test_fail("t41", "space");              return 1; }
    if (board_name_valid("aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa") != 0) { test_fail("t41", "33 char"); return 1; }
    test_pass("t41_board_name_valid_rejects");
    return 0;
}

