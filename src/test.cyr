    }
    if (memeq(buf, expected, strlen(expected)) == 0) {
        test_fail("t42_board_path_main_is_flat", "bytes");
        return 1;
    }
    test_pass("t42_board_path_main_is_flat");
    return 0;
}

# T43: board_path("/store", "art", ...) appends "/art".
fn t43_board_path_named(): i64 {
    var buf = alloc(PATH_MAX_BYTES);
    var len = board_path("/var/agora", "art", buf);
    var expected = "/var/agora/art";
    if (len != strlen(expected)) {
