}

# T49: post_format includes Reply-To when set, omits when not. Round-
# trip via post_reply_to. 0.9.0 ABI: PostHeaders struct (ADR 0008).
fn t49_format_with_reply_to_header(): i64 {
    var fbuf = alloc(POST_MAX_BYTES + 1024);
    var ph = post_headers_new();
    post_headers_set_subject(ph, "test");
    post_headers_set_reply_to(ph, 42);
    var flen = post_format(ph, "the body", 8, fbuf, POST_MAX_BYTES + 1024);
    if (flen < 0) {
        test_fail("t49_format_with_reply_to_header", "format returned -1");
        return 1;
    }
    var pid = post_reply_to(fbuf, flen);
    if (pid != 42) {
        test_fail("t49_format_with_reply_to_header", "Reply-To round-trip failed");
        return 1;
    }
    # Re-test without reply_to → no header → 0
    var ph2 = post_headers_new();
    post_headers_set_subject(ph2, "test");
    var flen2 = post_format(ph2, "the body", 8, fbuf, POST_MAX_BYTES + 1024);
    if (flen2 < 0) {
        test_fail("t49_format_with_reply_to_header", "format-no-reply returned -1");
        return 1;
    }
    var pid2 = post_reply_to(fbuf, flen2);
    if (pid2 != 0) {
        test_fail("t49_format_with_reply_to_header", "no-reply expected 0");
        return 1;
    }
    test_pass("t49_format_with_reply_to_header");
    return 0;
}

# T15: tx_buf drain / consume cycle resets length to 0.
fn t15_tx_consume_resets(): i64 {
    var ts = telnet_state_new();
    telnet_feed(ts, IAC);
    telnet_feed(ts, WILL);
    telnet_feed(ts, OPT_ECHO);
    if (telnet_tx_len(ts) != 3) {
        test_fail("t15_tx_consume_resets", "expected tx_len 3 before consume");
        return 1;
    }
    telnet_tx_consume(ts);
    if (telnet_tx_len(ts) != 0) {
        test_fail("t15_tx_consume_resets", "tx_len should be 0 after consume");
        return 1;
    }
    test_pass("t15_tx_consume_resets");
    return 0;
}

# === M6-B account primitive tests ===

# T50: compute_fingerprint of an all-zero 32-byte pubkey matches the
# known sha256(zeros32) prefix. SHA-256 of 32 zero bytes is
# 66687aadf862bd776c8fc18b8e9f8e20089714856ee233b3902a591d0d5f2925;
# first 8 bytes hex = "66687aadf862bd77".
fn t50_compute_fingerprint_known_pk(): i64 {
    var pk[32];
    memset(&pk, 0, 32);
    var fp[17];
    compute_fingerprint(&pk, &fp);
    var expected = "66687aadf862bd77";
    var exp_len = strlen(expected);
    if (memeq(&fp, expected, exp_len) == 0) {
        test_fail("t50_compute_fingerprint_known_pk", "fp bytes mismatch");
        return 1;
    }
    if ((load8((&fp) + ACCOUNT_FP_HEX_BYTES) & 0xFF) != 0) {
        test_fail("t50_compute_fingerprint_known_pk", "missing NUL terminator");
        return 1;
    }
    test_pass("t50_compute_fingerprint_known_pk");
    return 0;
}

# T51: compute_fingerprint is deterministic — same pk in twice yields
# the same 16-hex fp. Catches accidental non-determinism (e.g. if
# someone wires in a timestamp / nonce / heap-pointer dependency).
fn t51_compute_fingerprint_deterministic(): i64 {
    var pk[32];
    var i = 0;
    while (i < 32) { store8((&pk) + i, i + 1); i = i + 1; }
    var fp1[17];
    var fp2[17];
    compute_fingerprint(&pk, &fp1);
    compute_fingerprint(&pk, &fp2);
    if (memeq(&fp1, &fp2, ACCOUNT_FP_HEX_BYTES) == 0) {
        test_fail("t51_compute_fingerprint_deterministic", "two calls differ");
        return 1;
    }
    test_pass("t51_compute_fingerprint_deterministic");
    return 0;
}

# T52: handle_valid accepts the canonical alphabet — lowercase letters,
# digits, dashes, underscores. First char letter or digit.
fn t52_handle_valid_accepts(): i64 {
    if (handle_valid("alice")           != 1) { test_fail("t52", "alice");        return 1; }
    if (handle_valid("bob")             != 1) { test_fail("t52", "bob");          return 1; }
    if (handle_valid("op_1")            != 1) { test_fail("t52", "op_1");         return 1; }
    if (handle_valid("the-mole")        != 1) { test_fail("t52", "the-mole");     return 1; }
    if (handle_valid("a")               != 1) { test_fail("t52", "single char");  return 1; }
    if (handle_valid("9")               != 1) { test_fail("t52", "single digit"); return 1; }
    if (handle_valid("aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa") != 1) { test_fail("t52", "32 char"); return 1; }
    test_pass("t52_handle_valid_accepts");
    return 0;
}

# T53: handle_valid rejects what ADR 0006 says it should.
fn t53_handle_valid_rejects(): i64 {
    if (handle_valid(0)                  != 0) { test_fail("t53", "NUL pointer");       return 1; }
    if (handle_valid("")                 != 0) { test_fail("t53", "empty");             return 1; }
    if (handle_valid("anonymous")        != 0) { test_fail("t53", "reserved anon");     return 1; }
    if (handle_valid("system")           != 0) { test_fail("t53", "reserved system");   return 1; }
    if (handle_valid("admin")            != 0) { test_fail("t53", "reserved admin");    return 1; }
    if (handle_valid("Alice")            != 0) { test_fail("t53", "uppercase A");       return 1; }
    if (handle_valid("a.b")              != 0) { test_fail("t53", "dot");               return 1; }
    if (handle_valid("a/b")              != 0) { test_fail("t53", "slash");             return 1; }
    if (handle_valid("-foo")             != 0) { test_fail("t53", "leading dash");      return 1; }
    if (handle_valid("_foo")             != 0) { test_fail("t53", "leading underscore");return 1; }
    if (handle_valid("a b")              != 0) { test_fail("t53", "space");             return 1; }
    if (handle_valid("aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa") != 0) { test_fail("t53", "33 char"); return 1; }
    test_pass("t53_handle_valid_rejects");
    return 0;
}

