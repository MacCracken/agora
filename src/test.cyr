# T44: subject_reply_prefix prepends "Re: " when not already present.
fn t44_subject_reply_prefix_adds_re(): i64 {
    var out = alloc(SUBJECT_MAX_BYTES + 8);
    var n = subject_reply_prefix("Hello world", 11, out, SUBJECT_MAX_BYTES + 8);
    var expected = "Re: Hello world";
    var elen = strlen(expected);
    if (n != elen) {
        test_fail("t44_subject_reply_prefix_adds_re", "wrong length");
        return 1;
    }
    if (memeq(out, expected, elen) == 0) {
        test_fail("t44_subject_reply_prefix_adds_re", "byte mismatch");
        return 1;
    }
    test_pass("t44_subject_reply_prefix_adds_re");
    return 0;
}

# T45: subject_reply_prefix does NOT double-prefix when "Re: " is
# already present (RFC 5322 § 3.6.5).
fn t45_subject_reply_prefix_no_double_re(): i64 {
    var out = alloc(SUBJECT_MAX_BYTES + 8);
    var input = "Re: Hello world";
    var n = subject_reply_prefix(input, strlen(input), out, SUBJECT_MAX_BYTES + 8);
    if (n != strlen(input)) {
        test_fail("t45_subject_reply_prefix_no_double_re", "length should match input");
        return 1;
    }
    if (memeq(out, input, strlen(input)) == 0) {
        test_fail("t45_subject_reply_prefix_no_double_re", "byte mismatch");
        return 1;
    }
    test_pass("t45_subject_reply_prefix_no_double_re");
    return 0;
}

# T46: subject_reply_prefix Re: check is case-insensitive on the
# letters (matches mail-client behavior).
fn t46_subject_reply_prefix_case_insensitive(): i64 {
    var out = alloc(SUBJECT_MAX_BYTES + 8);
    # Lowercase "re: " — should NOT be doubled
    var n = subject_reply_prefix("re: foo", 7, out, SUBJECT_MAX_BYTES + 8);
    if (n != 7) {
        test_fail("t46_subject_reply_prefix_case_insensitive", "lowercase re: should not double");
        return 1;
    }
    # Mixed case "rE: " — also should not double
    var n2 = subject_reply_prefix("rE: bar", 7, out, SUBJECT_MAX_BYTES + 8);
    if (n2 != 7) {
        test_fail("t46_subject_reply_prefix_case_insensitive", "mixed-case rE: should not double");
        return 1;
    }
    test_pass("t46_subject_reply_prefix_case_insensitive");
    return 0;
}

