# test.cyr — unit tests for the telnet protocol module.
#
# Pure-parser tests — no socket, no kernel. Every test feeds a
# byte sequence into a TelnetState, then asserts on the emitted
# events + queued IAC responses + accumulated subneg payload.
#
# Run with: cyrius test src/test.cyr
# CI gate: exit 0 on full pass; non-zero on first failure.

include "src/telnet.cyr"
include "src/board.cyr"
include "src/account.cyr"

var test_count = 0;
var fail_count = 0;

fn test_pass(name): i64 {
    test_count = test_count + 1;
    syscall(1, 1, "PASS: ", 6);
    syscall(1, 1, name, strlen(name));
    syscall(1, 1, "\n", 1);
    return 0;
}

fn test_fail(name, why): i64 {
    test_count = test_count + 1;
    fail_count = fail_count + 1;
    syscall(1, 2, "FAIL: ", 6);
    syscall(1, 2, name, strlen(name));
    syscall(1, 2, " — ", 4);
    syscall(1, 2, why, strlen(why));
    syscall(1, 2, "\n", 1);
    return 0;
}

# Helper: feed a byte and assert the event matches expected.
fn expect_event(ts, b, want_event, name): i64 {
    var got = telnet_feed(ts, b);
    if (got == want_event) { return 0; }
    test_fail(name, "wrong event from telnet_feed");
    return 1;
}

# === Tests ===

# T1: plain data bytes pass through as EV_DATA with byte value preserved.
fn t01_plain_data(): i64 {
    var ts = telnet_state_new();
    var ev = telnet_feed(ts, 0x41);
    if (ev != EV_DATA) {
        test_fail("t01_plain_data", "expected EV_DATA");
        return 1;
    }
    var b = telnet_data_byte(ts);
    if (b != 0x41) {
        test_fail("t01_plain_data", "wrong data byte");
        return 1;
    }
    test_pass("t01_plain_data");
    return 0;
}

# T2: IAC IAC emits a literal 0xFF data byte (RFC 854 § Network Virtual Terminal).
fn t02_iac_iac_literal(): i64 {
    var ts = telnet_state_new();
    var ev1 = telnet_feed(ts, IAC);
    if (ev1 != EV_NONE) {
        test_fail("t02_iac_iac_literal", "first IAC should be EV_NONE");
        return 1;
    }
    var ev2 = telnet_feed(ts, IAC);
    if (ev2 != EV_DATA) {
        test_fail("t02_iac_iac_literal", "IAC IAC should emit data");
        return 1;
    }
    var b = telnet_data_byte(ts);
    if (b != 0xFF) {
        test_fail("t02_iac_iac_literal", "data byte should be 0xFF");
        return 1;
    }
    test_pass("t02_iac_iac_literal");
    return 0;
}

# T3: IAC WILL ECHO from client triggers IAC DONT ECHO response —
# Q-method: him_ECHO=NO is our preference (we want US to echo, not him).
fn t03_will_echo_refused(): i64 {
    var ts = telnet_state_new();
    telnet_feed(ts, IAC);
    telnet_feed(ts, WILL);
    telnet_feed(ts, OPT_ECHO);

    var len = telnet_tx_len(ts);
    if (len != 3) {
        test_fail("t03_will_echo_refused", "tx_len should be 3");
        return 1;
    }
    var buf = telnet_tx_buf(ts);
    var b0 = load8(buf) & 0xFF;
    var b1 = load8(buf + 1) & 0xFF;
    var b2 = load8(buf + 2) & 0xFF;
    if (b0 != IAC) {
        test_fail("t03_will_echo_refused", "byte 0 should be IAC");
        return 1;
    }
    if (b1 != DONT) {
        test_fail("t03_will_echo_refused", "byte 1 should be DONT");
        return 1;
    }
    if (b2 != OPT_ECHO) {
        test_fail("t03_will_echo_refused", "byte 2 should be OPT_ECHO");
        return 1;
    }
    if (opt_him(ts, OPT_ECHO) != Q_NO) {
        test_fail("t03_will_echo_refused", "him-ECHO state should stay Q_NO");
        return 1;
    }
    test_pass("t03_will_echo_refused");
    return 0;
}

# T4: IAC DO SGA from client triggers IAC WILL SGA — Q-method:
# us_SGA=YES is our preference (modern char-at-a-time mode), so we
# agree on the spot. Replaces the v0.1 naive-refuse-everything shape.
fn t04_do_sga_agreed(): i64 {
    var ts = telnet_state_new();
    telnet_feed(ts, IAC);
    telnet_feed(ts, DO);
    telnet_feed(ts, OPT_SUPPRESS_GO_AHEAD);

    var len = telnet_tx_len(ts);
    if (len != 3) {
        test_fail("t04_do_sga_agreed", "tx_len should be 3");
        return 1;
    }
    var buf = telnet_tx_buf(ts);
    var b1 = load8(buf + 1) & 0xFF;
    if (b1 != WILL) {
        test_fail("t04_do_sga_agreed", "verb should be WILL for tracked us-pref");
        return 1;
    }
    if (opt_us(ts, OPT_SUPPRESS_GO_AHEAD) != Q_YES) {
        test_fail("t04_do_sga_agreed", "us-SGA state should be Q_YES after agreement");
        return 1;
    }
    test_pass("t04_do_sga_agreed");
    return 0;
}

# T5: IAC NOP is a single-byte command — consumed silently, no data, no response.
fn t05_nop_consumed(): i64 {
    var ts = telnet_state_new();
    telnet_feed(ts, IAC);
    var ev = telnet_feed(ts, NOP);
    if (ev != EV_NONE) {
        test_fail("t05_nop_consumed", "NOP should be EV_NONE");
        return 1;
    }
    if (telnet_tx_len(ts) != 0) {
        test_fail("t05_nop_consumed", "NOP should not queue a response");
        return 1;
    }
    test_pass("t05_nop_consumed");
    return 0;
}

# T6: subnegotiation collects payload between IAC SB ... IAC SE, returns EV_SB.
fn t06_subneg_basic(): i64 {
    var ts = telnet_state_new();
    # IAC SB TERMINAL_TYPE 0x00 'V' 'T' '1' '0' '0' IAC SE
    # (canonical TERMINAL_TYPE IS response shape)
    telnet_feed(ts, IAC);
    telnet_feed(ts, SB);
    telnet_feed(ts, OPT_TERMINAL_TYPE);
    telnet_feed(ts, 0x00);
    telnet_feed(ts, 0x56);  # 'V'
    telnet_feed(ts, 0x54);  # 'T'
    telnet_feed(ts, 0x31);  # '1'
    telnet_feed(ts, 0x30);  # '0'
    telnet_feed(ts, 0x30);  # '0'
    telnet_feed(ts, IAC);
    var ev = telnet_feed(ts, SE);
    if (ev != EV_SB) {
        test_fail("t06_subneg_basic", "expected EV_SB at terminator");
        return 1;
    }
    var len = telnet_sb_len(ts);
    if (len != 7) {
        test_fail("t06_subneg_basic", "sb_len should be 7");
        return 1;
    }
    var buf = telnet_sb_buf(ts);
    if ((load8(buf) & 0xFF) != OPT_TERMINAL_TYPE) {
        test_fail("t06_subneg_basic", "first sb byte should be option code");
        return 1;
    }
    test_pass("t06_subneg_basic");
    return 0;
}

# T7: escaped IAC inside subneg (IAC IAC) is accumulated as literal 0xFF.
fn t07_subneg_escaped_iac(): i64 {
    var ts = telnet_state_new();
    telnet_feed(ts, IAC);
    telnet_feed(ts, SB);
    telnet_feed(ts, OPT_STATUS);
    telnet_feed(ts, 0x42);  # 'B'
    telnet_feed(ts, IAC);
    telnet_feed(ts, IAC);   # escaped → literal 0xFF in sb_buf
    telnet_feed(ts, 0x43);  # 'C'
    telnet_feed(ts, IAC);
    var ev = telnet_feed(ts, SE);
    if (ev != EV_SB) {
        test_fail("t07_subneg_escaped_iac", "expected EV_SB");
        return 1;
    }
    var buf = telnet_sb_buf(ts);
    var len = telnet_sb_len(ts);
    if (len != 4) {
        test_fail("t07_subneg_escaped_iac", "sb_len should be 4");
        return 1;
    }
    if ((load8(buf + 2) & 0xFF) != 0xFF) {
        test_fail("t07_subneg_escaped_iac", "byte 2 should be literal 0xFF");
        return 1;
    }
    test_pass("t07_subneg_escaped_iac");
    return 0;
}

# T8: data-IAC-data sequence (IAC DO ECHO sandwiched between 'X' and 'Y')
# emits exactly two data bytes and queues one 3-byte response.
fn t08_mixed_data_iac(): i64 {
    var ts = telnet_state_new();
    var data_count = 0;

    var ev1 = telnet_feed(ts, 0x58);  # 'X'
    if (ev1 == EV_DATA) { data_count = data_count + 1; }

    telnet_feed(ts, IAC);
    telnet_feed(ts, DO);
    telnet_feed(ts, OPT_ECHO);

    var ev2 = telnet_feed(ts, 0x59);  # 'Y'
    if (ev2 == EV_DATA) { data_count = data_count + 1; }

    if (data_count != 2) {
        test_fail("t08_mixed_data_iac", "should emit exactly 2 data bytes");
        return 1;
    }
    if (telnet_tx_len(ts) != 3) {
        test_fail("t08_mixed_data_iac", "should queue 3-byte IAC response");
        return 1;
    }
    test_pass("t08_mixed_data_iac");
    return 0;
}

# T9: malformed IAC inside SB (IAC followed by non-SE non-IAC) aborts the
# subneg cleanly without pinning the parser in SB_IAC state.
fn t09_subneg_malformed_recovers(): i64 {
    var ts = telnet_state_new();
    telnet_feed(ts, IAC);
    telnet_feed(ts, SB);
    telnet_feed(ts, OPT_STATUS);
    telnet_feed(ts, 0x42);
    telnet_feed(ts, IAC);
    telnet_feed(ts, NOP);   # malformed — NOP isn't valid after IAC inside SB

    # After recovery, a plain byte should come through as data.
    var ev = telnet_feed(ts, 0x5A);  # 'Z'
    if (ev != EV_DATA) {
        test_fail("t09_subneg_malformed_recovers", "parser should recover to DATA state");
        return 1;
    }
    if ((telnet_data_byte(ts) & 0xFF) != 0x5A) {
        test_fail("t09_subneg_malformed_recovers", "wrong data byte after recovery");
        return 1;
    }
    test_pass("t09_subneg_malformed_recovers");
    return 0;
}

# T10: telnet_announce queues the four-option opening salvo and
# parks each tracked option in Q_WANTYES on the appropriate side.
fn t10_announce_salvo(): i64 {
    var ts = telnet_state_new();
    telnet_announce(ts);

    var len = telnet_tx_len(ts);
    if (len != 12) {
        test_fail("t10_announce_salvo", "expected 12 bytes (4 × IAC verb opt)");
        return 1;
    }
    var buf = telnet_tx_buf(ts);
    # Order: WILL ECHO, WILL SGA, DO NAWS, DO TT
    if ((load8(buf + 0) & 0xFF) != IAC)                    { test_fail("t10_announce_salvo", "byte 0");  return 1; }
    if ((load8(buf + 1) & 0xFF) != WILL)                   { test_fail("t10_announce_salvo", "byte 1");  return 1; }
    if ((load8(buf + 2) & 0xFF) != OPT_ECHO)               { test_fail("t10_announce_salvo", "byte 2");  return 1; }
    if ((load8(buf + 3) & 0xFF) != IAC)                    { test_fail("t10_announce_salvo", "byte 3");  return 1; }
    if ((load8(buf + 4) & 0xFF) != WILL)                   { test_fail("t10_announce_salvo", "byte 4");  return 1; }
    if ((load8(buf + 5) & 0xFF) != OPT_SUPPRESS_GO_AHEAD)  { test_fail("t10_announce_salvo", "byte 5");  return 1; }
    if ((load8(buf + 6) & 0xFF) != IAC)                    { test_fail("t10_announce_salvo", "byte 6");  return 1; }
    if ((load8(buf + 7) & 0xFF) != DO)                     { test_fail("t10_announce_salvo", "byte 7");  return 1; }
    if ((load8(buf + 8) & 0xFF) != OPT_NAWS)               { test_fail("t10_announce_salvo", "byte 8");  return 1; }
    if ((load8(buf + 9) & 0xFF) != IAC)                    { test_fail("t10_announce_salvo", "byte 9");  return 1; }
    if ((load8(buf + 10) & 0xFF) != DO)                    { test_fail("t10_announce_salvo", "byte 10"); return 1; }
    if ((load8(buf + 11) & 0xFF) != OPT_TERMINAL_TYPE)     { test_fail("t10_announce_salvo", "byte 11"); return 1; }

    # All four parked in Q_WANTYES on the right side
    if (opt_us(ts, OPT_ECHO) != Q_WANTYES)                 { test_fail("t10_announce_salvo", "us-ECHO not WANTYES");  return 1; }
    if (opt_us(ts, OPT_SUPPRESS_GO_AHEAD) != Q_WANTYES)    { test_fail("t10_announce_salvo", "us-SGA not WANTYES");   return 1; }
    if (opt_him(ts, OPT_NAWS) != Q_WANTYES)                { test_fail("t10_announce_salvo", "him-NAWS not WANTYES"); return 1; }
    if (opt_him(ts, OPT_TERMINAL_TYPE) != Q_WANTYES)       { test_fail("t10_announce_salvo", "him-TT not WANTYES");   return 1; }

    test_pass("t10_announce_salvo");
    return 0;
}

# T11: post-announce, peer's DO ECHO reply is silent agreement —
# us-state moves WANTYES → YES, no reply on the wire.
fn t11_announce_then_do_silent(): i64 {
    var ts = telnet_state_new();
    telnet_announce(ts);
    telnet_tx_consume(ts);  # drain announce salvo

    telnet_feed(ts, IAC);
    telnet_feed(ts, DO);
    telnet_feed(ts, OPT_ECHO);

    if (telnet_tx_len(ts) != 0) {
        test_fail("t11_announce_then_do_silent", "WANTYES→YES must be silent");
        return 1;
    }
    if (opt_us(ts, OPT_ECHO) != Q_YES) {
        test_fail("t11_announce_then_do_silent", "us-ECHO should be Q_YES after agreement");
        return 1;
    }
    test_pass("t11_announce_then_do_silent");
    return 0;
}

# T12: post-announce, peer's DONT ECHO reply (refusal) silently
# moves us-state back to NO with no on-wire response.
fn t12_announce_then_dont_silent(): i64 {
    var ts = telnet_state_new();
    telnet_announce(ts);
    telnet_tx_consume(ts);

    telnet_feed(ts, IAC);
    telnet_feed(ts, DONT);
    telnet_feed(ts, OPT_ECHO);

    if (telnet_tx_len(ts) != 0) {
        test_fail("t12_announce_then_dont_silent", "WANTYES→NO must be silent");
        return 1;
    }
    if (opt_us(ts, OPT_ECHO) != Q_NO) {
        test_fail("t12_announce_then_dont_silent", "us-ECHO should be Q_NO after refusal");
        return 1;
    }
    test_pass("t12_announce_then_dont_silent");
    return 0;
}

# T13: untracked option (STATUS, code 5) still naive-refuses —
# Q machine only applies to options we declared a preference for.
fn t13_untracked_option_refused(): i64 {
    var ts = telnet_state_new();
    telnet_feed(ts, IAC);
    telnet_feed(ts, WILL);
    telnet_feed(ts, OPT_STATUS);

    if (telnet_tx_len(ts) != 3) {
        test_fail("t13_untracked_option_refused", "expected 3-byte refuse reply");
        return 1;
    }
    var buf = telnet_tx_buf(ts);
    if ((load8(buf + 1) & 0xFF) != DONT) {
        test_fail("t13_untracked_option_refused", "untracked WILL must DONT");
        return 1;
    }
    test_pass("t13_untracked_option_refused");
    return 0;
}

# T14: peer's WILL NAWS reply to our announce silently parks
# him-NAWS in Q_YES.
fn t14_announce_then_will_silent(): i64 {
    var ts = telnet_state_new();
    telnet_announce(ts);
    telnet_tx_consume(ts);

    telnet_feed(ts, IAC);
    telnet_feed(ts, WILL);
    telnet_feed(ts, OPT_NAWS);

    if (telnet_tx_len(ts) != 0) {
        test_fail("t14_announce_then_will_silent", "WANTYES→YES on him must be silent");
        return 1;
    }
    if (opt_him(ts, OPT_NAWS) != Q_YES) {
        test_fail("t14_announce_then_will_silent", "him-NAWS should be Q_YES");
        return 1;
    }
    test_pass("t14_announce_then_will_silent");
    return 0;
}

# T15a: NAWS subneg parses into term_cols / term_rows.
# Payload: IAC SB NAWS 0x00 0x50 0x00 0x18 IAC SE  → 80×24 (classic VT)
fn t16_naws_parse(): i64 {
    var ts = telnet_state_new();
    telnet_feed(ts, IAC);
    telnet_feed(ts, SB);
    telnet_feed(ts, OPT_NAWS);
    telnet_feed(ts, 0x00);
    telnet_feed(ts, 0x50);
    telnet_feed(ts, 0x00);
    telnet_feed(ts, 0x18);
    telnet_feed(ts, IAC);
    var ev = telnet_feed(ts, SE);
    if (ev != EV_SB) {
        test_fail("t16_naws_parse", "expected EV_SB");
        return 1;
    }
    telnet_handle_sb(ts);
    if (telnet_term_cols(ts) != 0x50) {
        test_fail("t16_naws_parse", "term_cols should be 80");
        return 1;
    }
    if (telnet_term_rows(ts) != 0x18) {
        test_fail("t16_naws_parse", "term_rows should be 24");
        return 1;
    }
    test_pass("t16_naws_parse");
    return 0;
}

# T17: NAWS with width=255 needs IAC IAC escaping in the payload —
# parser unescapes back to literal 0xFF.
# Payload: IAC SB NAWS 0x00 IAC IAC 0x00 0x18 IAC SE  → 255×24
fn t17_naws_iac_escape(): i64 {
    var ts = telnet_state_new();
    telnet_feed(ts, IAC);
    telnet_feed(ts, SB);
    telnet_feed(ts, OPT_NAWS);
    telnet_feed(ts, 0x00);
    telnet_feed(ts, IAC);
    telnet_feed(ts, IAC);   # escaped → literal 0xFF
    telnet_feed(ts, 0x00);
    telnet_feed(ts, 0x18);
    telnet_feed(ts, IAC);
    telnet_feed(ts, SE);
    telnet_handle_sb(ts);
    if (telnet_term_cols(ts) != 255) {
        test_fail("t17_naws_iac_escape", "term_cols should be 255");
        return 1;
    }
    if (telnet_term_rows(ts) != 0x18) {
        test_fail("t17_naws_iac_escape", "term_rows should be 24");
        return 1;
    }
    test_pass("t17_naws_iac_escape");
    return 0;
}

# T18: TERMINAL_TYPE IS payload stored as ASCII into term_type buffer.
# Payload: IAC SB TT IS X T E R M IAC SE  → "XTERM"
fn t18_terminal_type_is(): i64 {
    var ts = telnet_state_new();
    telnet_feed(ts, IAC);
    telnet_feed(ts, SB);
    telnet_feed(ts, OPT_TERMINAL_TYPE);
    telnet_feed(ts, TT_IS);
    telnet_feed(ts, 0x58);  # 'X'
    telnet_feed(ts, 0x54);  # 'T'
    telnet_feed(ts, 0x45);  # 'E'
    telnet_feed(ts, 0x52);  # 'R'
    telnet_feed(ts, 0x4D);  # 'M'
    telnet_feed(ts, IAC);
    telnet_feed(ts, SE);
    telnet_handle_sb(ts);

    var tt = telnet_term_type(ts);
    var ttlen = telnet_term_type_len(ts);
    if (ttlen != 5) {
        test_fail("t18_terminal_type_is", "term_type_len should be 5");
        return 1;
    }
    if ((load8(tt + 0) & 0xFF) != 0x58) { test_fail("t18_terminal_type_is", "byte 0"); return 1; }
    if ((load8(tt + 1) & 0xFF) != 0x54) { test_fail("t18_terminal_type_is", "byte 1"); return 1; }
    if ((load8(tt + 2) & 0xFF) != 0x45) { test_fail("t18_terminal_type_is", "byte 2"); return 1; }
    if ((load8(tt + 3) & 0xFF) != 0x52) { test_fail("t18_terminal_type_is", "byte 3"); return 1; }
    if ((load8(tt + 4) & 0xFF) != 0x4D) { test_fail("t18_terminal_type_is", "byte 4"); return 1; }
    test_pass("t18_terminal_type_is");
    return 0;
}

# T19: peer WILL TT → us-side him-TT lands Q_YES → ts_on_him_yes emits
# the 6-byte SEND request: IAC SB TT SEND IAC SE. Verified after the
# announce salvo so him-TT enters from Q_WANTYES.
fn t19_will_tt_emits_send(): i64 {
    var ts = telnet_state_new();
    telnet_announce(ts);
    telnet_tx_consume(ts);

    telnet_feed(ts, IAC);
    telnet_feed(ts, WILL);
    telnet_feed(ts, OPT_TERMINAL_TYPE);

    var len = telnet_tx_len(ts);
    if (len != 6) {
        test_fail("t19_will_tt_emits_send", "expected 6-byte SEND request");
        return 1;
    }
    var buf = telnet_tx_buf(ts);
    if ((load8(buf + 0) & 0xFF) != IAC)               { test_fail("t19_will_tt_emits_send", "byte 0"); return 1; }
    if ((load8(buf + 1) & 0xFF) != SB)                { test_fail("t19_will_tt_emits_send", "byte 1"); return 1; }
    if ((load8(buf + 2) & 0xFF) != OPT_TERMINAL_TYPE) { test_fail("t19_will_tt_emits_send", "byte 2"); return 1; }
    if ((load8(buf + 3) & 0xFF) != TT_SEND)           { test_fail("t19_will_tt_emits_send", "byte 3"); return 1; }
    if ((load8(buf + 4) & 0xFF) != IAC)               { test_fail("t19_will_tt_emits_send", "byte 4"); return 1; }
    if ((load8(buf + 5) & 0xFF) != SE)                { test_fail("t19_will_tt_emits_send", "byte 5"); return 1; }
    if (opt_him(ts, OPT_TERMINAL_TYPE) != Q_YES) {
        test_fail("t19_will_tt_emits_send", "him-TT should be Q_YES");
        return 1;
    }
    test_pass("t19_will_tt_emits_send");
    return 0;
}

# T20: NAWS with wrong payload length (3 bytes instead of 4) is
# silently dropped — defense in depth, malformed peers don't move
# our state.
fn t20_naws_malformed_dropped(): i64 {
    var ts = telnet_state_new();
    telnet_feed(ts, IAC);
    telnet_feed(ts, SB);
    telnet_feed(ts, OPT_NAWS);
    telnet_feed(ts, 0x00);
    telnet_feed(ts, 0x50);
    telnet_feed(ts, 0x00);
    telnet_feed(ts, IAC);
    telnet_feed(ts, SE);
    telnet_handle_sb(ts);
    if (telnet_term_cols(ts) != 0) {
        test_fail("t20_naws_malformed_dropped", "term_cols should stay 0");
        return 1;
    }
    test_pass("t20_naws_malformed_dropped");
    return 0;
}

# T21: peer WILL LINEMODE → server replies DO LINEMODE (Q_NO → Q_YES
# via opt_pref_him=1) and immediately emits the MODE request
# (IAC SB LINEMODE MODE EDIT|TRAPSIG IAC SE). Total tx_buf bytes: 3 + 7.
fn t21_will_linemode_emits_mode_request(): i64 {
    var ts = telnet_state_new();
    telnet_feed(ts, IAC);
    telnet_feed(ts, WILL);
    telnet_feed(ts, OPT_LINEMODE);

    var len = telnet_tx_len(ts);
    if (len != 10) {
        test_fail("t21_will_linemode_emits_mode_request", "expected 10 bytes (DO + MODE-req)");
        return 1;
    }
    var buf = telnet_tx_buf(ts);
    # 0..2 : IAC DO LINEMODE
    if ((load8(buf + 0) & 0xFF) != IAC)          { test_fail("t21_will_linemode_emits_mode_request", "byte 0"); return 1; }
    if ((load8(buf + 1) & 0xFF) != DO)           { test_fail("t21_will_linemode_emits_mode_request", "byte 1"); return 1; }
    if ((load8(buf + 2) & 0xFF) != OPT_LINEMODE) { test_fail("t21_will_linemode_emits_mode_request", "byte 2"); return 1; }
    # 3..9 : IAC SB LINEMODE LM_MODE 0x03 IAC SE
    if ((load8(buf + 3) & 0xFF) != IAC)          { test_fail("t21_will_linemode_emits_mode_request", "byte 3"); return 1; }
    if ((load8(buf + 4) & 0xFF) != SB)           { test_fail("t21_will_linemode_emits_mode_request", "byte 4"); return 1; }
    if ((load8(buf + 5) & 0xFF) != OPT_LINEMODE) { test_fail("t21_will_linemode_emits_mode_request", "byte 5"); return 1; }
    if ((load8(buf + 6) & 0xFF) != LM_MODE)      { test_fail("t21_will_linemode_emits_mode_request", "byte 6"); return 1; }
    if ((load8(buf + 7) & 0xFF) != 0x03)         { test_fail("t21_will_linemode_emits_mode_request", "byte 7"); return 1; }
    if ((load8(buf + 8) & 0xFF) != IAC)          { test_fail("t21_will_linemode_emits_mode_request", "byte 8"); return 1; }
    if ((load8(buf + 9) & 0xFF) != SE)           { test_fail("t21_will_linemode_emits_mode_request", "byte 9"); return 1; }
    if (opt_him(ts, OPT_LINEMODE) != Q_YES) {
        test_fail("t21_will_linemode_emits_mode_request", "him-LINEMODE should be Q_YES");
        return 1;
    }
    test_pass("t21_will_linemode_emits_mode_request");
    return 0;
}

# T22: peer's MODE ACK subneg parses into TS_LM_MODE.
# IAC SB LINEMODE MODE 0x07 IAC SE  (EDIT|TRAPSIG|MODE_ACK)
fn t22_linemode_mode_ack_parse(): i64 {
    var ts = telnet_state_new();
    telnet_feed(ts, IAC);
    telnet_feed(ts, SB);
    telnet_feed(ts, OPT_LINEMODE);
    telnet_feed(ts, LM_MODE);
    telnet_feed(ts, 0x07);   # EDIT | TRAPSIG | MODE_ACK
    telnet_feed(ts, IAC);
    var ev = telnet_feed(ts, SE);
    if (ev != EV_SB) {
        test_fail("t22_linemode_mode_ack_parse", "expected EV_SB");
        return 1;
    }
    telnet_handle_sb(ts);
    if (telnet_linemode_mask(ts) != 0x07) {
        test_fail("t22_linemode_mode_ack_parse", "lm_mask should be 0x07");
        return 1;
    }
    test_pass("t22_linemode_mode_ack_parse");
    return 0;
}

# T23: peer's SLC subneg is parsed-and-ignored — doesn't change
# lm_mask and doesn't corrupt the parser. SLC carries triplets
# (func, mod, val) and can be long; we accept any length.
fn t23_linemode_slc_ignored(): i64 {
    var ts = telnet_state_new();
    telnet_feed(ts, IAC);
    telnet_feed(ts, SB);
    telnet_feed(ts, OPT_LINEMODE);
    telnet_feed(ts, LM_SLC);
    # One triplet: func=3 (SLC_IP), mod=0, val=3 (Ctrl+C)
    telnet_feed(ts, 0x03);
    telnet_feed(ts, 0x00);
    telnet_feed(ts, 0x03);
    telnet_feed(ts, IAC);
    var ev = telnet_feed(ts, SE);
    if (ev != EV_SB) {
        test_fail("t23_linemode_slc_ignored", "expected EV_SB");
        return 1;
    }
    telnet_handle_sb(ts);
    if (telnet_linemode_mask(ts) != 0) {
        test_fail("t23_linemode_slc_ignored", "lm_mask should remain 0");
        return 1;
    }
    # Parser back in DATA — next byte comes through as data
    var ev2 = telnet_feed(ts, 0x42);
    if (ev2 != EV_DATA) {
        test_fail("t23_linemode_slc_ignored", "parser should recover to DATA");
        return 1;
    }
    test_pass("t23_linemode_slc_ignored");
    return 0;
}

# T24: malformed MODE subneg (wrong length — 2 bytes instead of 3)
# silently dropped, lm_mask stays 0.
fn t24_linemode_mode_malformed_dropped(): i64 {
    var ts = telnet_state_new();
    telnet_feed(ts, IAC);
    telnet_feed(ts, SB);
    telnet_feed(ts, OPT_LINEMODE);
    telnet_feed(ts, LM_MODE);
    # No mask byte — malformed
    telnet_feed(ts, IAC);
    telnet_feed(ts, SE);
    telnet_handle_sb(ts);
    if (telnet_linemode_mask(ts) != 0) {
        test_fail("t24_linemode_mode_malformed_dropped", "lm_mask must stay 0");
        return 1;
    }
    test_pass("t24_linemode_mode_malformed_dropped");
    return 0;
}

# T25-T29: M5-A board.cyr — post-id parsing + path building.
# Pure functions; no filesystem I/O in the test path (full round-trip
# verified via CLI smoke instead — see CHANGELOG [Unreleased] M5-A).

fn t25_parse_post_id_valid(): i64 {
    if (parse_post_id("1.txt") != 1)         { test_fail("t25_parse_post_id_valid", "1.txt");   return 1; }
    if (parse_post_id("42.txt") != 42)       { test_fail("t25_parse_post_id_valid", "42.txt");  return 1; }
    if (parse_post_id("9999.txt") != 9999)   { test_fail("t25_parse_post_id_valid", "9999.txt"); return 1; }
    test_pass("t25_parse_post_id_valid");
    return 0;
}

fn t26_parse_post_id_rejects_non_txt(): i64 {
    if (parse_post_id("1.log") != 0)         { test_fail("t26_parse_post_id_rejects_non_txt", "1.log");      return 1; }
    if (parse_post_id("1.tx") != 0)          { test_fail("t26_parse_post_id_rejects_non_txt", "1.tx");       return 1; }
    if (parse_post_id("1") != 0)             { test_fail("t26_parse_post_id_rejects_non_txt", "1 (no ext)"); return 1; }
    test_pass("t26_parse_post_id_rejects_non_txt");
    return 0;
}

fn t27_parse_post_id_rejects_non_digits(): i64 {
    if (parse_post_id("foo.txt") != 0)       { test_fail("t27_parse_post_id_rejects_non_digits", "foo.txt"); return 1; }
    if (parse_post_id("1a.txt") != 0)        { test_fail("t27_parse_post_id_rejects_non_digits", "1a.txt");  return 1; }
    if (parse_post_id("a1.txt") != 0)        { test_fail("t27_parse_post_id_rejects_non_digits", "a1.txt");  return 1; }
    if (parse_post_id("1.2.txt") != 0)       { test_fail("t27_parse_post_id_rejects_non_digits", "1.2.txt"); return 1; }
    test_pass("t27_parse_post_id_rejects_non_digits");
    return 0;
}

fn t28_parse_post_id_rejects_zero(): i64 {
    # IDs are 1-indexed — `0.txt` is reserved and rejected.
    if (parse_post_id("0.txt") != 0)         { test_fail("t28_parse_post_id_rejects_zero", "0.txt"); return 1; }
    test_pass("t28_parse_post_id_rejects_zero");
    return 0;
}

fn t29_build_post_path_shape(): i64 {
    # M5-E: build_post_path now takes (store, board, id). board=="main"
    # collapses to flat-root layout (free backwards compat with 0.4.0).
    var buf = alloc(PATH_MAX_BYTES);
    var len = build_post_path("/var/agora", "main", 42, buf);
    var expected = "/var/agora/42.txt";
    var exp_len = strlen(expected);
    if (len != exp_len) {
        test_fail("t29_build_post_path_shape", "length mismatch (main)");
        return 1;
    }
    if (memeq(buf, expected, exp_len) == 0) {
        test_fail("t29_build_post_path_shape", "byte mismatch (main)");
        return 1;
    }
    if ((load8(buf + len) & 0xFF) != 0) {
        test_fail("t29_build_post_path_shape", "missing NUL terminator (main)");
        return 1;
    }
    test_pass("t29_build_post_path_shape");
    return 0;
}

# T30: sort_i64_asc reorders an unsorted i64 array ascending.
# Matches the post_list use case where dir_list returns
# directory-iteration order and we need post IDs sorted for display.
fn t30_sort_i64_asc_basic(): i64 {
    var arr = alloc(8 * 8);
    store64(arr + 0 * 8, 5);
    store64(arr + 1 * 8, 2);
    store64(arr + 2 * 8, 9);
    store64(arr + 3 * 8, 1);
    store64(arr + 4 * 8, 7);
    store64(arr + 5 * 8, 3);
    store64(arr + 6 * 8, 8);
    store64(arr + 7 * 8, 4);
    sort_i64_asc(arr, 8);
    # NB: `var buf[N]` is N **bytes** in cyrius (per CLAUDE.md
    # Cyrius Conventions). 8 i64s = 64 bytes. Earlier drafts of this
    # test used `var expected[8]` and got 56-byte stack overruns
    # that the layout silently tolerated — fixed during the 0.4.0
    # closeout security re-scan.
    var expected[64];
    store64(&expected + 0 * 8, 1);
    store64(&expected + 1 * 8, 2);
    store64(&expected + 2 * 8, 3);
    store64(&expected + 3 * 8, 4);
    store64(&expected + 4 * 8, 5);
    store64(&expected + 5 * 8, 7);
    store64(&expected + 6 * 8, 8);
    store64(&expected + 7 * 8, 9);
    var i = 0;
    while (i < 8) {
        if (load64(arr + i * 8) != load64(&expected + i * 8)) {
            test_fail("t30_sort_i64_asc_basic", "mismatch at index");
            return 1;
        }
        i = i + 1;
    }
    test_pass("t30_sort_i64_asc_basic");
    return 0;
}

# T31: sort_i64_asc on empty and single-element arrays is a no-op
# (and doesn't crash). Edge cases that post_list hits on an empty
# store or a store with one post.
fn t31_sort_i64_asc_empty_and_single(): i64 {
    var arr = alloc(4 * 8);
    # Empty
    sort_i64_asc(arr, 0);
    # Single
    store64(arr + 0 * 8, 42);
    sort_i64_asc(arr, 1);
    if (load64(arr + 0 * 8) != 42) {
        test_fail("t31_sort_i64_asc_empty_and_single", "single-element value changed");
        return 1;
    }
    test_pass("t31_sort_i64_asc_empty_and_single");
    return 0;
}

# T32: input_byte_ok drops NUL + ESC, passes through everything else
# (TAB / CR / LF / printable ASCII / UTF-8 high bytes / BS / DEL).
fn t32_input_byte_ok_filters_nul_esc(): i64 {
    if (input_byte_ok(0)    != 0) { test_fail("t32_input_byte_ok_filters_nul_esc", "NUL should drop"); return 1; }
    if (input_byte_ok(0x1B) != 0) { test_fail("t32_input_byte_ok_filters_nul_esc", "ESC should drop"); return 1; }
    if (input_byte_ok(9)    != 1) { test_fail("t32_input_byte_ok_filters_nul_esc", "TAB should pass"); return 1; }
    if (input_byte_ok(10)   != 1) { test_fail("t32_input_byte_ok_filters_nul_esc", "LF should pass");  return 1; }
    if (input_byte_ok(13)   != 1) { test_fail("t32_input_byte_ok_filters_nul_esc", "CR should pass");  return 1; }
    if (input_byte_ok(32)   != 1) { test_fail("t32_input_byte_ok_filters_nul_esc", "space should pass"); return 1; }
    if (input_byte_ok(65)   != 1) { test_fail("t32_input_byte_ok_filters_nul_esc", "'A' should pass");   return 1; }
    if (input_byte_ok(126)  != 1) { test_fail("t32_input_byte_ok_filters_nul_esc", "'~' should pass");   return 1; }
    if (input_byte_ok(127)  != 1) { test_fail("t32_input_byte_ok_filters_nul_esc", "DEL should pass (BS handling is M5-B+ polish)"); return 1; }
    if (input_byte_ok(0xC3) != 1) { test_fail("t32_input_byte_ok_filters_nul_esc", "UTF-8 lead byte should pass"); return 1; }
    if (input_byte_ok(0xA9) != 1) { test_fail("t32_input_byte_ok_filters_nul_esc", "UTF-8 cont byte should pass"); return 1; }
    test_pass("t32_input_byte_ok_filters_nul_esc");
    return 0;
}

# T33: post_body_offset returns 0 (no headers) for content that
# doesn't start with an ASCII uppercase letter. Backwards-compat
# with M5-A/B/C posts (plaintext, no headers).
fn t33_post_body_offset_headerless(): i64 {
    var body = "just a plain body, no headers";
    var off = post_body_offset(body, strlen(body));
    if (off != 0) {
        test_fail("t33_post_body_offset_headerless", "expected 0 (headerless)");
        return 1;
    }
    test_pass("t33_post_body_offset_headerless");
    return 0;
}

# T34: post_body_offset finds the body after CRLF CRLF.
# Header block is `Subject: foo\r\nDate: bar\r\n\r\n` → body starts
# at offset of the byte after the second CRLF.
fn t34_post_body_offset_crlf(): i64 {
    var content = "Subject: hi\r\nDate: 2026\r\n\r\nbody";
    var off = post_body_offset(content, strlen(content));
    # Header block is "Subject: hi\r\nDate: 2026\r\n\r\n" = 27 bytes
    if (off != 27) {
        test_fail("t34_post_body_offset_crlf", "wrong body offset");
        return 1;
    }
    test_pass("t34_post_body_offset_crlf");
    return 0;
}

# T35: post_body_offset accepts LF-only (non-NVT) separators too.
fn t35_post_body_offset_lf(): i64 {
    var content = "Subject: hi\nDate: 2026\n\nbody";
    var off = post_body_offset(content, strlen(content));
    # Header block is "Subject: hi\nDate: 2026\n\n" = 24 bytes
    if (off != 24) {
        test_fail("t35_post_body_offset_lf", "wrong body offset (LF)");
        return 1;
    }
    test_pass("t35_post_body_offset_lf");
    return 0;
}

# T36: header_get extracts a Subject value from a well-formed
# header block, including the "skip optional single space after :"
# behavior.
fn t36_header_get_subject(): i64 {
    var content = "Subject: hello world\r\nDate: 2026-01-01T00:00:00Z\r\n\r\nbody";
    var out_buf = alloc(64);
    var n = header_get(content, strlen(content), "Subject", out_buf, 64);
    if (n != 11) {
        test_fail("t36_header_get_subject", "wrong length");
        return 1;
    }
    var expected = "hello world";
    if (memeq(out_buf, expected, 11) != 1) {
        test_fail("t36_header_get_subject", "byte mismatch");
        return 1;
    }
    test_pass("t36_header_get_subject");
    return 0;
}

# T37: header_get returns -1 when the header is absent.
fn t37_header_get_missing(): i64 {
    var content = "Subject: hi\r\nDate: 2026\r\n\r\nbody";
    var out_buf = alloc(64);
    var n = header_get(content, strlen(content), "From", out_buf, 64);
    if (n != (0 - 1)) {
        test_fail("t37_header_get_missing", "expected -1");
        return 1;
    }
    test_pass("t37_header_get_missing");
    return 0;
}

# T38: post_subject returns 0 (not -1) on headerless content —
# `list` always renders the bare ID and shows empty subject.
fn t38_post_subject_headerless_returns_zero(): i64 {
    var content = "plain body, no headers";
    var out_buf = alloc(64);
    var n = post_subject(content, strlen(content), out_buf, 64);
    if (n != 0) {
        test_fail("t38_post_subject_headerless_returns_zero", "expected 0");
        return 1;
    }
    test_pass("t38_post_subject_headerless_returns_zero");
    return 0;
}

# T39: build_post_path with a named board adds the subdirectory.
fn t39_build_post_path_named_board(): i64 {
