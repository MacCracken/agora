}

# T59: parse_auth_sig extracts a 64-byte signature from a well-formed line.
fn t59_parse_auth_sig_valid(): i64 {
    # 128 hex chars = 64 bytes
    var line = "auth: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef";
    var line_len = strlen(line);
    var sig[64];
    var n = parse_auth_sig(line, line_len, &sig);
    if (n != ACCOUNT_SIG_BYTES) {
        test_fail("t59_parse_auth_sig_valid", "wrong length");
        return 1;
    }
    # First byte should be 0x01 (from "01" at start of hex).
    if ((load8(&sig) & 0xFF) != 0x01) {
        test_fail("t59_parse_auth_sig_valid", "first byte mismatch");
        return 1;
    }
    test_pass("t59_parse_auth_sig_valid");
    return 0;
}

# T60: parse_auth_sig rejects malformed input.
fn t60_parse_auth_sig_rejects(): i64 {
    var sig[64];
    # Empty / too-short / wrong-prefix / wrong-length / non-hex
    if (parse_auth_sig(0, 0, &sig) >= 0)                         { test_fail("t60", "NUL ptr");      return 1; }
    if (parse_auth_sig("", 0, &sig) >= 0)                        { test_fail("t60", "empty");        return 1; }
    if (parse_auth_sig("hi", 2, &sig) >= 0)                      { test_fail("t60", "too short");    return 1; }
    if (parse_auth_sig("not-auth", 8, &sig) >= 0)                { test_fail("t60", "wrong prefix"); return 1; }
    if (parse_auth_sig("auth: 00", 8, &sig) >= 0)                { test_fail("t60", "too short hex");return 1; }
    # 127 hex chars (one short of 128)
    var short127 = "auth: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcde";
    if (parse_auth_sig(short127, strlen(short127), &sig) >= 0)   { test_fail("t60", "127 hex");      return 1; }
    # 128 chars but with a non-hex 'z'
    var nonhex  = "auth: z123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef";
    if (parse_auth_sig(nonhex, strlen(nonhex), &sig) >= 0)       { test_fail("t60", "non-hex char"); return 1; }
    test_pass("t60_parse_auth_sig_rejects");
    return 0;
}

# T61: parse_auth_sig tolerates optional single space after colon
# (both "auth:00..." and "auth: 00..." should work).
fn t61_parse_auth_sig_no_space(): i64 {
    var line = "auth:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef";
    var sig[64];
    var n = parse_auth_sig(line, strlen(line), &sig);
    if (n != ACCOUNT_SIG_BYTES) {
        test_fail("t61_parse_auth_sig_no_space", "should accept no-space form");
        return 1;
    }
    test_pass("t61_parse_auth_sig_no_space");
    return 0;
}

# === M6-D keyfile / seed-to-pk ===

# Helper: parse 2 hex chars into a byte. Returns 0..255 or -1 on
# non-hex. Used to load RFC 8032 test vectors as inline literals.
fn t_hex2(c1, c2): i64 {
    var hi = 0 - 1;
    if (c1 >= 48) { if (c1 <= 57)  { hi = c1 - 48; } }
    if (c1 >= 97) { if (c1 <= 102) { hi = c1 - 87; } }
    if (c1 >= 65) { if (c1 <= 70)  { hi = c1 - 55; } }
    var lo = 0 - 1;
    if (c2 >= 48) { if (c2 <= 57)  { lo = c2 - 48; } }
    if (c2 >= 97) { if (c2 <= 102) { lo = c2 - 87; } }
    if (c2 >= 65) { if (c2 <= 70)  { lo = c2 - 55; } }
    if (hi < 0) { return 0 - 1; }
    if (lo < 0) { return 0 - 1; }
    return (hi << 4) | lo;
}

# Decode a hex cstring into raw bytes. Assumes the input length is
# 2*expect_len. Writes expect_len bytes to out_buf. Returns
# expect_len on success, -1 on malformed.
fn t_hex_load(hex_str, expect_len, out_buf): i64 {
    var i = 0;
    while (i < expect_len) {
        var c1 = load8(hex_str + i * 2)     & 0xFF;
        var c2 = load8(hex_str + i * 2 + 1) & 0xFF;
        var b = t_hex2(c1, c2);
        if (b < 0) { return 0 - 1; }
        store8(out_buf + i, b);
        i = i + 1;
    }
    return expect_len;
}

# T62: seed_to_pk derives the RFC 8032 test-vector-1 pubkey from
# the RFC 8032 test-vector-1 seed.
#   seed: 9d61b19deffd5a60ba844af492ec2cc44449c5697b326919703bac031cae7f60
#   pk:   d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a
fn t62_seed_to_pk_rfc8032_v1(): i64 {
    var seed[32];
    t_hex_load("9d61b19deffd5a60ba844af492ec2cc44449c5697b326919703bac031cae7f60", 32, &seed);
    var pk[32];
    seed_to_pk(&seed, &pk);
    var expected[32];
    t_hex_load("d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a", 32, &expected);
    if (memeq(&pk, &expected, 32) == 0) {
        test_fail("t62_seed_to_pk_rfc8032_v1", "derived pk mismatch");
        return 1;
    }
    test_pass("t62_seed_to_pk_rfc8032_v1");
    return 0;
}

# T63: fingerprint of the RFC 8032 v1 pubkey is stable.
fn t63_fingerprint_of_rfc8032_v1_pk(): i64 {
    var pk[32];
    t_hex_load("d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a", 32, &pk);
    var fp[17];
    compute_fingerprint(&pk, &fp);
    # First 8 bytes of sha256(pk) = 21fe31dfa154a261
    # (computed externally: sha256(hex-decoded RFC 8032 v1 pk))
    var expected = "21fe31dfa154a261";
    if (memeq(&fp, expected, 16) == 0) {
        test_fail("t63_fingerprint_of_rfc8032_v1_pk", "fp mismatch");
        return 1;
    }
    test_pass("t63_fingerprint_of_rfc8032_v1_pk");
    return 0;
}

# === M6-E From-header round-trip ===

# T64: post_format writes a `From: <handle> <fp16>` line when both
# from_handle and from_fp are non-empty cstrings. 0.9.0 ABI struct.
fn t64_format_with_from_header(): i64 {
    var fbuf = alloc(POST_MAX_BYTES + 1024);
    var ph = post_headers_new();
    post_headers_set_subject(ph, "subj");
    post_headers_set_from(ph, "alice", "deadbeef12345678");
    var flen = post_format(ph, "body", 4, fbuf, POST_MAX_BYTES + 1024);
    if (flen < 0) {
        test_fail("t64_format_with_from_header", "format returned -1");
        return 1;
    }
    # The header block should contain the literal "From: alice deadbeef12345678\r\n"
    var needle = "From: alice deadbeef12345678";
    var nlen = strlen(needle);
    # Linear scan
    var i = 0;
    var found = 0;
    while (i + nlen <= flen) {
        if (memeq(fbuf + i, needle, nlen) == 1) {
            found = 1;
            i = flen;
            continue;
        }
        i = i + 1;
    }
    if (found == 0) {
        test_fail("t64_format_with_from_header", "From line missing");
        return 1;
    }
    test_pass("t64_format_with_from_header");
    return 0;
}

# T65: post_from extracts handle + fp from a well-formed header block.
# 0.9.0 ABI: PostHeaders struct.
fn t65_post_from_extracts(): i64 {
    var fbuf = alloc(POST_MAX_BYTES + 1024);
    var ph = post_headers_new();
    post_headers_set_subject(ph, "subj");
    post_headers_set_from(ph, "bob", "0123456789abcdef");
    var flen = post_format(ph, "body", 4, fbuf, POST_MAX_BYTES + 1024);
    var hbuf[33];
    var fpbuf[17];
    var ok = post_from(fbuf, flen, &hbuf, ACCOUNT_HANDLE_BUF, &fpbuf, ACCOUNT_FP_BUF_BYTES);
    if (ok != 1) {
        test_fail("t65_post_from_extracts", "post_from returned 0");
        return 1;
    }
    if (streq(&hbuf, "bob") == 0) {
        test_fail("t65_post_from_extracts", "handle mismatch");
        return 1;
    }
    if (streq(&fpbuf, "0123456789abcdef") == 0) {
        test_fail("t65_post_from_extracts", "fp mismatch");
        return 1;
    }
    test_pass("t65_post_from_extracts");
    return 0;
}

# T66: post_from on a header block without From → returns 0,
# writes empty cstrings to both out buffers (anonymous post).
# 0.9.0 ABI: PostHeaders struct (anonymous == default-constructed).
fn t66_post_from_absent_is_anonymous(): i64 {
    var fbuf = alloc(POST_MAX_BYTES + 1024);
    var ph = post_headers_new();
    post_headers_set_subject(ph, "subj");
    # No set_from call → from_handle / from_fp default to 0 → anonymous.
    var flen = post_format(ph, "body", 4, fbuf, POST_MAX_BYTES + 1024);
    var hbuf[33];
    var fpbuf[17];
    # Pre-fill to detect that they get zeroed
    store8(&hbuf, 0x41);
    store8(&fpbuf, 0x41);
    var ok = post_from(fbuf, flen, &hbuf, ACCOUNT_HANDLE_BUF, &fpbuf, ACCOUNT_FP_BUF_BYTES);
    if (ok != 0) {
        test_fail("t66_post_from_absent_is_anonymous", "expected 0");
        return 1;
    }
    if ((load8(&hbuf) & 0xFF) != 0) {
        test_fail("t66_post_from_absent_is_anonymous", "handle not NUL-zeroed");
        return 1;
    }
    if ((load8(&fpbuf) & 0xFF) != 0) {
        test_fail("t66_post_from_absent_is_anonymous", "fp not NUL-zeroed");
        return 1;
    }
    test_pass("t66_post_from_absent_is_anonymous");
    return 0;
}

